---
import fs from "node:fs";
import path from "node:path";
import yaml from "js-yaml";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { PROJECT_VERSION_LABEL } from "../../lib/project-version";
import { getMonitoringStatus } from "../../lib/runtime-monitoring-data";
import {
  getReviewQueueSummary,
  getSourceFreshnessSummary,
  getOperatorReviewSummary,
  getRegulationReviewQueue,
  getSignalQualitySummary,
  getIngressFilterSummary,
} from "../../lib/regulation-review-queue";

const healthPath = path.join(process.cwd(), "public/data/runtime-db-health.json");
const monitoring = getMonitoringStatus();
const reviewSummary = getReviewQueueSummary();
const freshnessSummary = getSourceFreshnessSummary();
const operatorSummary = getOperatorReviewSummary();
const reviewQueue = getRegulationReviewQueue();
const signalSummary = getSignalQualitySummary();
const ingressSummary = getIngressFilterSummary();
const signalRulesPath = path.join(process.cwd(), "data/runtime/signal-quality-rules.yml");
let signalRulesValid = false;
let signalRulesError: string | null = null;
try {
  yaml.load(fs.readFileSync(signalRulesPath, "utf8"));
  signalRulesValid = true;
} catch (e) {
  signalRulesError = e instanceof Error ? e.message : "invalid YAML";
}
const decisionsPath = path.join(process.cwd(), "data/runtime/operator-review-decisions.yml");
const packetsPath = path.join(process.cwd(), "public/data/review-packets-index.json");
const runtimePath = path.join(process.cwd(), "data/runtime/automation-runtime.yml");

let decisionsFileValid = false;
let decisionsFileError: string | null = null;
try {
  const raw = fs.readFileSync(decisionsPath, "utf8");
  yaml.load(raw);
  decisionsFileValid = true;
} catch (e) {
  decisionsFileError = e instanceof Error ? e.message : "invalid YAML";
}

const packetsIndex = fs.existsSync(packetsPath)
  ? (JSON.parse(fs.readFileSync(packetsPath, "utf8")) as { packet_count?: number })
  : null;
const staleUnreviewed =
  (reviewSummary.review_required ?? 0) + (reviewSummary.needs_source_check ?? 0);

const health = fs.existsSync(healthPath)
  ? (JSON.parse(fs.readFileSync(healthPath, "utf8")) as Record<string, unknown>)
  : null;

const runtime = fs.existsSync(runtimePath)
  ? (yaml.load(fs.readFileSync(runtimePath, "utf8")) as Record<string, unknown>)
  : null;

const status = (health?.status as string) ?? "unknown";
const missingTables = (health?.missing_tables as string[]) ?? [];
const presentTables = (health?.expected_tables_present as string[]) ?? [];
---

<BaseLayout
  title="Runtime health"
  currentPath="/runtime-health/"
  description="Backend runtime and Supabase/Postgres health — metadata only, live monitoring disabled."
>
  <h1>Runtime health</h1>
  <p class="lead">
    T079 dev Worker activation ({PROJECT_VERSION_LABEL}). Public view of tracked runtime DB health and
    pilot monitoring status — no credentials, no legal text, no broad live ingestion.
  </p>

  <div class="banner banner--review" role="note">
    <strong>Not live monitoring.</strong> Live ingestion, scheduled monitoring, and network execution are
    disabled. This page shows metadata-only health from <code>runtime-db-health.json</code>.
  </div>

  <section>
    <h2>Backend runtime</h2>
    <dl class="meta-grid">
      <div><dt>runtime_id</dt><dd><span class="mono">{runtime?.runtime_id ?? "—"}</span></dd></div>
      <div><dt>status</dt><dd><span class="mono">{runtime?.status ?? "—"}</span></dd></div>
      <div><dt>backend_target</dt><dd><span class="mono">{runtime?.backend_target ?? "—"}</span></dd></div>
      <div><dt>checked_at</dt><dd><span class="mono">{health?.checked_at ?? "—"}</span></dd></div>
    </dl>
  </section>

  <section>
    <h2>Supabase / Postgres</h2>
    <dl class="meta-grid">
      <div><dt>db_health_status</dt><dd><strong>{status}</strong></dd></div>
      <div><dt>schema_name</dt><dd><span class="mono">{health?.schema_name ?? "public"}</span></dd></div>
      <div><dt>runtime_environment</dt><dd><span class="mono">{health?.runtime_environment ?? "—"}</span></dd></div>
      <div><dt>runtime_event_count</dt><dd>{health?.runtime_event_count ?? "—"}</dd></div>
      <div><dt>latest_runtime_event_at</dt><dd><span class="mono">{health?.latest_runtime_event_at ?? "—"}</span></dd></div>
    </dl>
  </section>

  <section>
    <h2>Schema tables</h2>
    {presentTables.length > 0 ? (
      <p>Present: {presentTables.map((t) => <code>{t}</code>)}</p>
    ) : (
      <p>No tables reported present (DB may be not configured).</p>
    )}
    {missingTables.length > 0 && (
      <p class="warn">Missing: {missingTables.map((t) => <code>{t}</code>).join(", ")}</p>
    )}
  </section>

  <section>
    <h2>Backend monitoring MVP (T078)</h2>
    <dl class="meta-grid">
      <div><dt>monitoring_status</dt><dd><strong>{monitoring.status ?? "—"}</strong></dd></div>
      <div><dt>backend_mvp</dt><dd><span class="mono">{monitoring.backend_mvp ?? "—"}</span></dd></div>
      <div><dt>monitored_sources</dt><dd>{monitoring.monitored_source_count ?? "—"}</dd></div>
      <div><dt>automated_rss</dt><dd>{monitoring.automated_rss_source_count ?? monitoring.automated_source_count ?? "—"}</dd></div>
      <div><dt>manual_review_sources</dt><dd>{monitoring.manual_review_source_count ?? monitoring.manual_source_count ?? "—"}</dd></div>
      <div><dt>detected_changes</dt><dd>{monitoring.detected_changes_count ?? "—"}</dd></div>
      <div><dt>review_candidates</dt><dd>{monitoring.review_candidates_count ?? "—"}</dd></div>
      <div><dt>latest_run</dt><dd><span class="mono">{monitoring.latest_run?.run_id ?? "—"}</span></dd></div>
      <div><dt>worker_deployed</dt><dd>{monitoring.worker_deployed ? "yes" : "no"}</dd></div>
      <div><dt>latest_worker_run</dt><dd><span class="mono">{monitoring.latest_worker_run?.run_id ?? "—"}</span></dd></div>
      <div><dt>source_runs_count</dt><dd>{monitoring.source_runs_count ?? "—"}</dd></div>
    </dl>
    <p><a href="/data/runtime-monitoring-status.json">runtime-monitoring-status.json</a></p>
  </section>

  <section>
    <h2>Operator workflow health (T082)</h2>
    <dl class="meta-grid">
      <div>
        <dt>operator_decisions_file</dt>
        <dd>
          {decisionsFileValid ? (
            <strong>valid YAML</strong>
          ) : (
            <span class="warn">invalid — {decisionsFileError}</span>
          )}
        </dd>
      </div>
      <div><dt>local_decisions</dt><dd>{operatorSummary.decision_count ?? 0}</dd></div>
      <div><dt>applied_to_queue</dt><dd>{reviewSummary.with_operator_decision ?? 0}</dd></div>
      <div><dt>review_packets</dt><dd>{packetsIndex?.packet_count ?? 0}</dd></div>
      <div><dt>stale_unreviewed_high</dt><dd>{staleUnreviewed}</dd></div>
      <div><dt>in_review</dt><dd>{reviewSummary.in_review ?? 0}</dd></div>
      <div><dt>tracking_only</dt><dd>{reviewSummary.accepted_for_tracking ?? 0}</dd></div>
      <div><dt>dismissed</dt><dd>{reviewSummary.dismissed ?? 0}</dd></div>
    </dl>
    <p>
      Decisions file: <code>data/runtime/operator-review-decisions.yml</code> · Guide:{" "}
      <code>docs/OPERATOR_REVIEW_WORKFLOW.md</code>
    </p>
  </section>

  <section>
    <h2>Ingress filtering (T084)</h2>
    <dl class="meta-grid">
      <div><dt>ingress_rules_version</dt><dd><span class="mono">{ingressSummary.rules_version ?? "—"}</span></dd></div>
      <div><dt>validation</dt><dd>validate:ingress-filtering (build)</dd></div>
      <div><dt>automated_sources_ready</dt><dd>{ingressSummary.automated_source_count ?? monitoring.automated_source_count ?? "—"}</dd></div>
      <div><dt>operator_visible_queue</dt><dd>{ingressSummary.operator_visible_count ?? reviewQueue.operator_queue_card_count ?? "—"}</dd></div>
      <div><dt>suppress_noise</dt><dd>{ingressSummary.suppress_noise_count ?? 0}</dd></div>
      <div><dt>suppress_duplicate</dt><dd>{ingressSummary.suppress_duplicate_count ?? 0}</dd></div>
      <div><dt>cron_enabled</dt><dd>false</dd></div>
      <div><dt>scheduled_monitoring</dt><dd>false</dd></div>
      <div><dt>gates_closed</dt><dd>{ingressSummary.gates_closed === true ? "yes" : "no"}</dd></div>
    </dl>
    <p>
      <a href="/data/ingress-filter-summary.json">ingress-filter-summary.json</a> ·{" "}
      <code>data/runtime/monitoring-pilot-registry.yml</code>
    </p>
  </section>

  <section>
    <h2>Signal quality (T083)</h2>
    <dl class="meta-grid">
      <div>
        <dt>signal_rules_file</dt>
        <dd>
          {signalRulesValid ? (
            <strong>valid YAML</strong>
          ) : (
            <span class="warn">invalid — {signalRulesError}</span>
          )}
        </dd>
      </div>
      <div><dt>rules_version</dt><dd><span class="mono">{signalSummary.rules_version ?? "—"}</span></dd></div>
      <div><dt>validation</dt><dd>validate:signal-quality (build)</dd></div>
      <div><dt>gates_closed</dt><dd>{signalSummary.gates_closed === true ? "yes" : "no"}</dd></div>
      <div><dt>high_relevance</dt><dd>{signalSummary.high_relevance_count ?? 0}</dd></div>
      <div><dt>noise_count</dt><dd>{signalSummary.noise_count ?? 0}</dd></div>
      <div><dt>dismiss_recommended</dt><dd>{signalSummary.dismiss_recommended_count ?? 0}</dd></div>
      <div><dt>review_now</dt><dd>{signalSummary.review_now_count ?? 0}</dd></div>
    </dl>
    <p>
      <a href="/data/signal-quality-summary.json">signal-quality-summary.json</a> ·{" "}
      <code>data/runtime/signal-quality-rules.yml</code>
    </p>
  </section>

  <section>
    <h2>Review queue &amp; source freshness (T081)</h2>
    <dl class="meta-grid">
      <div><dt>review_queue_total</dt><dd>{reviewSummary.total ?? 0}</dd></div>
      <div><dt>review_required</dt><dd>{reviewSummary.review_required ?? 0}</dd></div>
      <div><dt>high_priority</dt><dd>{reviewSummary.high_priority ?? 0}</dd></div>
      <div><dt>fresh_sources</dt><dd>{freshnessSummary.fresh ?? 0}</dd></div>
      <div><dt>stale_sources</dt><dd>{freshnessSummary.stale ?? 0}</dd></div>
      <div><dt>manual_review_needed</dt><dd>{freshnessSummary.manual_review_needed ?? 0}</dd></div>
      <div><dt>queue_decision_counts</dt><dd class="mono">{JSON.stringify(reviewQueue.decision_counts ?? {})}</dd></div>
    </dl>
    <p>
      <a href="/review-queue/">Review queue</a> ·{" "}
      <a href="/data/regulation-review-queue.json">regulation-review-queue.json</a> ·{" "}
      <a href="/data/source-freshness.json">source-freshness.json</a> ·{" "}
      <a href="/data/operator-review-summary.json">operator-review-summary.json</a>
    </p>
  </section>

  <section>
    <h2>Safety flags (public export)</h2>
    <dl class="meta-grid">
      <div><dt>live_ingestion_enabled</dt><dd>false</dd></div>
      <div><dt>scheduled_monitoring_enabled</dt><dd>false</dd></div>
      <div><dt>network_execution_enabled</dt><dd>false</dd></div>
    </dl>
  </section>

  <section>
    <h2>Notice</h2>
    <p>{health?.public_note ?? "Metadata-only runtime health export."}</p>
    <ul>
      <li>No database host, URL, keys, or passwords on this page.</li>
      <li>No full legal text stored in the runtime schema.</li>
      <li>Not legal advice; not verified legal change.</li>
    </ul>
  </section>

  <section>
    <h2>Related</h2>
    <ul>
      <li><a href="/automation/">Automation runtime</a></li>
      <li><a href="/runtime-services/">Runtime services onboarding</a></li>
      <li><a href="/source-pilot/">Source pilot</a></li>
      <li><a href="/source-pilot/review/">Source pilot review</a></li>
      <li><a href="/monitoring/">Monitoring (file-based)</a></li>
      <li><a href="/data/runtime-db-health.json">runtime-db-health.json</a></li>
      <li><a href="/data/automation-runtime-manifest.json">automation-runtime-manifest.json</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .warn {
    color: var(--warn, #8a4510);
  }
</style>
