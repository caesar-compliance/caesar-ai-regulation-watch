---
import { getTaxonomies, taxonomyLabel } from "../lib/data";

interface Props {
  status: string;
}

const { status } = Astro.props;
const taxonomies = getTaxonomies();
const label = taxonomyLabel(taxonomies, "review-statuses", status);
---

<span class={`badge badge--review-${status}`} title={status}>{label}</span>
