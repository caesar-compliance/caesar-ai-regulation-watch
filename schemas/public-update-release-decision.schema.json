{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/public-update-release-decision.schema.json",
  "title": "Caesar AI Regulation Watch — Public update release decision",
  "description": "Internal public update release decision. Records publication hold or release — not automatic publication.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "public_update_release_decisions_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_live_collection",
    "no_scheduled_monitoring",
    "decisions"
  ],
  "properties": {
    "public_update_release_decisions_id": {
      "type": "string",
      "pattern": "^public-update-release-decisions-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_collection": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/decisionRecord" }
    }
  },
  "$defs": {
    "gateState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false }
      }
    },
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_update_release_decision_recorded",
        "publication_allowed",
        "public_export_allowed",
        "evidence_export_allowed",
        "client_use_allowed",
        "public_update_route_created",
        "public_data_inclusion_allowed",
        "metadata_only",
        "stores_full_text",
        "requires_explicit_publication_release_approval",
        "requires_separate_client_evidence_approval"
      ],
      "properties": {
        "public_update_release_decision_recorded": { "type": "boolean" },
        "publication_allowed": { "type": "boolean", "const": false },
        "public_export_allowed": { "type": "boolean", "const": false },
        "evidence_export_allowed": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "public_update_route_created": { "type": "boolean", "const": false },
        "public_data_inclusion_allowed": { "type": "boolean", "const": false },
        "metadata_only": { "type": "boolean", "const": true },
        "stores_full_text": { "type": "boolean", "const": false },
        "requires_explicit_publication_release_approval": { "type": "boolean", "const": true },
        "requires_separate_client_evidence_approval": { "type": "boolean", "const": true }
      }
    },
    "decisionScope": {
      "type": "string",
      "const": "internal_public_update_release_decision_only"
    },
    "decisionStatus": {
      "type": "string",
      "enum": ["recorded", "superseded"]
    },
    "decisionValue": {
      "type": "string",
      "enum": [
        "hold_publication_pending_explicit_release_approval",
        "approve_publication_release",
        "reject_publication_release",
        "request_changes"
      ]
    },
    "decisionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "public_export_approval_decision_id",
        "release_gate_id",
        "staging_preview_id",
        "draft_update_id",
        "draft_update_path",
        "proposed_public_update_id",
        "proposed_route",
        "decision_scope",
        "decision_status",
        "decision",
        "decision_summary",
        "hold_reasons",
        "release_requirements_remaining",
        "next_required_step",
        "decided_by_role",
        "decided_at",
        "created_at",
        "updated_at",
        "gates",
        "safety"
      ],
      "properties": {
        "decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "public_export_approval_decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "release_gate_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "staging_preview_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "draft_update_id": { "type": "string", "minLength": 1 },
        "draft_update_path": { "type": "string", "pattern": "^data/regulatory-updates/drafts/" },
        "proposed_public_update_id": { "type": "string", "minLength": 1 },
        "proposed_route": { "type": "string", "pattern": "^/updates/" },
        "decision_scope": { "$ref": "#/$defs/decisionScope" },
        "decision_status": { "$ref": "#/$defs/decisionStatus" },
        "decision": { "$ref": "#/$defs/decisionValue" },
        "decision_summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "hold_reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "release_requirements_remaining": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "next_required_step": { "type": "string", "minLength": 1 },
        "decided_by_role": { "type": "string", "minLength": 1 },
        "decided_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" },
        "gates": { "$ref": "#/$defs/gateState" },
        "safety": { "$ref": "#/$defs/safetyFlags" }
      }
    }
  }
}
