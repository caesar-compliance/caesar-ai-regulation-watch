---
import type { EnrichedCountryStatus } from "../lib/tracker-data";
import { STATUS_BUCKET_LABELS } from "../lib/tracker-data";
import ChoroplethLegend from "./ChoroplethLegend.astro";

interface Props {
  items: EnrichedCountryStatus[];
  linkBase?: string;
}

const { items, linkBase = "/jurisdictions/" } = Astro.props;

const byRegion = items.reduce(
  (acc, cs) => {
    const list = acc.get(cs.region) ?? [];
    list.push(cs);
    acc.set(cs.region, list);
    return acc;
  },
  new Map<string, EnrichedCountryStatus[]>(),
);

const regions = [...byRegion.entries()].sort(([a], [b]) => a.localeCompare(b));
---

<div class="choropleth-map" aria-label="Regulation status choropleth panel (pilot jurisdictions)">
  <p class="choropleth-map__note">
    Status visualization is based on current tracker metadata and pilot coverage (13
    jurisdictions). This is an abstract regional panel — not precise geographic boundaries. Not legal
    advice. Not complete global coverage.
  </p>

  <div class="choropleth-map__layout">
    <div class="choropleth-map__panel">
      <svg
        class="choropleth-map__svg"
        viewBox="0 0 900 420"
        role="img"
        aria-label="Regional status choropleth panel"
      >
        <rect x="0" y="0" width="900" height="420" fill="var(--color-accent-soft)" rx="10" />
        <text x="450" y="26" text-anchor="middle" class="choropleth-map__svg-title">
          Pilot jurisdiction status surface (T050)
        </text>
        {
          regions.map(([region], i) => {
            const col = i % 3;
            const row = Math.floor(i / 3);
            const x = 24 + col * 290;
            const y = 44 + row * 118;
            const regionItems = byRegion.get(region) ?? [];
            const avgMaturity =
              regionItems.length > 0
                ? Math.round(
                    regionItems.reduce((s, c) => s + c.regulation_maturity_score, 0) /
                      regionItems.length,
                  )
                : 0;
            return (
              <g>
                <rect
                  x={x}
                  y={y}
                  width="270"
                  height="100"
                  rx="8"
                  fill="var(--color-surface)"
                  stroke="var(--color-border)"
                />
                <text x={x + 12} y={y + 22} class="choropleth-map__region-label">
                  {region}
                </text>
                <text x={x + 12} y={y + 42} class="choropleth-map__region-meta">
                  {regionItems.length} jurisdiction{regionItems.length === 1 ? "" : "s"} · avg
                  maturity {avgMaturity}
                </text>
                <rect
                  x={x + 12}
                  y={y + 54}
                  width={246}
                  height="8"
                  rx="4"
                  fill="var(--color-border)"
                />
                <rect
                  x={x + 12}
                  y={y + 54}
                  width={Math.max(8, Math.round((246 * avgMaturity) / 100))}
                  height="8"
                  rx="4"
                  fill="#5c7cfa"
                  opacity="0.85"
                />
              </g>
            );
          })
        }
      </svg>

      <div class="choropleth-map__tiles">
        {
          regions.map(([region, regionItems]) => (
            <section class="choropleth-map__region-block">
              <h3 class="choropleth-map__region-heading">{region}</h3>
              <div class="choropleth-tiles">
                {regionItems
                  .sort((a, b) => a.country_name.localeCompare(b.country_name))
                  .map((cs) => (
                    <a
                      href={`${linkBase}${cs.jurisdiction_id}/`}
                      class={`choropleth-tile choropleth-tile--${cs.status_bucket}`}
                      title={cs.comparison_summary}
                    >
                      <span class="choropleth-tile__name">{cs.country_name}</span>
                      <span class="choropleth-tile__status">
                        {STATUS_BUCKET_LABELS[cs.status_bucket]}
                      </span>
                      <span class="choropleth-tile__metrics">
                        Maturity {cs.regulation_maturity_score} · Activity {cs.activity_score} ·{" "}
                        {cs.latest_update_count} update{cs.latest_update_count === 1 ? "" : "s"}
                      </span>
                      <span
                        class="choropleth-tile__bar"
                        style={`--maturity: ${cs.regulation_maturity_score}%`}
                        aria-hidden="true"
                      />
                    </a>
                  ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>

    <ChoroplethLegend />
  </div>

  <p class="choropleth-map__cta">
    <a href="/compare/">Compare jurisdictions (2–4) →</a>
  </p>
</div>
