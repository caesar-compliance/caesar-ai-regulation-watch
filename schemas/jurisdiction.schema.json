{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/jurisdiction.schema.json",
  "title": "Caesar AI Regulation Watch — Jurisdiction (pilot)",
  "description": "Pilot jurisdiction record for curated EU/Norway monitoring. Not legal advice.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "jurisdiction_id",
    "name",
    "type",
    "region",
    "regulatory_focus",
    "monitoring_priority",
    "notes",
    "review_status"
  ],
  "properties": {
    "jurisdiction_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "description": "Stable slug (e.g. eu, norway)"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "country",
        "supranational_bloc",
        "region",
        "territory",
        "other"
      ]
    },
    "region": {
      "type": "string",
      "minLength": 1
    },
    "parent_jurisdiction": {
      "type": ["string", "null"],
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "regulatory_focus": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "monitoring_priority": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "notes": {
      "type": "string",
      "minLength": 1,
      "description": "Coverage limits and review disclaimers"
    },
    "review_status": {
      "type": "string",
      "enum": ["pending_review", "reviewed", "archived"]
    }
  }
}
