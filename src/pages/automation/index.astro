---
import fs from "node:fs";
import path from "node:path";
import yaml from "js-yaml";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { PROJECT_VERSION_LABEL } from "../../lib/project-version";

const configPath = path.join(process.cwd(), "data/runtime/automation-runtime.yml");
const runtime = fs.existsSync(configPath)
  ? (yaml.load(fs.readFileSync(configPath, "utf8")) as Record<string, unknown>)
  : null;

const plannedTables = (runtime?.planned_tables as string[]) ?? [];
const sourceCandidates = (runtime?.first_source_candidates as string[]) ?? [];
const policy = (runtime?.source_policy as Record<string, boolean>) ?? {};
---

<BaseLayout
  title="Automation runtime"
  currentPath="/automation/"
  description="Automation runtime foundation status for Regulation Watch — design ready, live ingestion disabled."
>
  <h1>Automation Runtime Foundation</h1>
  <p class="lead">
    Production-oriented monitoring architecture scaffold ({PROJECT_VERSION_LABEL}). Status:{" "}
    <strong>{runtime?.status ?? "backend_bootstrap_ready"}</strong> — live ingestion not enabled yet.
  </p>

  <div class="banner banner--review" role="note">
    <strong>Not live monitoring.</strong> T074 adds runtime DB health tooling and Supabase apply helper; live
    ingestion, scheduled monitoring, and network execution remain disabled. See{" "}
    <a href="/runtime-health/">Runtime health</a>.
  </div>

  <section>
    <h2>Architecture</h2>
    <div class="status-cards">
      <div class="status-card">
        <h3>Supabase / Postgres</h3>
        <p>Monitored sources, runs, snapshots, items, detected changes, review candidates.</p>
      </div>
      <div class="status-card">
        <h3>Cloudflare Worker</h3>
        <p>Allowlisted RSS metadata checks; manual <code>/run/:sourceKey</code> when approved.</p>
      </div>
      <div class="status-card">
        <h3>GitHub Pages</h3>
        <p>Public tracker and JSON exports from hosted pipeline (future).</p>
      </div>
      <div class="status-card">
        <h3>Review queue</h3>
        <p>Detected changes → human triage before any public update.</p>
      </div>
      <div class="status-card">
        <h3>Future API / RSS / search</h3>
        <p>After runtime bootstrap and Control Tower approval.</p>
      </div>
    </div>
  </section>

  <section>
    <h2>Runtime safety</h2>
    <dl class="meta-grid">
      <div><dt>live_ingestion_enabled</dt><dd>false</dd></div>
      <div><dt>scheduled_monitoring_enabled</dt><dd>false</dd></div>
      <div><dt>network_execution_enabled</dt><dd>false</dd></div>
      <div><dt>allowlisted_sources_only</dt><dd>{String(policy.allowlisted_sources_only ?? true)}</dd></div>
      <div><dt>no_broad_crawl</dt><dd>{String(policy.no_broad_crawl ?? true)}</dd></div>
      <div><dt>metadata_only</dt><dd>{String(policy.metadata_only ?? true)}</dd></div>
      <div><dt>full_text_storage_allowed</dt><dd>false</dd></div>
      <div><dt>runtime_id</dt><dd><span class="mono">{runtime?.runtime_id ?? "regulation-watch-runtime-v1"}</span></dd></div>
      <div><dt>status</dt><dd><span class="mono">{runtime?.status ?? "design_ready"}</span></dd></div>
    </dl>
  </section>

  <section>
    <h2>Planned tables</h2>
    <ul>
      {plannedTables.map((t) => (
        <li><code>{t}</code></li>
      ))}
    </ul>
  </section>

  <section>
    <h2>First source candidates</h2>
    <ul>
      {sourceCandidates.map((k) => (
        <li><code>{k}</code></li>
      ))}
    </ul>
  </section>

  <section>
    <h2>Setup checklist</h2>
    <ol>
      <li>Create Supabase project</li>
      <li>Apply <code>ops/supabase/001_regulation_watch_runtime_schema.sql</code></li>
      <li>Configure Worker secrets from <code>wrangler.toml.example</code></li>
      <li>Deploy Worker (not done in T073)</li>
      <li>Run manual allowlisted source check</li>
      <li>Wire detected changes to review queue</li>
    </ol>
  </section>

  <section>
    <h2>Related</h2>
    <ul>
      <li><a href="/source-adapters/">Source adapters</a></li>
      <li><a href="/public-export-gate/">Public export gate</a></li>
      <li><a href="/publication-release/">Publication release</a></li>
      <li><a href="/tracker/">Tracker</a></li>
      <li><a href="/updates/">Updates</a></li>
      <li><a href="/runtime-health/">Runtime health</a></li>
      <li><a href="/source-pilot/">Source pilot</a></li>
      <li><a href="/source-pilot/review/">Source pilot review</a></li>
      <li><a href="/source-pilot/decision-packets/">Source pilot decision packets</a></li>
      <li><a href="/data/runtime-db-health.json">runtime-db-health.json</a></li>
      <li><a href="/data/automation-runtime-manifest.json">automation-runtime-manifest.json</a></li>
      <li><a href="/review-queue/">Review queue</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .status-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 0.75rem;
    margin: 1rem 0 1.5rem;
  }
  .status-card {
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    border: 1px solid var(--border, #ccc);
    background: var(--surface, #f8f8f8);
  }
  .status-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
  }
  .status-card p {
    margin: 0;
    font-size: 0.9rem;
  }
</style>
