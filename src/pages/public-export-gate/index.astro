---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublicExportReleaseGateCockpitCase } from "../../lib/data";
import { PROJECT_VERSION_LABEL } from "../../lib/project-version";

const GATE_ID = "T069-001";
const EXPORT_APPROVAL_ID = "T070-001";
const RELEASE_DECISION_ID = "T071-001";
const cockpit = getPublicExportReleaseGateCockpitCase(GATE_ID);

if (!cockpit) {
  throw new Error(`Public export release gate cockpit case missing: ${GATE_ID}`);
}

const {
  gate,
  stagingPreview,
  publicationGateDecision,
  publicationGatePacket,
  publicExportApprovalDecision,
  publicUpdateReleaseDecision,
  draft,
} = cockpit;

const approvalDecision = publicExportApprovalDecision;
const releaseDecision = publicUpdateReleaseDecision;
const proposedRoute = gate.candidate_metadata.proposed_route;

const readyItems = gate.release_gate_items.filter(
  (i) => i.status === "ready_for_approval_review",
);
const blockedItems = gate.release_gate_items.filter((i) => i.status === "blocked");
---

<BaseLayout
  title="Public Export Release Gate"
  description="Internal public export release gate — not published, not exported to public/data, gates closed."
  currentPath="/public-export-gate/"
  noindex={true}
>
  <h1>Public Export Release Gate</h1>
  <p class="lead">
    Internal public export release gate ({PROJECT_VERSION_LABEL}). Candidate metadata for
    separate approval review — no publish, export, or approval controls on this page.
  </p>

  <div class="banner banner--danger" role="alert">
    <strong>Internal release gate only.</strong> Not a public regulatory update. Not exported to
    public/data. Not client/evidence ready. All publication, public export, and evidence gates
    remain closed. No verified legal-change claim.
  </div>

  {
    approvalDecision && (
      <div class="banner banner--warn" role="alert">
        <strong>Non-public preview artifact only.</strong> Decision{" "}
        <code>{approvalDecision.decision_id}</code> —{" "}
        <code>{approvalDecision.decision}</code>. Does not publish. Does not add to public/data.
        Public export and client/evidence remain blocked.
      </div>
    )
  }

  {
    releaseDecision && (
      <div class="banner banner--danger" role="alert">
        <strong>Publication held.</strong> Release decision{" "}
        <code>{releaseDecision.decision_id}</code> —{" "}
        <code>{releaseDecision.decision}</code>. No public route or public/data inclusion.
        Explicit publication release approval required before any publish step.
      </div>
    )
  }

  <div class="status-cards">
    <div class="status-card status-card--pending">
      <strong>Gate result</strong>
      <code>{gate.gate_result}</code>
    </div>
    <div class="status-card status-card--pending">
      <strong>Ready for approval review</strong>
      <span>Yes — internal next step only</span>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Public export</strong>
      <span>Not allowed</span>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Publication</strong>
      <span>Not allowed</span>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Client / evidence</strong>
      <span>Blocked</span>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Gates</strong>
      <span>Closed — verification and legal-change gates false</span>
    </div>
  </div>

  <section>
    <h2>Gate record</h2>
    <dl class="meta-grid">
      <div><dt>Gate ID</dt><dd><span class="mono">{gate.gate_id}</span></dd></div>
      <div><dt>Gate scope</dt><dd><span class="mono">{gate.gate_scope}</span></dd></div>
      <div><dt>Gate status</dt><dd><span class="mono">{gate.gate_status}</span></dd></div>
      <div><dt>Staging preview</dt><dd><span class="mono">{gate.staging_preview_id}</span></dd></div>
      <div><dt>Draft ID</dt><dd><span class="mono">{draft?.draft_id ?? gate.draft_update_id}</span></dd></div>
      <div><dt>Update ID</dt><dd><span class="mono">{gate.draft_update_id}</span></dd></div>
    </dl>
    <p>{gate.gate_summary}</p>
  </section>

  {
    approvalDecision && (
      <section>
        <h2>Public export approval decision</h2>
        <dl class="meta-grid">
          <div><dt>Decision ID</dt><dd><span class="mono">{approvalDecision.decision_id}</span></dd></div>
          <div><dt>Decision</dt><dd><span class="mono">{approvalDecision.decision}</span></dd></div>
          <div><dt>Status</dt><dd><span class="mono">{approvalDecision.decision_status}</span></dd></div>
          <div><dt>Release gate</dt><dd><span class="mono">{approvalDecision.release_gate_id}</span></dd></div>
          <div><dt>Preview artifact</dt><dd><span class="mono">{approvalDecision.non_public_preview_artifact_path}</span></dd></div>
          <div><dt>Next step</dt><dd><span class="mono">{approvalDecision.next_required_step}</span></dd></div>
          <div><dt>publication_allowed</dt><dd>false</dd></div>
          <div><dt>public_export_allowed</dt><dd>false</dd></div>
          <div><dt>client_use_allowed</dt><dd>false</dd></div>
          <div><dt>evidence_export_allowed</dt><dd>false</dd></div>
        </dl>
        <p>{approvalDecision.decision_summary}</p>
        <h3>Preview limitations</h3>
        <ul>
          {approvalDecision.preview_limitations.map((l) => <li>{l}</li>)}
        </ul>
        <h3>Blockers remaining</h3>
        <ul>
          {approvalDecision.blockers_remaining.map((b) => <li>{b}</li>)}
        </ul>
      </section>
    )
  }

  {
    releaseDecision && (
      <section>
        <h2>Public update release decision</h2>
        <dl class="meta-grid">
          <div><dt>Decision ID</dt><dd><span class="mono">{releaseDecision.decision_id}</span></dd></div>
          <div><dt>Decision</dt><dd><span class="mono">{releaseDecision.decision}</span></dd></div>
          <div><dt>Status</dt><dd><span class="mono">{releaseDecision.decision_status}</span></dd></div>
          <div><dt>Export approval</dt><dd><span class="mono">{releaseDecision.public_export_approval_decision_id}</span></dd></div>
          <div><dt>Proposed update ID</dt><dd><span class="mono">{releaseDecision.proposed_public_update_id}</span></dd></div>
          <div><dt>Proposed route</dt><dd><span class="mono">{releaseDecision.proposed_route}</span> (text only — not generated)</dd></div>
          <div><dt>Next step</dt><dd><span class="mono">{releaseDecision.next_required_step}</span></dd></div>
          <div><dt>publication_allowed</dt><dd>false</dd></div>
          <div><dt>public_export_allowed</dt><dd>false</dd></div>
          <div><dt>public_data_inclusion_allowed</dt><dd>false</dd></div>
          <div><dt>public_update_route_created</dt><dd>false</dd></div>
          <div><dt>client_use_allowed</dt><dd>false</dd></div>
          <div><dt>evidence_export_allowed</dt><dd>false</dd></div>
        </dl>
        <p>{releaseDecision.decision_summary}</p>
        <h3>Hold reasons</h3>
        <ul>
          {releaseDecision.hold_reasons.map((r) => <li>{r}</li>)}
        </ul>
        <h3>Release requirements remaining</h3>
        <ul>
          {releaseDecision.release_requirements_remaining.map((r) => <li>{r}</li>)}
        </ul>
      </section>
    )
  }

  {
    approvalDecision && stagingPreview && (
      <section>
        <h2>Non-public preview artifact</h2>
        <p class="card__excerpt">
          Metadata-only candidate for a future public update — preview artifact path only. Not a
          live public update page.
        </p>
        <dl class="meta-grid">
          <div><dt>Proposed public update ID</dt><dd><span class="mono">{gate.candidate_metadata.proposed_public_update_id}</span></dd></div>
          <div><dt>Proposed route</dt><dd><span class="mono">{proposedRoute}</span> (not generated — disabled)</dd></div>
          <div><dt>Title</dt><dd>{stagingPreview.preview_title}</dd></div>
          <div><dt>Summary</dt><dd>{stagingPreview.preview_summary}</dd></div>
          <div><dt>Status</dt><dd><span class="mono">non_public_export_preview</span></dd></div>
        </dl>
      </section>
    )
  }

  <section>
    <h2>Candidate metadata</h2>
    <p class="card__excerpt">
      Proposed public update candidate for a future separate public export approval decision. Route
      and ID are planning metadata only — no public update page generated in T069.
    </p>
    <dl class="meta-grid">
      <div><dt>Candidate ID</dt><dd><span class="mono">{gate.candidate_metadata.candidate_id}</span></dd></div>
      <div><dt>Proposed public update ID</dt><dd><span class="mono">{gate.candidate_metadata.proposed_public_update_id}</span></dd></div>
      <div><dt>Proposed route</dt><dd><span class="mono">{gate.candidate_metadata.proposed_route}</span></dd></div>
      <div><dt>Jurisdictions</dt><dd>{gate.candidate_metadata.jurisdiction_ids.join(", ")}</dd></div>
      <div><dt>Topics</dt><dd>{gate.candidate_metadata.topic_ids.join(", ")}</dd></div>
      <div><dt>Source</dt><dd><span class="mono">{gate.candidate_metadata.source_id}</span></dd></div>
      <div><dt>Adapter</dt><dd><span class="mono">{gate.candidate_metadata.source_adapter_id}</span></dd></div>
      <div><dt>Source URL</dt><dd>
        <a href={gate.candidate_metadata.source_url} rel="noopener noreferrer">
          {gate.candidate_metadata.source_url}
        </a>
      </dd></div>
    </dl>
  </section>

  <section>
    <h2>Release gate checklist</h2>
    <table class="checklist-table">
      <thead>
        <tr>
          <th>Item</th>
          <th>Status</th>
          <th>Note</th>
          <th>Owner</th>
        </tr>
      </thead>
      <tbody>
        {gate.release_gate_items.map((item) => (
          <tr>
            <td><span class="mono">{item.item_id}</span></td>
            <td><code>{item.status}</code></td>
            <td>{item.note}</td>
            <td><span class="mono">{item.owner_role}</span></td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="timeline-detail">
      Ready for approval review: {readyItems.length} · Blocked: {blockedItems.length}
    </p>
  </section>

  <section>
    <h2>Blockers remaining</h2>
    <ul>
      {gate.blockers_remaining.map((b) => <li>{b}</li>)}
    </ul>
  </section>

  <section>
    <h2>Safety and gates</h2>
    <dl class="meta-grid">
      <div><dt>public_export_gate_ready</dt><dd>true</dd></div>
      <div><dt>ready_for_public_export_approval</dt><dd>true</dd></div>
      <div><dt>publication_allowed</dt><dd>false</dd></div>
      <div><dt>public_export_allowed</dt><dd>false</dd></div>
      <div><dt>evidence_export_allowed</dt><dd>false</dd></div>
      <div><dt>client_use_allowed</dt><dd>false</dd></div>
      <div><dt>verified_on_source</dt><dd>false</dd></div>
      <div><dt>legal_change_claimed</dt><dd>false</dd></div>
      <div><dt>client_evidence_allowed</dt><dd>false</dd></div>
      <div><dt>final_evidence_allowed</dt><dd>false</dd></div>
      <div><dt>metadata_only</dt><dd>true</dd></div>
      <div><dt>stores_full_text</dt><dd>false</dd></div>
      <div><dt>requires_public_export_approval_decision</dt><dd>true</dd></div>
      <div><dt>requires_publication_release_approval</dt><dd>true</dd></div>
      <div><dt>requires_client_evidence_approval</dt><dd>true</dd></div>
    </dl>
  </section>

  <section>
    <h2>Pipeline</h2>
    <ol class="timeline">
      <li>
        <span class="mono">T067</span> — Publication gate decision{" "}
        <code>{publicationGateDecision?.decision_id ?? gate.publication_gate_decision_id}</code>{" "}
        (<span class="mono">{publicationGateDecision?.decision ?? "—"}</span>)
      </li>
      <li>
        <span class="mono">T068</span> — Publication staging preview{" "}
        <code>{stagingPreview?.preview_id ?? gate.staging_preview_id}</code> (
        <span class="mono">{stagingPreview?.preview_status ?? "—"}</span>)
      </li>
      <li>
        <span class="mono">T069</span> — Public export release gate <code>{gate.gate_id}</code> (
        <span class="mono">{gate.gate_result}</span>)
      </li>
      {
        approvalDecision && (
          <li>
            <span class="mono">T070</span> — Public export approval decision{" "}
            <code>{approvalDecision.decision_id}</code> (
            <span class="mono">{approvalDecision.decision}</span>)
          </li>
        )
      }
      {
        releaseDecision && (
          <li>
            <span class="mono">T071</span> — Public update release decision{" "}
            <code>{releaseDecision.decision_id}</code> (
            <span class="mono">{releaseDecision.decision}</span>)
          </li>
        )
      }
      <li>
        <span class="mono">Next</span> —{" "}
        <code>{releaseDecision?.next_required_step ?? approvalDecision?.next_required_step ?? gate.next_required_step}</code> (not
        completed)
      </li>
    </ol>
    {
      publicationGatePacket && (
        <p class="timeline-detail">
          Gate packet <code>{publicationGatePacket.packet_id}</code> —{" "}
          <code>{publicationGatePacket.gate_result}</code>
        </p>
      )
    }
  </section>

  <section>
    <h2>Related</h2>
    <ul>
      <li><a href="/publication-staging/">Publication staging preview</a></li>
      <li><a href="/publication-gate/">Publication gate packet</a></li>
      <li><a href="/legal-review/">Final legal review packet</a></li>
      <li><a href="/source-verification/">Source verification cockpit</a></li>
      <li><a href="/source-adapters/">Source adapters pipeline</a></li>
      <li><a href="/tracker/">Automation-first tracker</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .status-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 0.75rem;
    margin: 1rem 0 1.5rem;
  }
  .status-card {
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    border: 1px solid var(--border, #ccc);
    background: var(--surface, #f8f8f8);
  }
  .status-card strong {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
  }
  .status-card--pending code {
    color: var(--accent-warn, #8a6d00);
  }
  .status-card--blocked span {
    color: var(--accent-danger, #a00);
  }
  .banner--warn {
    border-color: var(--accent-warn, #8a6d00);
    background: color-mix(in srgb, var(--accent-warn, #8a6d00) 8%, transparent);
    margin-bottom: 1.25rem;
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    border-width: 1px;
    border-style: solid;
  }
  .banner--danger {
    border-color: var(--accent-danger, #a00);
    background: color-mix(in srgb, var(--accent-danger, #a00) 8%, transparent);
    margin-bottom: 1.25rem;
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    border-width: 1px;
    border-style: solid;
  }
  .checklist-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .checklist-table th,
  .checklist-table td {
    border: 1px solid var(--border, #ddd);
    padding: 0.4rem 0.6rem;
    text-align: left;
    vertical-align: top;
  }
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .timeline li {
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--border, #eee);
  }
  .timeline-detail {
    color: var(--text-muted, #666);
    font-size: 0.9em;
    margin-top: 0.5rem;
  }
</style>
