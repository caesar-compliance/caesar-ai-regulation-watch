---
import fs from "node:fs";
import path from "node:path";
import yaml from "js-yaml";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { PROJECT_VERSION_LABEL } from "../../lib/project-version";

const statusPath = path.join(process.cwd(), "public/data/source-pilot-status.json");
const registryPath = path.join(process.cwd(), "data/runtime/source-pilot-registry.yml");
const runtimePath = path.join(process.cwd(), "data/runtime/automation-runtime.yml");

const status = fs.existsSync(statusPath)
  ? (JSON.parse(fs.readFileSync(statusPath, "utf8")) as Record<string, unknown>)
  : null;

const registry = fs.existsSync(registryPath)
  ? (yaml.load(fs.readFileSync(registryPath, "utf8")) as Record<string, unknown>)
  : null;

const runtime = fs.existsSync(runtimePath)
  ? (yaml.load(fs.readFileSync(runtimePath, "utf8")) as Record<string, unknown>)
  : null;

const sources = (status?.sources as Record<string, unknown>[]) ?? [];
const runtimeFlags = (status?.runtime_flags as Record<string, boolean>) ?? {};
const gates = (status?.gates as Record<string, boolean>) ?? {};
---

<BaseLayout
  title="Source pilot"
  currentPath="/source-pilot/"
  description="Controlled allowlisted source pilot framework — metadata only, no live network execution."
>
  <h1>Controlled source pilot</h1>
  <p class="lead">
    T075A source pilot framework ({PROJECT_VERSION_LABEL}). Metadata-only registry and fixture-based
    dry-run status — not live monitoring.
  </p>

  <div class="banner banner--review" role="note">
    <strong>Offline framework only.</strong> No live network execution, no scheduled monitoring, no full
    legal text storage. Evidence and publication gates remain closed. Next step: Supabase runtime
    connection and explicit Control Tower network approval.
  </div>

  <section>
    <h2>Framework status</h2>
    <dl class="meta-grid">
      <div><dt>pilot_status</dt><dd><strong>{status?.status ?? "—"}</strong></dd></div>
      <div><dt>runtime_status</dt><dd><span class="mono">{runtime?.status ?? "—"}</span></dd></div>
      <div><dt>source_count</dt><dd>{status?.source_count ?? "—"}</dd></div>
      <div><dt>checked_at</dt><dd><span class="mono">{status?.checked_at ?? "—"}</span></dd></div>
      <div><dt>detected_metadata_changes</dt><dd>{status?.detected_metadata_changes_count ?? 0}</dd></div>
      <div><dt>latest_fixture_snapshot_at</dt><dd><span class="mono">{status?.latest_fixture_snapshot_at ?? "—"}</span></dd></div>
    </dl>
  </section>

  <section>
    <h2>Runtime safety flags</h2>
    <dl class="meta-grid">
      <div><dt>live_ingestion_enabled</dt><dd>{runtimeFlags.live_ingestion_enabled === false ? "false" : "—"}</dd></div>
      <div><dt>scheduled_monitoring_enabled</dt><dd>{runtimeFlags.scheduled_monitoring_enabled === false ? "false" : "—"}</dd></div>
      <div><dt>network_execution_enabled</dt><dd>{runtimeFlags.network_execution_enabled === false ? "false" : "—"}</dd></div>
    </dl>
  </section>

  <section>
    <h2>Evidence &amp; publication gates</h2>
    <dl class="meta-grid">
      <div><dt>verified_on_source</dt><dd>false</dd></div>
      <div><dt>client_use_allowed</dt><dd>false</dd></div>
      <div><dt>publication_allowed</dt><dd>false</dd></div>
      <div><dt>public_export_allowed</dt><dd>false</dd></div>
    </dl>
    <p class="muted">All gates in public export: {Object.values(gates).every((v) => v === false) ? "closed" : "check export"}</p>
  </section>

  <section>
    <h2>Pilot sources</h2>
    {sources.length === 0 ? (
      <p>No sources in status export. Run <code>npm run build:source-pilot-status</code>.</p>
    ) : (
      <table class="data-table">
        <thead>
          <tr>
            <th>source_id</th>
            <th>monitoring_status</th>
            <th>adapter</th>
            <th>items</th>
            <th>network</th>
          </tr>
        </thead>
        <tbody>
          {sources.map((s) => (
            <tr>
              <td><code>{s.source_id}</code></td>
              <td>{s.monitoring_status}</td>
              <td><span class="mono">{s.adapter_type}</span></td>
              <td>{s.item_count}</td>
              <td>{s.allowed_for_network_check === false ? "disabled" : "—"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
    <p class="muted">{registry?.legal_safe_note ?? ""}</p>
  </section>

  <section>
    <h2>What this is not</h2>
    <ul>
      <li>Not automated crawling or broad external fetching.</li>
      <li>Not storage of full legal text or raw webpage bodies.</li>
      <li>Not verified legal change or client evidence use.</li>
      <li>Not publication or public export approval.</li>
    </ul>
  </section>

  <section>
    <h2>Next steps</h2>
    <ol>
      <li>Configure Supabase runtime credentials and apply schema (T075B).</li>
      <li>Persist pilot snapshots and detected changes to runtime DB when approved.</li>
      <li>Explicit controlled network check only after Control Tower approval (T076+).</li>
    </ol>
  </section>

  <section>
    <h2>Related</h2>
    <ul>
      <li><a href="/automation/">Automation runtime</a></li>
      <li><a href="/runtime-health/">Runtime health</a></li>
      <li><a href="/source-adapters/">Source adapters</a></li>
      <li><a href="/data/source-pilot-status.json">source-pilot-status.json</a></li>
      <li><a href="/data/automation-runtime-manifest.json">automation-runtime-manifest.json</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .data-table {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
  }
  .data-table th,
  .data-table td {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border, #ddd);
  }
  .muted {
    font-size: 0.9rem;
    color: var(--muted, #555);
  }
</style>
