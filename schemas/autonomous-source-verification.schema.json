{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/autonomous-source-verification.schema.json",
  "title": "Caesar AI Regulation Watch — Autonomous official source verification batch",
  "description": "Machine verification attempts on blocked or priority official sources. No WAF bypass. No full text storage. Not client evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "autonomous_source_verification_batch_id",
    "run_date",
    "verifier_type",
    "legal_safe_note",
    "verifications"
  ],
  "properties": {
    "autonomous_source_verification_batch_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "run_date": {
      "type": "string",
      "format": "date"
    },
    "verifier_type": {
      "type": "string",
      "enum": ["human_reviewer", "automated_check_pending", "curator_batch", "autonomous_worker"]
    },
    "legal_safe_note": {
      "type": "string",
      "minLength": 1
    },
    "verifications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "verification_id",
          "related_source_id",
          "official_url",
          "verification_strategy",
          "verification_result",
          "source_identity_confirmed",
          "full_instrument_identity_confirmed",
          "content_not_copied",
          "no_full_text_storage",
          "no_bypass_attempted",
          "client_use_allowed",
          "final_evidence_allowed",
          "verified_on_source",
          "legal_change_claimed",
          "limitations",
          "next_action",
          "checked_at",
          "legal_safe_note"
        ],
        "properties": {
          "verification_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "related_source_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "related_record_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "related_candidate_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "official_url": {
            "type": "string",
            "format": "uri"
          },
          "verification_strategy": {
            "type": "string",
            "enum": [
              "official_api",
              "official_sparql",
              "official_pdf",
              "official_alternative",
              "browser_worker",
              "metadata_fetch",
              "failed_safe"
            ]
          },
          "verification_result": {
            "type": "string",
            "enum": [
              "machine_verified_identity",
              "official_api_verified_identity",
              "official_sparql_verified_identity",
              "browser_worker_verified_identity",
              "official_alternative_verified_identity",
              "machine_unverifiable",
              "blocked_by_waf_or_bot_gate",
              "access_failed",
              "needs_human_policy_decision"
            ]
          },
          "http_status": {
            "type": ["integer", "null"],
            "minimum": 0,
            "maximum": 599
          },
          "final_url": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "visible_or_extracted_title": {
            "type": ["string", "null"],
            "maxLength": 400
          },
          "official_identifier": {
            "type": ["string", "null"],
            "maxLength": 80
          },
          "publisher_or_authority": {
            "type": ["string", "null"],
            "maxLength": 200
          },
          "publication_date_or_visible_date": {
            "type": ["string", "null"],
            "maxLength": 80
          },
          "source_identity_confirmed": {
            "type": "boolean"
          },
          "full_instrument_identity_confirmed": {
            "type": "boolean"
          },
          "content_not_copied": {
            "type": "boolean",
            "const": true
          },
          "no_full_text_storage": {
            "type": "boolean",
            "const": true
          },
          "no_bypass_attempted": {
            "type": "boolean",
            "const": true
          },
          "client_use_allowed": {
            "type": "boolean",
            "const": false
          },
          "final_evidence_allowed": {
            "type": "boolean",
            "const": false
          },
          "verified_on_source": {
            "type": "boolean",
            "const": false
          },
          "legal_change_claimed": {
            "type": "boolean",
            "const": false
          },
          "strategies_attempted": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 120
            },
            "maxItems": 12
          },
          "limitations": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "next_action": {
            "type": "string",
            "enum": [
              "no_action_recorded",
              "retry_official_machine_later",
              "await_browser_worker_support",
              "needs_human_policy_decision",
              "corroborate_on_eur_lex_when_accessible",
              "document_blocker_only"
            ]
          },
          "checked_at": {
            "type": "string",
            "format": "date-time"
          },
          "legal_safe_note": {
            "type": "string",
            "minLength": 1,
            "maxLength": 800
          }
        }
      }
    }
  }
}
