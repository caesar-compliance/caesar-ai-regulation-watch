{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/country-status.schema.json",
  "title": "Caesar AI Regulation Watch — Country regulation status (automation-first seed)",
  "description": "Per-jurisdiction AI regulation status for public tracker skeleton. Not legal advice.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "jurisdiction_id",
    "country_name",
    "region",
    "status_bucket",
    "status_label",
    "status_summary",
    "last_update_date",
    "source_ids",
    "topic_tags",
    "confidence_score",
    "automation_method",
    "requires_human_review",
    "client_evidence_allowed",
    "final_evidence_allowed",
    "legal_change_claimed",
    "legal_safe_note"
  ],
  "properties": {
    "jurisdiction_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "country_name": { "type": "string", "minLength": 1 },
    "region": { "type": "string", "minLength": 1 },
    "status_bucket": {
      "type": "string",
      "enum": [
        "adopted",
        "proposed",
        "consultation",
        "guidance",
        "enforcement",
        "monitoring",
        "no_clear_framework"
      ]
    },
    "status_label": { "type": "string", "minLength": 1 },
    "status_summary": { "type": "string", "minLength": 1 },
    "last_update_date": { "type": "string", "format": "date" },
    "latest_update_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
      "uniqueItems": true
    },
    "topic_tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
      "uniqueItems": true
    },
    "confidence_score": {
      "type": "string",
      "enum": ["high", "medium", "low", "blocked"]
    },
    "automation_method": {
      "type": "string",
      "enum": ["manual_seed", "api", "rss", "official_feed", "official_page", "public_page"]
    },
    "requires_human_review": { "type": "boolean" },
    "client_evidence_allowed": { "type": "boolean" },
    "final_evidence_allowed": { "type": "boolean" },
    "legal_change_claimed": { "type": "boolean" },
    "legal_safe_note": { "type": "string", "minLength": 1 }
  }
}
