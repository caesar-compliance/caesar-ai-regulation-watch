{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RegulationMapMetricsExport",
  "type": "object",
  "required": ["markers", "generated_at", "map_version"],
  "properties": {
    "generated_at": { "type": "string" },
    "map_version": { "type": "string" },
    "markers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["jurisdiction_id", "maturity_score", "activity_score"],
        "properties": {
          "jurisdiction_id": { "type": "string" },
          "maturity_score": { "type": "number" },
          "activity_score": { "type": "number" },
          "freshness_score": { "type": "number" },
          "confidence_score": { "type": "number" },
          "review_required": { "type": "boolean" }
        }
      }
    }
  }
}
