{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/publication-staging-preview.schema.json",
  "title": "Caesar AI Regulation Watch — Publication staging preview",
  "description": "Internal publication staging preview record. Not publication. Not public export.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "publication_staging_previews_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_live_collection",
    "no_scheduled_monitoring",
    "previews"
  ],
  "properties": {
    "publication_staging_previews_id": {
      "type": "string",
      "pattern": "^publication-staging-previews-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_collection": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "previews": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/previewRecord" }
    }
  },
  "$defs": {
    "gateState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false }
      }
    },
    "previewMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_url",
        "jurisdiction_ids",
        "topic_ids",
        "source_id",
        "source_adapter_id"
      ],
      "properties": {
        "source_url": { "type": "string", "format": "uri" },
        "jurisdiction_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "topic_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "source_id": { "type": "string", "minLength": 1 },
        "source_adapter_id": { "type": "string", "minLength": 1 }
      }
    },
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "staging_preview_created",
        "publication_allowed",
        "public_export_allowed",
        "evidence_export_allowed",
        "client_use_allowed",
        "metadata_only",
        "stores_full_text",
        "noindex_requested",
        "requires_public_export_approval",
        "requires_publication_release_approval",
        "requires_client_evidence_approval"
      ],
      "properties": {
        "staging_preview_created": { "type": "boolean", "const": true },
        "publication_allowed": { "type": "boolean", "const": false },
        "public_export_allowed": { "type": "boolean", "const": false },
        "evidence_export_allowed": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "metadata_only": { "type": "boolean", "const": true },
        "stores_full_text": { "type": "boolean", "const": false },
        "noindex_requested": { "type": "boolean", "const": true },
        "requires_public_export_approval": { "type": "boolean", "const": true },
        "requires_publication_release_approval": { "type": "boolean", "const": true },
        "requires_client_evidence_approval": { "type": "boolean", "const": true }
      }
    },
    "previewScope": {
      "type": "string",
      "const": "internal_publication_staging_preview"
    },
    "previewStatus": {
      "type": "string",
      "enum": ["generated_internal_preview", "superseded", "blocked"]
    },
    "previewRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_id",
        "publication_gate_decision_id",
        "publication_gate_packet_id",
        "draft_update_id",
        "draft_update_path",
        "preview_scope",
        "preview_status",
        "preview_route",
        "preview_title",
        "preview_summary",
        "preview_metadata",
        "staging_limitations",
        "blockers_remaining",
        "next_required_step",
        "created_at",
        "updated_at",
        "gates",
        "safety"
      ],
      "properties": {
        "preview_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "publication_gate_decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "publication_gate_packet_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "draft_update_id": { "type": "string", "minLength": 1 },
        "draft_update_path": { "type": "string", "pattern": "^data/regulatory-updates/drafts/" },
        "preview_scope": { "$ref": "#/$defs/previewScope" },
        "preview_status": { "$ref": "#/$defs/previewStatus" },
        "preview_route": { "type": "string", "minLength": 1 },
        "preview_title": { "type": "string", "minLength": 1, "maxLength": 500 },
        "preview_summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "preview_metadata": { "$ref": "#/$defs/previewMetadata" },
        "staging_limitations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "blockers_remaining": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "next_required_step": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" },
        "gates": { "$ref": "#/$defs/gateState" },
        "safety": { "$ref": "#/$defs/safetyFlags" }
      }
    }
  }
}
