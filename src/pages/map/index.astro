---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TrackerChoroplethMap from "../../components/TrackerChoroplethMap.astro";
import ChoroplethLegend from "../../components/ChoroplethLegend.astro";
import TrackerMeter from "../../components/TrackerMeter.astro";
import { getEnrichedCountryStatuses } from "../../lib/tracker-data";
import {
  getMapMarkers,
  getMonitoringStatus,
  profileCardForJurisdiction,
} from "../../lib/runtime-monitoring-data";
import {
  getReviewQueueSummary,
  jurisdictionReviewState,
} from "../../lib/regulation-review-queue";

const enriched = getEnrichedCountryStatuses();
const markers = getMapMarkers();
const monitoring = getMonitoringStatus();
const reviewQueueSummary = getReviewQueueSummary();

const markerById = new Map(markers.map((m) => [m.jurisdiction_id, m]));

const region = Astro.url.searchParams.get("region");
const status = Astro.url.searchParams.get("status");
const maturity = Astro.url.searchParams.get("maturity");
const activity = Astro.url.searchParams.get("activity");

function levelMatch(score: number, filter: string | null) {
  if (!filter) return true;
  if (filter === "high") return score >= 70;
  if (filter === "medium") return score >= 40 && score < 70;
  if (filter === "low") return score < 40;
  return true;
}

let filtered = enriched;
if (region) filtered = filtered.filter((e) => e.region === region);
if (status) filtered = filtered.filter((e) => e.status_bucket === status);
if (maturity || activity) {
  filtered = filtered.filter((e) => {
    const m = markerById.get(e.jurisdiction_id);
    const mat = m?.maturity_score ?? e.regulation_maturity_score ?? 0;
    const act = m?.activity_score ?? e.source_activity_score ?? 0;
    return levelMatch(mat, maturity) && levelMatch(act, activity);
  });
}

const selectedId = Astro.url.searchParams.get("jurisdiction");
const selected =
  selectedId && filtered.find((e) => e.jurisdiction_id === selectedId)
    ? filtered.find((e) => e.jurisdiction_id === selectedId)!
    : filtered[0] ?? null;
const selectedMarker = selected ? markerById.get(selected.jurisdiction_id) : null;
const selectedProfile = selected ? profileCardForJurisdiction(selected.jurisdiction_id) : null;
const selectedReviewState = selected
  ? jurisdictionReviewState(selected.jurisdiction_id)
  : null;
---

<BaseLayout
  title="Regulation map"
  currentPath="/map/"
  description="Interactive pilot map with jurisdiction status, maturity/activity/freshness meters, and backend monitoring coverage."
>
  <h1>Global regulation map</h1>
  <p class="lead">
    Techieray-inspired pilot map combining tracker status coloring, freshness/maturity meters, and T080
    backend monitoring coverage — metadata only, review required, not legal advice.
  </p>

  <div class="banner banner--review" role="note">
    <strong>Detected change ≠ verified legal change.</strong> {monitoring.monitored_source_count ?? 0}{" "}
    sources in pilot registry ({monitoring.automated_source_count ?? 0} automated RSS,{" "}
    {monitoring.manual_source_count ?? 0} manual review). Review queue:{" "}
    {reviewQueueSummary.review_required ?? 0} required · Scheduled monitoring disabled.
  </div>

  <section class="tracker-section">
    <h2>Review &amp; freshness overlay (T081)</h2>
    <p>
      Countries may show pending review candidates, stale/manual-review sources, or fresh automated
      coverage. Overlay uses jurisdiction review state from public exports — not legal verification.
    </p>
    <p>
      <a href="/review-queue/">Review queue</a> · <a href="/data/source-freshness.json">Source freshness JSON</a>
    </p>
  </section>

  <section class="tracker-section">
    <h2>Filters</h2>
    <form class="filter-form map-filters-advanced" method="get" action="/map/">
      <label>
        Region
        <select name="region">
          <option value="">All</option>
          {[...new Set(enriched.map((e) => e.region))].sort().map((r) => (
            <option value={r} selected={region === r}>
              {r}
            </option>
          ))}
        </select>
      </label>
      <label>
        Status
        <select name="status">
          <option value="">All</option>
          {["adopted", "proposed", "guidance", "monitoring", "no_clear_framework"].map((s) => (
            <option value={s} selected={status === s}>
              {s}
            </option>
          ))}
        </select>
      </label>
      <label>
        Maturity
        <select name="maturity">
          <option value="">All</option>
          <option value="high" selected={maturity === "high"}>High (70+)</option>
          <option value="medium" selected={maturity === "medium"}>Medium</option>
          <option value="low" selected={maturity === "low"}>Low</option>
        </select>
      </label>
      <label>
        Activity
        <select name="activity">
          <option value="">All</option>
          <option value="high" selected={activity === "high"}>High (70+)</option>
          <option value="medium" selected={activity === "medium"}>Medium</option>
          <option value="low" selected={activity === "low"}>Low</option>
        </select>
      </label>
      <button type="submit">Apply</button>
    </form>
  </section>

  <section class="tracker-section map-side-panel">
    <div>
      <h2>Status map</h2>
      <TrackerChoroplethMap items={filtered.length ? filtered : enriched} />
      <ChoroplethLegend />
    </div>
    {
      selected && (
        <aside class="country-card" aria-label="Country side panel">
          <div class="country-card__head">
            <h3>
              <a href={`/jurisdictions/${selected.jurisdiction_id}/`}>{selected.country_name}</a>
            </h3>
          </div>
          <p class="country-card__meta">
            {selectedProfile?.status_headline ?? selected.status_summary}
          </p>
          <p class="country-card__meta">
            <strong>Review state:</strong>{" "}
            {selectedReviewState?.review_state ?? "unknown"} · Pending candidates:{" "}
            {selectedReviewState?.pending_review_count ?? 0} · Stale sources:{" "}
            {selectedReviewState?.stale_source_count ?? 0}
          </p>
          <TrackerMeter
            label="Maturity"
            score={selectedMarker?.maturity_score ?? selected.regulation_maturity_score}
          />
          <TrackerMeter
            label="Activity"
            score={selectedMarker?.activity_score ?? selected.source_activity_score}
          />
          <TrackerMeter
            label="Freshness"
            score={selectedMarker?.freshness_score ?? 30}
          />
          <TrackerMeter
            label="Confidence"
            score={selectedMarker?.confidence_score ?? 30}
          />
          <p class="country-card__meta">
            Sources: {selectedMarker?.source_count ?? selectedMarker?.monitored_source_count ?? 0} ·
            Regulations: {selectedMarker?.regulation_count ?? selectedProfile?.regulation_records_count ?? 0}
          </p>
          <p>
            <a href={`/map/?${new URLSearchParams({ ...(region ? { region } : {}), ...(status ? { status } : {}), jurisdiction: selected.jurisdiction_id }).toString()}`}>
              Pin panel
            </a>
            {" · "}
            <a href={`/compare/?ids=${selected.jurisdiction_id}`}>Compare</a>
          </p>
        </aside>
      )
    }
  </section>

  <section class="tracker-section">
    <h2>All jurisdictions</h2>
    <ul class="country-status-list">
      {(filtered.length ? filtered : enriched).map((cs) => {
        const m = markerById.get(cs.jurisdiction_id);
        return (
          <li class="country-status-list__item">
            <div class="country-status-list__header">
              <h3>
                <a href={`/jurisdictions/${cs.jurisdiction_id}/`}>{cs.country_name}</a>
              </h3>
            </div>
            <TrackerMeter label="Maturity" score={m?.maturity_score ?? cs.regulation_maturity_score} />
            <TrackerMeter label="Activity" score={m?.activity_score ?? cs.source_activity_score} />
            <p class="country-status-list__meta">{cs.status_summary}</p>
          </li>
        );
      })}
    </ul>
  </section>

  <section>
    <h2>Data exports</h2>
    <ul>
      <li><a href="/data/regulation-map-metrics.json">regulation-map-metrics.json</a></li>
      <li><a href="/data/regulation-country-coverage.json">regulation-country-coverage.json</a></li>
      <li><a href="/data/regulation-records.json">regulation-records.json</a></li>
      <li><a href="/data/jurisdiction-profile-cards.json">jurisdiction-profile-cards.json</a></li>
      <li><a href="/data/tracker-summary.json">tracker-summary.json</a></li>
      <li><a href="/data/runtime-monitoring-status.json">runtime-monitoring-status.json</a></li>
    </ul>
  </section>
</BaseLayout>
