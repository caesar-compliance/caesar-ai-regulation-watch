{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/manual-review-decision.schema.json",
  "title": "Caesar AI Regulation Watch — Manual review decision record",
  "description": "Metadata-only reviewer decision for a draft regulatory update. Internal draft progression only. Not publication.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manual_review_decisions_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_live_collection",
    "no_scheduled_monitoring",
    "decisions"
  ],
  "properties": {
    "manual_review_decisions_id": {
      "type": "string",
      "pattern": "^manual-review-decisions-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_collection": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/decisionRecord" }
    }
  },
  "$defs": {
    "gateState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false }
      }
    },
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_allowed",
        "public_export_allowed",
        "evidence_export_allowed",
        "source_verification_completed",
        "metadata_only",
        "stores_full_text",
        "requires_followup_before_publication"
      ],
      "properties": {
        "publication_allowed": { "type": "boolean", "const": false },
        "public_export_allowed": { "type": "boolean", "const": false },
        "evidence_export_allowed": { "type": "boolean", "const": false },
        "source_verification_completed": { "type": "boolean", "const": false },
        "metadata_only": { "type": "boolean", "const": true },
        "stores_full_text": { "type": "boolean", "const": false },
        "requires_followup_before_publication": { "type": "boolean", "const": true }
      }
    },
    "decisionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "promotion_id",
        "draft_update_id",
        "draft_update_path",
        "source_execution_id",
        "source_approval_id",
        "source_adapter_id",
        "reviewer_role",
        "decision",
        "decision_status",
        "decision_scope",
        "review_notes",
        "requested_changes",
        "decided_at",
        "created_at",
        "updated_at",
        "gates",
        "safety"
      ],
      "properties": {
        "decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "promotion_id": { "type": "string" },
        "draft_update_id": { "type": "string" },
        "draft_update_path": { "type": "string" },
        "source_execution_id": { "type": "string" },
        "source_approval_id": { "type": "string" },
        "source_adapter_id": { "type": "string" },
        "reviewer_role": { "type": "string" },
        "decision": {
          "type": "string",
          "enum": ["approve_internal_draft", "reject", "request_changes"]
        },
        "decision_status": {
          "type": "string",
          "enum": ["draft", "recorded", "superseded"]
        },
        "decision_scope": {
          "type": "string",
          "const": "internal_draft_only"
        },
        "review_notes": { "type": "string", "maxLength": 1000 },
        "requested_changes": {
          "type": "array",
          "items": { "type": "string", "maxLength": 500 }
        },
        "decided_at": { "type": "string", "format": "date" },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" },
        "gates": { "$ref": "#/$defs/gateState" },
        "safety": { "$ref": "#/$defs/safetyFlags" }
      }
    }
  }
}
