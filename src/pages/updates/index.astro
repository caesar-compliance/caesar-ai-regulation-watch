---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TrackerFilterForm from "../../components/TrackerFilterForm.astro";
import UpdateFeedCard from "../../components/UpdateFeedCard.astro";
import {
  getTrackerTopics,
  getCountryStatuses,
  filterRegulatoryUpdates,
  getRegulatoryUpdates,
} from "../../lib/tracker-data";

const topics = getTrackerTopics();
const regions = [...new Set(getCountryStatuses().map((c) => c.region))].sort();
const allUpdates = getRegulatoryUpdates();
const manualCount = allUpdates.filter((u) => u.automation_method === "manual_seed").length;
const adapterCount = allUpdates.filter(
  (u) => u.automation_method === "offline_metadata_adapter",
).length;

const region = Astro.url.searchParams.get("region");
const status = Astro.url.searchParams.get("status");
const topic = Astro.url.searchParams.get("topic");
const updateType = Astro.url.searchParams.get("update_type");
const automationMethod = Astro.url.searchParams.get("automation_method");

const filtered = filterRegulatoryUpdates({
  region,
  status,
  topic,
  updateType,
  automationMethod,
});
---

<BaseLayout
  title="Regulatory updates"
  currentPath="/updates/"
  description="Source-linked regulatory update feed — automation-first tracker."
>
  <h1>Regulatory updates</h1>
  <p class="lead">
    Chronological feed of source-linked regulatory update records. Manual seeds and repository
    metadata adapter outputs coexist in the pilot tracker. Not legal advice; not a claim that law
    has changed unless explicitly verified elsewhere.
  </p>

  <div class="banner banner--automation" role="note">
    <strong>Feed sources.</strong> {manualCount} manual seed · {adapterCount} metadata adapter
    (`offline_metadata_adapter`). Some updates are generated from repository metadata adapters
    (detected changes, monitoring packs, registry leads). They are source-linked technical tracker
    records, not legal advice or final evidence. `legal_change_claimed` remains false on all items.
    Live source adapters are a later phase (T050+).
  </div>

  <TrackerFilterForm
    action="/updates/"
    regions={regions}
    topics={topics}
    current={{ region, status, topic, update_type: updateType, automation_method: automationMethod }}
    showUpdateType={true}
    showAutomationMethod={true}
  />

  <p class="feed-count">
    Showing {filtered.length} of {allUpdates.length} update(s).
  </p>

  {
    filtered.length === 0 ? (
      <p>No updates match the current filters.</p>
    ) : (
      <div class="update-feed-list">
        {filtered.map((u) => (
          <article id={u.update_id}>
            <UpdateFeedCard update={u} />
          </article>
        ))}
      </div>
    )
  }
</BaseLayout>
