---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getFinalLegalReviewCockpitCase } from "../../lib/data";
import { humanizeId } from "../../lib/format";
import { PROJECT_VERSION_LABEL } from "../../lib/project-version";

const PACKET_ID = "T062-001";
const DECISION_ID = "T063-001";
const RESPONSE_ID = "T064-001";
const cockpit = getFinalLegalReviewCockpitCase(PACKET_ID);

if (!cockpit) {
  throw new Error(`Final legal review cockpit case missing: ${PACKET_ID}`);
}

const {
  packet,
  finalLegalDecision,
  revisionResponse,
  reviewerRecheck,
  publicationGatePacket,
  publicationGateDecision,
  draft,
  result,
  checklist,
  promotion,
  decision,
  revision,
  readinessGate,
  execution,
  approval,
} = cockpit;

const hasStagingPreview = draft?.latest_publication_staging_preview_id === "T068-001";
const hasPublicExportGate = draft?.latest_public_export_release_gate_id === "T069-001";
const hasPublicExportApproval =
  draft?.latest_public_export_approval_decision_id === "T070-001";

const timeline = [
  {
    step: "T055",
    label: "Single-source network dry-run",
    id: execution?.execution_id ?? draft?.source_execution_id,
    status: execution?.status,
    detail: approval ? `Approval ${approval.approval_id}` : null,
  },
  {
    step: "T056",
    label: "Manual review promotion",
    id: promotion?.promotion_id ?? draft?.promotion_id,
    status: promotion?.status,
    detail: promotion?.draft_update_path,
  },
  {
    step: "T057",
    label: "Reviewer decision",
    id: decision?.decision_id ?? draft?.latest_review_decision_id,
    status: decision?.decision,
    detail: decision?.decision_scope,
  },
  {
    step: "T058",
    label: "Draft revision packet",
    id: revision?.revision_id ?? draft?.latest_revision_id,
    status: revision?.revision_status,
    detail: draft?.review_status,
  },
  {
    step: "T059",
    label: "Internal draft readiness gate",
    id: readinessGate?.readiness_id ?? draft?.latest_readiness_gate_id,
    status: readinessGate?.readiness_result ?? draft?.readiness_result,
    detail: readinessGate?.next_required_step ?? draft?.next_required_step,
  },
  {
    step: "T060",
    label: "Source verification checklist",
    id: checklist?.checklist_id ?? packet.checklist_id,
    status: checklist?.status,
    detail: checklist?.next_required_step,
  },
  {
    step: "T061",
    label: "Source verification result",
    id: result?.result_id ?? packet.source_verification_result_id,
    status: result?.result_status ?? "—",
    detail: result?.overall_result ?? draft?.source_verification_result,
  },
  {
    step: "T062",
    label: "Final legal review packet",
    id: packet.packet_id,
    status: packet.packet_status,
    detail: packet.next_required_step,
  },
  {
    step: "T063",
    label: "Final legal reviewer decision",
    id: finalLegalDecision?.decision_id ?? draft?.latest_final_legal_review_decision_id,
    status: finalLegalDecision?.decision ?? draft?.final_legal_review_decision,
    detail: finalLegalDecision?.decision_scope ?? draft?.final_legal_review_status,
  },
  {
    step: "T064",
    label: "Legal review revision response",
    id: revisionResponse?.response_id ?? draft?.latest_final_legal_review_response_id,
    status: revisionResponse?.response_status ?? draft?.final_legal_review_response_status,
    detail: revisionResponse?.next_required_step ?? "final_legal_reviewer_recheck",
  },
  {
    step: "T065",
    label: "Final reviewer re-check",
    id: reviewerRecheck?.recheck_id ?? draft?.latest_final_reviewer_recheck_id,
    status: reviewerRecheck?.recheck_result ?? draft?.final_reviewer_recheck_result,
    detail: reviewerRecheck?.next_required_step ?? "publication_gate_packet",
  },
  {
    step: "T066",
    label: "Publication gate packet",
    id: publicationGatePacket?.packet_id ?? draft?.latest_publication_gate_packet_id,
    status: publicationGatePacket?.gate_result ?? draft?.publication_gate_result,
    detail: publicationGatePacket?.next_required_step ?? draft?.next_required_step,
  },
];

const addressedChangeCounts = { addressed_metadata_only: 0, partially_addressed: 0, still_blocked: 0 };
for (const change of revisionResponse?.addressed_changes ?? []) {
  if (addressedChangeCounts[change.status] !== undefined) {
    addressedChangeCounts[change.status] += 1;
  }
}

const recheckItemCounts = {
  accepted_for_internal_recheck: 0,
  still_blocked: 0,
  needs_follow_up: 0,
};
for (const item of reviewerRecheck?.reviewed_response_items ?? []) {
  if (recheckItemCounts[item.recheck_status] !== undefined) {
    recheckItemCounts[item.recheck_status] += 1;
  }
}

const itemCounts = { pending: 0, needs_follow_up: 0, blocked: 0, local_metadata_available: 0 };
for (const item of packet.legal_review_items) {
  if (itemCounts[item.status] !== undefined) itemCounts[item.status] += 1;
}
---

<BaseLayout
  title="Final Legal Review Packet"
  description="Internal final legal review packet — not approved, not published, not verified on source."
  currentPath="/legal-review/"
>
  <h1>Final Legal Review Packet</h1>
  <p class="lead">
    Internal pre-publication legal review ({PROJECT_VERSION_LABEL}). Read-only metadata — no approve,
    publish, or source verification controls.
  </p>

  <div class="status-cards">
    <div class="status-card status-card--pending">
      <strong>Packet status</strong>
      <code>{packet.packet_status}</code>
    </div>
    <div class="status-card status-card--pending">
      <strong>Legal decision</strong>
      <code>{finalLegalDecision?.decision ?? draft?.final_legal_review_decision ?? "—"}</code>
    </div>
    <div class="status-card status-card--pending">
      <strong>Revision response</strong>
      <code>{revisionResponse?.response_status ?? draft?.final_legal_review_response_status ?? "—"}</code>
    </div>
    <div class="status-card status-card--pending">
      <strong>Reviewer re-check</strong>
      <code>{reviewerRecheck?.recheck_result ?? draft?.final_reviewer_recheck_result ?? "—"}</code>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Source verified</strong>
      <span>No — not verified on source</span>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Published</strong>
      <span>No — not published</span>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Gates</strong>
      <span>Closed — client/evidence/legal-change gates false</span>
    </div>
  </div>

  <div class="banner banner--review" role="note">
    <strong>Not approved.</strong> Not published. Not final source verification. Not legal advice.
    {
      reviewerRecheck && (
        <>
          {" "}Re-check <code>{reviewerRecheck.recheck_id}</code> recorded — internal next step toward publication
          gate only; not publication approval.
        </>
      )
    }
    {
      revisionResponse && !reviewerRecheck && (
        <>
          {" "}Revision response <code>{revisionResponse.response_id}</code> ready for reviewer re-check — not
          ready for publication.
        </>
      )
    }{" "}
    Packet <code>{packet.packet_id}</code> — review stage <code>{packet.review_stage}</code>.
  </div>

  <section>
    <h2>Draft under review</h2>
    <dl class="meta-grid">
      <div><dt>Draft ID</dt><dd><span class="mono">{packet.draft_update_id}</span></dd></div>
      <div><dt>Draft path</dt><dd><span class="mono">{packet.draft_update_path}</span></dd></div>
      <div><dt>Source URL</dt><dd>
        {
          draft ? (
            <a href={draft.source_url} rel="noopener noreferrer">{draft.source_url}</a>
          ) : (
            "—"
          )
        }
      </dd></div>
      <div><dt>Review status</dt><dd>{draft ? humanizeId(draft.review_status) : "—"}</dd></div>
      <div><dt>Final legal review</dt><dd><span class="mono">{draft?.final_legal_review_status ?? packet.packet_status}</span></dd></div>
      <div><dt>Revision response</dt><dd><span class="mono">{revisionResponse?.response_status ?? draft?.final_legal_review_response_status ?? "—"}</span></dd></div>
      <div><dt>Legal reviewer decision</dt><dd><span class="mono">{finalLegalDecision?.decision ?? draft?.final_legal_review_decision ?? "—"}</span></dd></div>
      <div><dt>Reviewer re-check</dt><dd><span class="mono">{reviewerRecheck?.recheck_result ?? draft?.final_reviewer_recheck_result ?? "—"}</span></dd></div>
      <div><dt>Next required step</dt><dd><span class="mono">{reviewerRecheck?.next_required_step ?? draft?.next_required_step ?? packet.next_required_step}</span></dd></div>
    </dl>
    {
      draft && (
        <>
          <h3>Draft metadata (internal only)</h3>
          <dl class="meta-grid">
            <div><dt>Title</dt><dd>{draft.title}</dd></div>
            <div><dt>Status</dt><dd>{humanizeId(draft.status)}</dd></div>
            <div><dt>Published (metadata)</dt><dd>{draft.source_published_at ?? draft.published_at}</dd></div>
            <div><dt>Jurisdictions</dt><dd>{draft.jurisdiction_ids.join(", ")}</dd></div>
            <div><dt>Topics</dt><dd>{draft.topic_ids.join(", ")}</dd></div>
          </dl>
          <p class="card__excerpt">{draft.summary}</p>
        </>
      )
    }
  </section>

  {
    result && (
      <section>
        <h2>Source verification result (T061)</h2>
        <p>
          Item-level manual checks from result <code>{result.result_id}</code> — not final source
          verification.
        </p>
        <dl class="meta-grid">
          <div><dt>Overall result</dt><dd><span class="mono">{result.overall_result}</span></dd></div>
          <div><dt>Result status</dt><dd><span class="mono">{result.result_status}</span></dd></div>
          <div><dt>Final verification completed</dt><dd>No</dd></div>
        </dl>
      </section>
    )
  }

  <section>
    <h2>Pipeline timeline</h2>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Step</th>
            <th>Stage</th>
            <th>Record</th>
            <th>Status</th>
            <th>Detail</th>
          </tr>
        </thead>
        <tbody>
          {
            timeline.map((row) => (
              <tr>
                <td><span class="mono">{row.step}</span></td>
                <td>{row.label}</td>
                <td><span class="mono">{row.id ?? "—"}</span></td>
                <td>{row.status ? humanizeId(String(row.status)) : "—"}</td>
                <td><span class="mono">{row.detail ?? "—"}</span></td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  {
    finalLegalDecision && (
      <section>
        <h2>Final legal reviewer decision (T063)</h2>
        <p>
          Decision <code>{finalLegalDecision.decision_id}</code> for packet{" "}
          <code>{finalLegalDecision.packet_id}</code> — workflow record only. Not publication. Not
          final approval. Not legal advice.
        </p>
        <dl class="meta-grid">
          <div><dt>Decision</dt><dd><span class="mono">{finalLegalDecision.decision}</span></dd></div>
          <div><dt>Decision scope</dt><dd><span class="mono">{finalLegalDecision.decision_scope}</span></dd></div>
          <div><dt>Decision status</dt><dd><span class="mono">{finalLegalDecision.decision_status}</span></dd></div>
          <div><dt>Reviewer role</dt><dd><span class="mono">{finalLegalDecision.reviewer_role}</span></dd></div>
          <div><dt>Decided at</dt><dd>{finalLegalDecision.decided_at}</dd></div>
          <div><dt>Next required step</dt><dd><span class="mono">{finalLegalDecision.next_required_step}</span></dd></div>
          <div><dt>Publication allowed</dt><dd>false</dd></div>
          <div><dt>Evidence export</dt><dd>false</dd></div>
          <div><dt>verified_on_source</dt><dd>false</dd></div>
        </dl>
        <p class="card__excerpt">{finalLegalDecision.decision_summary}</p>
        <h3>Required changes ({finalLegalDecision.required_changes.length})</h3>
        <ul>
          {finalLegalDecision.required_changes.map((c) => <li>{c}</li>)}
        </ul>
        <h3>Approval limitations ({finalLegalDecision.approval_limitations.length})</h3>
        <ul>
          {finalLegalDecision.approval_limitations.map((l) => <li>{l}</li>)}
        </ul>
      </section>
    )
  }

  {
    reviewerRecheck && (
      <section>
        <h2>Final reviewer re-check (T065)</h2>
        <div class="banner banner--warn" role="note">
          <strong>Internal next-step only.</strong> <code>ready_for_publication_gate_review</code> is not
          publication approval. Publication, public export, client/evidence use, and legal-change claim remain
          blocked.
        </div>
        <p>
          Re-check <code>{reviewerRecheck.recheck_id}</code> of response{" "}
          <code>{reviewerRecheck.response_id}</code> — conservative internal re-check record. Not final legal
          approval. Not final source verification. Not legal advice.
        </p>
        <dl class="meta-grid">
          <div><dt>Re-check result</dt><dd><span class="mono">{reviewerRecheck.recheck_result}</span></dd></div>
          <div><dt>Re-check scope</dt><dd><span class="mono">{reviewerRecheck.recheck_scope}</span></dd></div>
          <div><dt>Re-check status</dt><dd><span class="mono">{reviewerRecheck.recheck_status}</span></dd></div>
          <div><dt>Checked by</dt><dd><span class="mono">{reviewerRecheck.checked_by_role}</span> at {reviewerRecheck.checked_at}</dd></div>
          <div><dt>Next required step</dt><dd><span class="mono">{reviewerRecheck.next_required_step}</span></dd></div>
          <div><dt>Ready for publication gate</dt><dd>{reviewerRecheck.safety.ready_for_publication_gate_review ? "Yes (internal only)" : "No"}</dd></div>
          <div><dt>Final legal approval</dt><dd>false</dd></div>
          <div><dt>Source verification final</dt><dd>false</dd></div>
          <div><dt>Publication allowed</dt><dd>false</dd></div>
          <div><dt>Public export</dt><dd>false</dd></div>
          <div><dt>Evidence export</dt><dd>false</dd></div>
          <div><dt>verified_on_source</dt><dd>false</dd></div>
        </dl>
        <p class="card__excerpt">{reviewerRecheck.recheck_summary}</p>
        <h3>
          Reviewed response items ({reviewerRecheck.reviewed_response_items.length}) — accepted{" "}
          {recheckItemCounts.accepted_for_internal_recheck}, blocked {recheckItemCounts.still_blocked}, follow-up{" "}
          {recheckItemCounts.needs_follow_up}
        </h3>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Item</th>
                <th>Prior status</th>
                <th>Re-check status</th>
                <th>Note</th>
              </tr>
            </thead>
            <tbody>
              {
                reviewerRecheck.reviewed_response_items.map((item) => (
                  <tr>
                    <td><span class="mono">{item.item_id}</span></td>
                    <td><span class="mono">{item.prior_status}</span></td>
                    <td>
                      <span class={`badge badge--status-${item.recheck_status}`}>{item.recheck_status}</span>
                    </td>
                    <td>{item.recheck_note}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <h3>Remaining blockers ({reviewerRecheck.remaining_blockers.length})</h3>
        <ul>
          {reviewerRecheck.remaining_blockers.map((b) => <li>{b}</li>)}
        </ul>
      </section>
    )
  }

  {
    revisionResponse && (
      <section>
        <h2>Legal review revision response (T064)</h2>
        <p>
          Response <code>{revisionResponse.response_id}</code> to decision{" "}
          <code>{revisionResponse.decision_id}</code> — metadata-only revision record. Ready for reviewer
          re-check. Not final approval. Not publication. Not legal advice.
        </p>
        <dl class="meta-grid">
          <div><dt>Response status</dt><dd><span class="mono">{revisionResponse.response_status}</span></dd></div>
          <div><dt>Response scope</dt><dd><span class="mono">{revisionResponse.response_scope}</span></dd></div>
          <div><dt>Next required step</dt><dd><span class="mono">{revisionResponse.next_required_step}</span></dd></div>
          <div><dt>Final legal approval</dt><dd>false</dd></div>
          <div><dt>Source verification final</dt><dd>false</dd></div>
          <div><dt>Publication allowed</dt><dd>false</dd></div>
          <div><dt>Public export</dt><dd>false</dd></div>
          <div><dt>Evidence export</dt><dd>false</dd></div>
        </dl>
        <p class="card__excerpt">{revisionResponse.response_summary}</p>
        <h3>
          Addressed changes ({revisionResponse.addressed_changes.length}) — metadata-only{" "}
          {addressedChangeCounts.addressed_metadata_only}, partial{" "}
          {addressedChangeCounts.partially_addressed}, still blocked{" "}
          {addressedChangeCounts.still_blocked}
        </h3>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Change</th>
                <th>Status</th>
                <th>Response note</th>
              </tr>
            </thead>
            <tbody>
              {
                revisionResponse.addressed_changes.map((change) => (
                  <tr>
                    <td><span class="mono">{change.change_id}</span></td>
                    <td>
                      <span class={`badge badge--status-${change.status}`}>{change.status}</span>
                    </td>
                    <td>{change.response_note}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <h3>Remaining blockers ({revisionResponse.remaining_blockers.length})</h3>
        <ul>
          {revisionResponse.remaining_blockers.map((b) => <li>{b}</li>)}
        </ul>
      </section>
    )
  }

  <section>
    <h2>Legal review checklist</h2>
    <p>
      Item counts: pending {itemCounts.pending}, needs follow-up {itemCounts.needs_follow_up}, blocked{" "}
      {itemCounts.blocked}, local metadata {itemCounts.local_metadata_available}. No item approved for
      publication.
    </p>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Item</th>
            <th>Status</th>
            <th>Reviewer role</th>
            <th>Note</th>
          </tr>
        </thead>
        <tbody>
          {
            packet.legal_review_items.map((item) => (
              <tr>
                <td><span class="mono">{item.item_id}</span></td>
                <td>
                  <span class={`badge badge--status-${item.status}`}>{item.status}</span>
                </td>
                <td><span class="mono">{item.reviewer_role}</span></td>
                <td>{item.note ?? "—"}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Blockers</h2>
    <ul>
      {packet.blockers_remaining.map((b) => <li>{b}</li>)}
    </ul>
    {
      result && result.blockers_remaining.length > 0 && (
        <>
          <h3>Source verification blockers ({result.result_id})</h3>
          <ul>
            {result.blockers_remaining.map((b) => <li>{b}</li>)}
          </ul>
        </>
      )
    }
  </section>

  <section>
    <h2>Gates and safety</h2>
    <dl class="meta-grid">
      <div><dt>verified_on_source</dt><dd>false</dd></div>
      <div><dt>client_use_allowed</dt><dd>false</dd></div>
      <div><dt>client_evidence_allowed</dt><dd>false</dd></div>
      <div><dt>final_evidence_allowed</dt><dd>false</dd></div>
      <div><dt>legal_change_claimed</dt><dd>false</dd></div>
      <div><dt>publication_allowed</dt><dd>false</dd></div>
      <div><dt>public_export_allowed</dt><dd>false</dd></div>
      <div><dt>evidence_export_allowed</dt><dd>false</dd></div>
      <div><dt>final_legal_approval_completed</dt><dd>false</dd></div>
      <div><dt>final_source_verification_completed</dt><dd>false</dd></div>
      <div><dt>metadata_only</dt><dd>true</dd></div>
      <div><dt>stores_full_text</dt><dd>false</dd></div>
      <div><dt>requires_final_approval_before_publication</dt><dd>true</dd></div>
    </dl>
  </section>

  {
    hasStagingPreview && (
      <section>
        <h2>Publication staging preview</h2>
        <div class="banner banner--review" role="note">
          <strong>Publication staging preview generated.</strong> Preview <code>T068-001</code> —
          internal only. Not a public regulatory update. Not published.
        </div>
        <p><a href="/publication-staging/">Open Publication Staging Preview →</a></p>
      </section>
    )
  }

  {
    hasPublicExportGate && (
      <section>
        <h2>Public export release gate</h2>
        <div class="banner banner--review" role="note">
          <strong>Public export gate ready for approval review.</strong> Gate <code>T069-001</code> —
          no export yet. Not client/evidence ready.
        </div>
        <p><a href="/public-export-gate/">Open Public Export Release Gate →</a></p>
      </section>
    )
  }

  {
    hasPublicExportApproval && (
      <section>
        <h2>Public export approval decision</h2>
        <div class="banner banner--review" role="note">
          <strong>Non-public export preview approved.</strong> Decision <code>T070-001</code> —
          no publication yet. Public export and client/evidence remain blocked.
        </div>
        <p><a href="/public-export-gate/">Open Public Export Release Gate →</a></p>
      </section>
    )
  }

  {
    publicationGatePacket && (
      <section>
        <h2>Publication gate</h2>
        <div class="banner banner--review" role="note">
          {
            publicationGateDecision ? (
              <>
                <strong>Publication gate decision recorded.</strong> Decision{" "}
                <code>{publicationGateDecision.decision_id}</code> —{" "}
                <code>{publicationGateDecision.decision}</code>. Internal staging allowed only.
                Publication still blocked. Public export blocked.
              </>
            ) : (
              <>
                <strong>Publication gate packet available.</strong> Packet{" "}
                <code>{publicationGatePacket.packet_id}</code> — status{" "}
                <code>{publicationGatePacket.packet_status}</code>. Not published. Publication decision
                not recorded.
              </>
            )
          }
        </div>
        <p><a href="/publication-gate/">Open Publication Gate Packet →</a></p>
      </section>
    )
  }

  <section>
    <h2>Related</h2>
    <ul>
      <li><a href="/public-export-gate/">Public export release gate</a></li>
      <li><a href="/publication-staging/">Publication staging preview</a></li>
      <li><a href="/publication-gate/">Publication gate packet</a></li>
      <li><a href="/source-verification/">Source verification cockpit</a></li>
      <li><a href="/source-adapters/">Source adapters pipeline</a></li>
      <li><a href="/updates/">Public regulatory updates feed</a></li>
      <li><a href="/tracker/">Automation-first tracker</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .status-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 0.75rem;
    margin: 1rem 0 1.5rem;
  }
  .status-card {
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    border: 1px solid var(--border, #ccc);
    background: var(--surface, #f8f8f8);
  }
  .status-card strong {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
  }
  .status-card--pending code {
    color: var(--accent-warn, #8a6d00);
  }
  .status-card--blocked span {
    color: var(--accent-danger, #a00);
  }
  .banner--warn {
    border-color: var(--accent-warn, #8a6d00);
