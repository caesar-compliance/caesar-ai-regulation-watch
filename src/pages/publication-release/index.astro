---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getExplicitPublicationReleaseApprovalCockpitCase } from "../../lib/data";
import { PROJECT_VERSION_LABEL } from "../../lib/project-version";

const PACKET_ID = "T072-001";
const cockpit = getExplicitPublicationReleaseApprovalCockpitCase(PACKET_ID);

if (!cockpit) {
  throw new Error(`Explicit publication release approval cockpit case missing: ${PACKET_ID}`);
}

const {
  packet,
  publicUpdateReleaseDecision,
  publicExportApprovalDecision,
  publicExportReleaseGate,
  stagingPreview,
  draft,
} = cockpit;

const readyChecks = packet.pre_release_checks.filter(
  (c) => c.status === "ready_for_authorization_review",
);
const blockedChecks = packet.pre_release_checks.filter((c) => c.status === "blocked");
const sourceUrl =
  publicExportReleaseGate?.candidate_metadata.source_url ?? draft?.source_url ?? "—";
---

<BaseLayout
  title="Explicit Publication Release Approval"
  description="Explicit publication release approval packet — awaiting Control Tower authorization, not published."
  currentPath="/publication-release/"
  noindex={true}
>
  <h1>Explicit Publication Release Approval</h1>
  <p class="lead">
    Operator confirmation screen ({PROJECT_VERSION_LABEL}). Approval packet only — no publish,
    export, or authorization controls on this page.
  </p>

  <div class="banner banner--danger" role="alert">
    <strong>Awaiting Control Tower authorization.</strong> Operator confirmation pending. Not
    published. No public route or public/data inclusion. All publication, export, and evidence gates
    remain closed. No verified legal-change claim.
  </div>

  <div class="status-cards">
    <div class="status-card status-card--pending">
      <strong>Approval packet</strong>
      <span>Created — metadata only</span>
    </div>
    <div class="status-card status-card--pending">
      <strong>Authorization</strong>
      <span>Control Tower required</span>
    </div>
    <div class="status-card status-card--pending">
      <strong>Operator confirmation</strong>
      <code>{packet.operator_confirmation_status}</code>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Publication release</strong>
      <span>Not authorized</span>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Public route / data</strong>
      <span>Not created / not included</span>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Gates</strong>
      <span>Closed</span>
    </div>
  </div>

  <section>
    <h2>Approval packet</h2>
    <dl class="meta-grid">
      <div><dt>Packet ID</dt><dd><span class="mono">{packet.packet_id}</span></dd></div>
      <div><dt>Packet scope</dt><dd><span class="mono">{packet.packet_scope}</span></dd></div>
      <div><dt>Packet status</dt><dd><span class="mono">{packet.packet_status}</span></dd></div>
      <div><dt>Release decision</dt><dd><span class="mono">{packet.public_update_release_decision_id}</span></dd></div>
      <div><dt>Export approval</dt><dd><span class="mono">{packet.public_export_approval_decision_id}</span></dd></div>
      <div><dt>Release gate</dt><dd><span class="mono">{packet.release_gate_id}</span></dd></div>
      <div><dt>Next step</dt><dd><span class="mono">{packet.next_required_step}</span></dd></div>
    </dl>
    <p>{packet.approval_summary}</p>
  </section>

  <section>
    <h2>Candidate (metadata only)</h2>
    <dl class="meta-grid">
      <div><dt>Proposed public update ID</dt><dd><span class="mono">{packet.proposed_public_update_id}</span></dd></div>
      <div><dt>Proposed route</dt><dd><span class="mono">{packet.proposed_route}</span> (text only — not an active link)</dd></div>
      <div><dt>Draft ID</dt><dd><span class="mono">{draft?.draft_id ?? packet.draft_update_id}</span></dd></div>
      <div><dt>Update ID</dt><dd><span class="mono">{packet.draft_update_id}</span></dd></div>
      <div><dt>Source URL</dt><dd>
        <a href={sourceUrl} rel="noopener noreferrer">{sourceUrl}</a>
      </dd></div>
      {
        stagingPreview && (
          <>
            <div><dt>Preview title</dt><dd>{stagingPreview.preview_title}</dd></div>
            <div><dt>Preview summary</dt><dd>{stagingPreview.preview_summary}</dd></div>
          </>
        )
      }
    </dl>
  </section>

  <section>
    <h2>Pre-release checks</h2>
    <table class="checklist-table">
      <thead>
        <tr>
          <th>Item</th>
          <th>Status</th>
          <th>Note</th>
          <th>Owner</th>
        </tr>
      </thead>
      <tbody>
        {packet.pre_release_checks.map((item) => (
          <tr>
            <td><span class="mono">{item.item_id}</span></td>
            <td><code>{item.status}</code></td>
            <td>{item.note}</td>
            <td><span class="mono">{item.owner_role}</span></td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="timeline-detail">
      Ready for authorization review: {readyChecks.length} · Blocked: {blockedChecks.length}
    </p>
  </section>

  <section>
    <h2>Authorization requirements</h2>
    <ul>
      {packet.authorization_requirements.map((r) => <li>{r}</li>)}
    </ul>
  </section>

  <section>
    <h2>Blockers remaining</h2>
    <ul>
      {packet.blockers_remaining.map((b) => <li>{b}</li>)}
    </ul>
  </section>

  <section>
    <h2>Safety and gates</h2>
    <dl class="meta-grid">
      <div><dt>explicit_publication_approval_packet_created</dt><dd>true</dd></div>
      <div><dt>control_tower_authorization_required</dt><dd>true</dd></div>
      <div><dt>operator_confirmation_required</dt><dd>true</dd></div>
      <div><dt>publication_release_authorized</dt><dd>false</dd></div>
      <div><dt>publication_allowed</dt><dd>false</dd></div>
      <div><dt>public_export_allowed</dt><dd>false</dd></div>
      <div><dt>public_data_inclusion_allowed</dt><dd>false</dd></div>
      <div><dt>public_update_route_created</dt><dd>false</dd></div>
      <div><dt>client_use_allowed</dt><dd>false</dd></div>
      <div><dt>evidence_export_allowed</dt><dd>false</dd></div>
      <div><dt>verified_on_source</dt><dd>false</dd></div>
      <div><dt>legal_change_claimed</dt><dd>false</dd></div>
      <div><dt>client_evidence_allowed</dt><dd>false</dd></div>
      <div><dt>final_evidence_allowed</dt><dd>false</dd></div>
      <div><dt>metadata_only</dt><dd>true</dd></div>
      <div><dt>stores_full_text</dt><dd>false</dd></div>
    </dl>
  </section>

  <section>
    <h2>Pipeline</h2>
    <ol class="timeline">
      {
        publicExportApprovalDecision && (
          <li>
            <span class="mono">T070</span> — Non-public export preview{" "}
            <code>{publicExportApprovalDecision.decision_id}</code> (
            <span class="mono">{publicExportApprovalDecision.decision}</span>)
          </li>
        )
      }
      {
        publicUpdateReleaseDecision && (
          <li>
            <span class="mono">T071</span> — Publication hold decision{" "}
            <code>{publicUpdateReleaseDecision.decision_id}</code> (
            <span class="mono">{publicUpdateReleaseDecision.decision}</span>)
          </li>
        )
      }
      <li>
        <span class="mono">T072</span> — Explicit approval packet <code>{packet.packet_id}</code> (
        <span class="mono">{packet.packet_status}</span>)
      </li>
      <li>
        <span class="mono">Next</span> — <code>{packet.next_required_step}</code> (not completed)
      </li>
    </ol>
  </section>

  <section>
    <h2>Automation runtime foundation (T073)</h2>
    <div class="banner banner--review" role="note">
      <strong>Runtime scaffold added.</strong> Product pivot toward live monitoring — see{" "}
      <a href="/automation/">/automation/</a>. Live ingestion not enabled yet.
    </div>
  </section>

  <section>
    <h2>Related</h2>
    <ul>
      <li><a href="/automation/">Automation runtime status</a></li>
      <li><a href="/public-export-gate/">Public export release gate</a></li>
      <li><a href="/publication-staging/">Publication staging preview</a></li>
      <li><a href="/publication-gate/">Publication gate packet</a></li>
      <li><a href="/legal-review/">Final legal review packet</a></li>
      <li><a href="/source-verification/">Source verification cockpit</a></li>
      <li><a href="/source-adapters/">Source adapters pipeline</a></li>
      <li><a href="/tracker/">Automation-first tracker</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .status-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 0.75rem;
    margin: 1rem 0 1.5rem;
  }
  .status-card {
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    border: 1px solid var(--border, #ccc);
    background: var(--surface, #f8f8f8);
  }
  .status-card strong {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
  }
  .status-card--pending code {
    color: var(--accent-warn, #8a6d00);
  }
  .status-card--blocked span {
    color: var(--accent-danger, #a00);
  }
  .banner--danger {
    border-color: var(--accent-danger, #a00);
    background: color-mix(in srgb, var(--accent-danger, #a00) 8%, transparent);
    margin-bottom: 1.25rem;
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    border-width: 1px;
    border-style: solid;
  }
  .checklist-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .checklist-table th,
  .checklist-table td {
    border: 1px solid var(--border, #ddd);
    padding: 0.4rem 0.6rem;
    text-align: left;
    vertical-align: top;
  }
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .timeline li {
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--border, #eee);
  }
  .timeline-detail {
    color: var(--text-muted, #666);
    font-size: 0.9em;
    margin-top: 0.5rem;
  }
</style>
