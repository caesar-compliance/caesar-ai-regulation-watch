---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublicationStagingCockpitCase } from "../../lib/data";
import { PROJECT_VERSION_LABEL } from "../../lib/project-version";

const PREVIEW_ID = "T068-001";
const cockpit = getPublicationStagingCockpitCase(PREVIEW_ID);

if (!cockpit) {
  throw new Error(`Publication staging cockpit case missing: ${PREVIEW_ID}`);
}

const {
  preview,
  publicationGateDecision,
  publicationGatePacket,
  publicExportReleaseGate,
  draft,
} = cockpit;

const hasPublicExportApproval =
  draft?.latest_public_export_approval_decision_id === "T070-001";
---

<BaseLayout
  title="Publication Staging Preview"
  description="Internal publication staging preview — not published, not public export, gates closed."
  currentPath="/publication-staging/"
  noindex={preview.safety.noindex_requested}
>
  <h1>Publication Staging Preview</h1>
  <p class="lead">
    Internal publication staging preview ({PROJECT_VERSION_LABEL}). Safe metadata only — no publish,
    export, or approval controls.
  </p>

  <div class="banner banner--danger" role="alert">
    <strong>Internal staging preview only.</strong> Not a public regulatory update. Not published.
    Not client/evidence ready. All publication and export gates remain closed. No verified
    legal-change claim. Noindex requested.
  </div>

  <div class="status-cards">
    <div class="status-card status-card--pending">
      <strong>Preview status</strong>
      <code>{preview.preview_status}</code>
    </div>
    <div class="status-card status-card--pending">
      <strong>Scope</strong>
      <code>{preview.preview_scope}</code>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Published</strong>
      <span>No — not published</span>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Public export</strong>
      <span>Blocked</span>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Client / evidence</strong>
      <span>Blocked</span>
    </div>
    <div class="status-card status-card--blocked">
      <strong>Gates</strong>
      <span>Closed — verification and legal-change gates false</span>
    </div>
    <div class="status-card status-card--pending">
      <strong>Noindex</strong>
      <span>{preview.safety.noindex_requested ? "Requested" : "—"}</span>
    </div>
  </div>

  <section>
    <h2>Preview card</h2>
    <dl class="meta-grid">
      <div><dt>Preview ID</dt><dd><span class="mono">{preview.preview_id}</span></dd></div>
      <div><dt>Draft ID</dt><dd><span class="mono">{draft?.draft_id ?? preview.draft_update_id}</span></dd></div>
      <div><dt>Update ID</dt><dd><span class="mono">{preview.draft_update_id}</span></dd></div>
      <div><dt>Preview route</dt><dd><span class="mono">{preview.preview_route}</span></dd></div>
    </dl>
    <h3>{preview.preview_title}</h3>
    <p class="card__excerpt">{preview.preview_summary}</p>
    <dl class="meta-grid">
      <div><dt>Jurisdictions</dt><dd>{preview.preview_metadata.jurisdiction_ids.join(", ")}</dd></div>
      <div><dt>Topics</dt><dd>{preview.preview_metadata.topic_ids.join(", ")}</dd></div>
      <div><dt>Source</dt><dd><span class="mono">{preview.preview_metadata.source_id}</span></dd></div>
      <div><dt>Adapter</dt><dd><span class="mono">{preview.preview_metadata.source_adapter_id}</span></dd></div>
      <div><dt>Source URL</dt><dd>
        <a href={preview.preview_metadata.source_url} rel="noopener noreferrer">
          {preview.preview_metadata.source_url}
        </a>
      </dd></div>
    </dl>
  </section>

  <section>
    <h2>Pipeline status</h2>
    <ol class="timeline">
      <li>
        <span class="mono">T067</span> — Publication gate decision{" "}
        <code>{publicationGateDecision?.decision_id ?? preview.publication_gate_decision_id}</code>{" "}
        (<span class="mono">{publicationGateDecision?.decision ?? "—"}</span>) — internal staging
        approved only
      </li>
      <li>
        <span class="mono">T068</span> — Publication staging preview{" "}
        <code>{preview.preview_id}</code> (<span class="mono">{preview.preview_status}</span>)
      </li>
      <li>
        <span class="mono">T069</span> — Public export release gate{" "}
        <code>{publicExportReleaseGate?.gate_id ?? "—"}</code> (
        <span class="mono">{publicExportReleaseGate?.gate_result ?? "pending"}</span>)
      </li>
      <li>
        <span class="mono">Next</span> —{" "}
        <code>{publicExportReleaseGate?.next_required_step ?? preview.next_required_step}</code>{" "}
        (not completed)
      </li>
    </ol>
    {
      publicationGatePacket && (
        <p class="timeline-detail">
          Gate packet <code>{publicationGatePacket.packet_id}</code> —{" "}
          <code>{publicationGatePacket.gate_result}</code>
        </p>
      )
    }
  </section>

  <section>
    <h2>Staging limitations</h2>
    <ul>
      {preview.staging_limitations.map((l) => <li>{l}</li>)}
    </ul>
  </section>

  <section>
    <h2>Blockers remaining</h2>
    <ul>
      {preview.blockers_remaining.map((b) => <li>{b}</li>)}
    </ul>
  </section>

  <section>
    <h2>Safety and gates</h2>
    <dl class="meta-grid">
      <div><dt>staging_preview_created</dt><dd>{String(preview.safety.staging_preview_created)}</dd></div>
      <div><dt>publication_allowed</dt><dd>false</dd></div>
      <div><dt>public_export_allowed</dt><dd>false</dd></div>
      <div><dt>evidence_export_allowed</dt><dd>false</dd></div>
      <div><dt>client_use_allowed</dt><dd>false</dd></div>
      <div><dt>verified_on_source</dt><dd>false</dd></div>
      <div><dt>legal_change_claimed</dt><dd>false</dd></div>
      <div><dt>client_evidence_allowed</dt><dd>false</dd></div>
      <div><dt>final_evidence_allowed</dt><dd>false</dd></div>
      <div><dt>metadata_only</dt><dd>true</dd></div>
      <div><dt>stores_full_text</dt><dd>false</dd></div>
      <div><dt>requires_public_export_approval</dt><dd>true</dd></div>
      <div><dt>requires_publication_release_approval</dt><dd>true</dd></div>
      <div><dt>requires_client_evidence_approval</dt><dd>true</dd></div>
    </dl>
  </section>

  {
    publicExportReleaseGate && (
      <section>
        <h2>Public export release gate</h2>
        <div class="banner banner--warn" role="note">
          <strong>Public export release gate created.</strong> Gate{" "}
          <code>{publicExportReleaseGate.gate_id}</code> — ready for approval review only. Public
          export still false. Not added to public/data.
        </div>
        <p><a href="/public-export-gate/">Open Public Export Release Gate →</a></p>
      </section>
    )
  }

  {
    hasPublicExportApproval && (
      <section>
        <h2>Public export approval decision</h2>
        <div class="banner banner--warn" role="note">
          <strong>Public export approval decision recorded.</strong> Decision <code>T070-001</code> —
          non-public preview artifact approved. Public export still false.
        </div>
        <p><a href="/public-export-gate/">Open Public Export Release Gate →</a></p>
      </section>
    )
  }

  <section>
    <h2>Related</h2>
    <ul>
      <li><a href="/public-export-gate/">Public export release gate</a></li>
      <li><a href="/publication-gate/">Publication gate packet</a></li>
      <li><a href="/legal-review/">Final legal review packet</a></li>
      <li><a href="/source-verification/">Source verification cockpit</a></li>
      <li><a href="/source-adapters/">Source adapters pipeline</a></li>
      <li><a href="/tracker/">Automation-first tracker</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .status-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 0.75rem;
    margin: 1rem 0 1.5rem;
  }
  .status-card {
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    border: 1px solid var(--border, #ccc);
    background: var(--surface, #f8f8f8);
  }
  .status-card strong {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
  }
  .status-card--pending code {
    color: var(--accent-warn, #8a6d00);
  }
  .status-card--blocked span {
    color: var(--accent-danger, #a00);
  }
  .banner--danger {
    border-color: var(--accent-danger, #a00);
    background: color-mix(in srgb, var(--accent-danger, #a00) 8%, transparent);
    margin-bottom: 1.25rem;
    padding: 0.75rem 1rem;
    border-radius: 0.375rem;
    border-width: 1px;
    border-style: solid;
  }
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .timeline li {
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--border, #eee);
  }
  .timeline-detail {
    color: var(--text-muted, #666);
    font-size: 0.9em;
    margin-top: 0.5rem;
  }
</style>
