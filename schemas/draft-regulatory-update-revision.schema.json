{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/draft-regulatory-update-revision.schema.json",
  "title": "Caesar AI Regulation Watch — Draft regulatory update revision packet",
  "description": "Metadata-only revision record after reviewer request_changes. Not publication. Not source verification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "draft_regulatory_update_revisions_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_live_collection",
    "no_scheduled_monitoring",
    "revisions"
  ],
  "properties": {
    "draft_regulatory_update_revisions_id": {
      "type": "string",
      "pattern": "^draft-regulatory-update-revisions-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_collection": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "revisions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/revisionRecord" }
    }
  },
  "$defs": {
    "gateState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false }
      }
    },
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_allowed",
        "public_export_allowed",
        "evidence_export_allowed",
        "source_verification_completed",
        "metadata_only",
        "stores_full_text",
        "requires_followup_before_publication"
      ],
      "properties": {
        "publication_allowed": { "type": "boolean", "const": false },
        "public_export_allowed": { "type": "boolean", "const": false },
        "evidence_export_allowed": { "type": "boolean", "const": false },
        "source_verification_completed": { "type": "boolean", "const": false },
        "metadata_only": { "type": "boolean", "const": true },
        "stores_full_text": { "type": "boolean", "const": false },
        "requires_followup_before_publication": { "type": "boolean", "const": true }
      }
    },
    "revisionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "revision_id",
        "draft_update_id",
        "draft_update_path",
        "source_promotion_id",
        "source_decision_id",
        "revision_status",
        "revision_scope",
        "revision_reason",
        "revision_notes",
        "requested_changes_addressed",
        "requested_changes_remaining",
        "changed_fields",
        "reviewer_followup_required",
        "created_at",
        "updated_at",
        "gates",
        "safety"
      ],
      "properties": {
        "revision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "draft_update_id": { "type": "string" },
        "draft_update_path": { "type": "string" },
        "source_promotion_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "source_decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "revision_status": {
          "type": "string",
          "enum": ["draft_revision_applied", "draft_revision_pending", "rejected"]
        },
        "revision_scope": {
          "type": "string",
          "const": "internal_draft_metadata_only"
        },
        "revision_reason": { "type": "string", "minLength": 1 },
        "revision_notes": { "type": "string", "maxLength": 1000 },
        "requested_changes_addressed": {
          "type": "array",
          "items": { "type": "string", "maxLength": 500 }
        },
        "requested_changes_remaining": {
          "type": "array",
          "items": { "type": "string", "maxLength": 500 }
        },
        "changed_fields": {
          "type": "array",
          "items": { "type": "string", "maxLength": 100 }
        },
        "reviewer_followup_required": { "type": "boolean", "const": true },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" },
        "gates": { "$ref": "#/$defs/gateState" },
        "safety": { "$ref": "#/$defs/safetyFlags" }
      }
    }
  }
}
