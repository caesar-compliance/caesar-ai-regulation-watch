{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/network-dry-run-approval.schema.json",
  "title": "Caesar AI Regulation Watch — Network dry-run approval packets",
  "description": "Manual approval registry for future single-source network dry-runs. Planning only in T054. Not live collection. Not legal advice.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "network_dry_run_approvals_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_live_collection",
    "no_scheduled_monitoring",
    "approvals"
  ],
  "properties": {
    "network_dry_run_approvals_id": {
      "type": "string",
      "pattern": "^network-dry-run-approvals-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_collection": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "approvals": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/approvalPacket" }
    }
  },
  "$defs": {
    "gateState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false }
      }
    },
    "approvalPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_id",
        "run_id",
        "adapter_id",
        "source_id",
        "source_name",
        "source_type",
        "allowed_host",
        "endpoint_url",
        "mode",
        "status",
        "control_tower_approval_required",
        "network_execution_allowed",
        "schedule_enabled",
        "broad_crawl_allowed",
        "max_items",
        "max_bytes",
        "timeout_seconds",
        "user_agent_policy",
        "robots_policy_note",
        "paywall_login_required",
        "captcha_or_waf_risk",
        "stores_metadata_only",
        "stores_full_text",
        "legal_text_publication_allowed",
        "output_path",
        "dry_run_plan_path",
        "approval_notes",
        "gates",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "approval_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "run_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "adapter_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "source_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "source_name": { "type": "string", "minLength": 1 },
        "source_type": {
          "type": "string",
          "enum": ["rss", "atom", "api", "webpage_metadata"]
        },
        "allowed_host": { "type": "string", "minLength": 1 },
        "endpoint_url": { "type": "string", "format": "uri" },
        "mode": {
          "type": "string",
          "enum": ["planning_only", "future_manual_network_dry_run"]
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "ready_for_control_tower_review",
            "approved_for_future_single_run",
            "rejected"
          ]
        },
        "control_tower_approval_required": { "type": "boolean", "const": true },
        "network_execution_allowed": { "type": "boolean" },
        "schedule_enabled": { "type": "boolean", "const": false },
        "broad_crawl_allowed": { "type": "boolean", "const": false },
        "max_items": { "type": "integer", "minimum": 1, "maximum": 5 },
        "max_bytes": { "type": "integer", "minimum": 1, "maximum": 500000 },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 20 },
        "user_agent_policy": { "type": "string", "minLength": 1 },
        "robots_policy_note": { "type": "string", "minLength": 1 },
        "paywall_login_required": { "type": "boolean" },
        "captcha_or_waf_risk": { "type": "boolean" },
        "stores_metadata_only": { "type": "boolean", "const": true },
        "stores_full_text": { "type": "boolean", "const": false },
        "legal_text_publication_allowed": { "type": "boolean", "const": false },
        "output_path": {
          "type": "string",
          "pattern": "^generated/network-dry-run-candidates/[A-Za-z0-9._-]+\\.json$"
        },
        "dry_run_plan_path": {
          "type": "string",
          "pattern": "^generated/network-dry-run-plans/[A-Za-z0-9._-]+\\.json$"
        },
        "approval_notes": { "type": "string", "minLength": 1 },
        "gates": { "$ref": "#/$defs/gateState" },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "approved_for_future_single_run" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "mode": { "const": "future_manual_network_dry_run" },
              "network_execution_allowed": { "const": true }
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": { "status": { "const": "approved_for_future_single_run" } },
              "required": ["status"]
            }
          },
          "then": {
            "properties": { "network_execution_allowed": { "const": false } }
          }
        }
      ]
    }
  }
}
