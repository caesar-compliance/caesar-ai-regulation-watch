---
import fs from "node:fs";
import path from "node:path";
import yaml from "js-yaml";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getWatchers,
  latestWatcherRun,
  getDetectedChanges,
  getMonitoringRuns,
  latestMonitoringRun,
  latestMonitoringDiffSummary,
  getWatcherEligibilityEntries,
  latestWatcherMonitoringRun,
  getMonitoringSourceConfigs,
} from "../../lib/data";
import { humanizeId } from "../../lib/format";
import { PROJECT_VERSION_LABEL } from "../../lib/project-version";

const monitoringRuns = getMonitoringRuns();
const latest = latestMonitoringRun();
const diffSummary = latestMonitoringDiffSummary();
const latestWatcher = latestWatcherRun();
const watchers = getWatchers();
const detected = getDetectedChanges();
const realDetected = detected.filter((d) => !d.simulation);
const simulatedDetected = detected.filter((d) => d.simulation);
const enabledWatchers = watchers.filter((w) => w.enabled);
const eligibility = getWatcherEligibilityEntries();
const sourceConfigs = getMonitoringSourceConfigs();
const watcherEligible = eligibility.filter(
  (e) =>
    e.allowed_to_fetch &&
    e.monitoring_method === "url_status_check" &&
    e.watcher_eligibility?.eligible_basic_url_check,
);
const manualOnly = eligibility.filter((e) => e.monitoring_method === "manual_only");
const blocked = eligibility.filter(
  (e) => e.watcher_eligibility?.blocked_by_waf_or_bot_protection || !e.allowed_to_fetch,
);
const fetchableConfigs = sourceConfigs.filter((c) => c.allowed_to_fetch);
const manualConfigs = sourceConfigs.filter((c) => c.adapter_type === "manual_only");
const packRun = latestWatcherMonitoringRun();
const packChecks = packRun?.checks ?? [];

function readLiveMetadataFromDisk() {
  const dir = path.join(process.cwd(), "data/monitoring");
  if (!fs.existsSync(dir)) return { allowlist: null, run: null, pack: null };
  const allowlistFile = fs
    .readdirSync(dir)
    .filter((f) => f.startsWith("live-metadata-pilot-allowlist-") && f.endsWith(".yml"))
    .sort()
    .reverse()[0];
  const runFile = fs
    .readdirSync(dir)
    .filter((f) => f.startsWith("live-metadata-run-") && f.endsWith(".yml"))
    .sort()
    .reverse()[0];
  const packFile = fs
    .readdirSync(dir)
    .filter((f) => f.startsWith("change-review-pack-") && f.endsWith(".yml"))
    .sort()
    .reverse()[0];
  const triageFile = fs
    .readdirSync(dir)
    .filter((f) => f.startsWith("metadata-review-triage-") && f.endsWith(".yml"))
    .sort()
    .reverse()[0];
  const read = (name: string | undefined) =>
    name ? yaml.load(fs.readFileSync(path.join(dir, name), "utf8")) : null;
  return {
    allowlist: read(allowlistFile),
    run: read(runFile),
    pack: read(packFile),
    triage: read(triageFile),
  };
}

const { allowlist: liveAllowlist, run: liveRun, pack: livePack, triage: metadataTriage } =
  readLiveMetadataFromDisk();
const liveChecks = liveRun?.checks ?? [];
const triageItems = metadataTriage?.items ?? [];
---

<BaseLayout title="Monitoring" currentPath="/monitoring/">
  <h1>Monitoring</h1>
  <p class="lead">
    Monitoring adapter pack, deterministic local runs, and cautious live metadata pilot for confirmed official sources ({PROJECT_VERSION_LABEL}).
    Not legal advice. Not complete coverage. Not client evidence.
  </p>

  <div class="banner banner--review" role="note">
    <strong>Deterministic local pack + cautious live metadata pilot.</strong> Max one request per allowlisted source;
    metadata headers/title only; no link crawl; no full legal text storage. Not scheduled broad monitoring.
    Blocked/WAF sources stay manual-only. Human review required before any record update. Does not set{" "}
    <code>verified_on_source</code> or <code>client_use_allowed</code>.
  </div>

  <section>
    <h2>Manual artifact review workflow ({PROJECT_VERSION_LABEL})</h2>
    <p class="prose">
      GitHub Actions workflow <strong>Manual live metadata review</strong> (<code>manual-live-metadata-review.yml</code>)
      runs only via <code>workflow_dispatch</code> with confirmation input <code>confirm_live_metadata=RUN</code>.
      It produces a downloadable artifact pack (JSON/Markdown) for human triage — <strong>no</strong> schedule,{" "}
      <strong>no</strong> auto-commit to <code>main</code>, <strong>no</strong> auto-merge, <strong>no</strong> deploy,
      and <strong>no</strong> client or final evidence flags.
    </p>
    <dl class="meta-grid">
      <div><dt>Trigger</dt><dd>workflow_dispatch only</dd></div>
      <div><dt>Confirmation</dt><dd class="mono">confirm_live_metadata=RUN</dd></div>
      <div><dt>Artifact pack</dt><dd>live-metadata-run, change-review-pack, policy-checks, summary MD</dd></div>
      <div><dt>Local equivalent</dt><dd><code>npm run monitoring:live-artifact</code></dd></div>
    </dl>
    <p>
      <small>
        See <code>docs/MONITORING_RUNBOOK.md</code> — artifact review only; metadata differences are not legal change claims.
      </small>
    </p>
  </section>

  {
    liveAllowlist && liveRun ? (
      <section>
        <h2>Cautious live metadata pilot ({PROJECT_VERSION_LABEL})</h2>
        <dl class="meta-grid">
          <div><dt>Pilot ID</dt><dd class="mono">{liveAllowlist.pilot_id}</dd></div>
          <div><dt>Allowlisted sources</dt><dd>{liveAllowlist.sources?.length ?? 0} (max 5)</dd></div>
          <div><dt>Latest run</dt><dd class="mono">{liveRun.run_id}</dd></div>
          <div><dt>Run mode</dt><dd>{humanizeId(liveRun.run_mode)}</dd></div>
          <div><dt>Reference baseline</dt><dd class="mono">{liveRun.previous_reference_run_id ?? "—"}</dd></div>
          <div>
            <dt>metadata_check_ok</dt>
            <dd>{liveChecks.filter((c) => c.check_result === "metadata_check_ok").length}</dd>
          </div>
          <div>
            <dt>metadata_changed_needs_review</dt>
            <dd>{liveChecks.filter((c) => c.check_result === "metadata_changed_needs_review").length}</dd>
          </div>
          <div>
            <dt>metadata_check_failed</dt>
            <dd>{liveChecks.filter((c) => c.check_result === "metadata_check_failed").length}</dd>
          </div>
          <div><dt>client_use_allowed</dt><dd>0</dd></div>
          <div><dt>final_evidence_allowed</dt><dd>0</dd></div>
        </dl>
        <p>
          <small>
            <a href="/data/live-metadata-runs.json">live-metadata-runs.json</a>
            {livePack ? <> · <a href="/data/change-review-packs.json">change-review-packs.json</a></> : null}
            {" "}· Regenerate: <code>npm run monitoring:live-metadata</code>
          </small>
        </p>
        <h3>Allowlisted sources (one request each)</h3>
        <ul>
          {(liveAllowlist.sources ?? []).map((s) => (
            <li>
              <span class="mono">{s.source_id}</span> — {s.request_method} · metadata only · no crawl
            </li>
          ))}
        </ul>
        <h3>Latest live check results</h3>
        <ul>
          {liveChecks.map((c) => (
            <li>
              <span class="mono">{c.source_id}</span> — {humanizeId(c.check_result)}
              {c.http_status != null ? ` HTTP ${c.http_status}` : ""}
              {c.requires_human_review ? " · needs review" : ""}
            </li>
          ))}
        </ul>
        {livePack ? (
          <>
            <h3>Change review pack</h3>
            <p class="prose">
              <small>
                Pack <span class="mono">{livePack.change_review_pack_id}</span> — metadata differences are not legal/regulatory change claims.
              </small>
            </p>
          </>
        ) : null}
        {metadataTriage ? (
          <section>
            <h3>Live metadata review triage ({PROJECT_VERSION_LABEL})</h3>
            <div class="banner banner--review" role="note">
              <strong>Metadata change ≠ legal/regulatory change.</strong> v0.9.7 triage classifies v0.9.6 pilot
              candidates. No full page text stored. Not client evidence. Not final evidence.
            </div>
            <dl class="meta-grid">
              <div><dt>Triage batch</dt><dd class="mono">{metadataTriage.triage_batch_id}</dd></div>
              <div><dt>Related live run</dt><dd class="mono">{metadataTriage.related_live_run_id}</dd></div>
              <div>
                <dt>benign_metadata_change</dt>
                <dd>
                  {triageItems.filter((i) => i.triage_classification === "benign_metadata_change").length}
                </dd>
              </div>
              <div>
                <dt>check_artifact</dt>
                <dd>{triageItems.filter((i) => i.triage_classification === "check_artifact").length}</dd>
              </div>
              <div><dt>legal_change_claimed</dt><dd>0</dd></div>
              <div><dt>client_use_allowed</dt><dd>0</dd></div>
            </dl>
            <p>
              <small>
                <a href="/data/metadata-review-triage.json">metadata-review-triage.json</a>
              </small>
            </p>
            <ul>
              {triageItems.map((item) => (
                <li>
                  <span class="mono">{item.source_id}</span> — {humanizeId(item.triage_classification)}
                  {item.human_review_required ? " · human review" : " · triaged"}
                  {item.changed_fields?.length ? ` (${item.changed_fields.join(", ")})` : ""}
                </li>
              ))}
            </ul>
          </section>
        ) : null}
      </section>
    ) : null
  }

  <section>
    <h2>Monitoring adapter pack ({PROJECT_VERSION_LABEL})</h2>
    <dl class="meta-grid">
      <div><dt>Source configs</dt><dd>{sourceConfigs.length}</dd></div>
      <div><dt>Fetchable (adapter)</dt><dd>{fetchableConfigs.length}</dd></div>
      <div><dt>Manual-only configs</dt><dd>{manualConfigs.length}</dd></div>
      <div><dt>Static page adapters</dt><dd>{sourceConfigs.filter((c) => c.adapter_type === "static_page").length}</dd></div>
    </dl>
    <p>
      <small>
        Data: <code>data/monitoring/source-configs-2026-05-20-v095.yml</code> ·{" "}
        <a href="/data/monitoring-source-configs.json">JSON export</a>
      </small>
    </p>
    <h3>Adapter configs (fetchable)</h3>
    <ul>
      {fetchableConfigs.map((c) => (
        <li>
          <span class="mono">{c.source_id}</span> — {humanizeId(c.adapter_type)} / {humanizeId(c.fetch_scope)} /{" "}
          {humanizeId(c.monitoring_method)}
        </li>
      ))}
    </ul>
    <h3>Blocked / manual-only</h3>
    <ul>
      {manualConfigs.map((c) => (
        <li>
          <span class="mono">{c.source_id}</span> — {humanizeId(c.adapter_type)} ({humanizeId(c.fetch_scope)})
        </li>
      ))}
    </ul>
  </section>

  <section>
    <h2>Watcher eligibility (v0.9.4 batch)</h2>
    <dl class="meta-grid">
      <div><dt>Entries</dt><dd>{eligibility.length}</dd></div>
      <div><dt>Eligible (url_status_check)</dt><dd>{watcherEligible.length}</dd></div>
      <div><dt>Manual-only</dt><dd>{manualOnly.length}</dd></div>
      <div><dt>Blocked / no fetch</dt><dd>{blocked.length}</dd></div>
    </dl>
    <p>
      <small>
        <a href="/data/watcher-eligibility.json">watcher-eligibility.json</a>
      </small>
    </p>
  </section>

  {
    packRun ? (
      <section>
        <h2>Latest monitoring pack run ({packRun.product_version ?? PROJECT_VERSION_LABEL})</h2>
        <dl class="meta-grid">
          <div><dt>Run ID</dt><dd class="mono">{packRun.monitoring_run_id}</dd></div>
          <div><dt>Date</dt><dd>{packRun.run_date}</dd></div>
          <div><dt>Mode</dt><dd>{humanizeId(packRun.mode)}</dd></div>
          <div><dt>Config batch</dt><dd class="mono">{packRun.monitoring_source_config_batch_id ?? "—"}</dd></div>
          <div><dt>Checks</dt><dd>{packChecks.length}</dd></div>
          <div><dt>Change detected</dt><dd>{packRun.change_detected_count ?? 0}</dd></div>
          <div><dt>Needs human review</dt><dd>{packRun.requires_human_review_count ?? packChecks.filter((c) => c.requires_human_review).length}</dd></div>
          <div>
            <dt>metadata_snapshot_created</dt>
            <dd>{packChecks.filter((c) => c.check_result === "metadata_snapshot_created").length}</dd>
          </div>
          <div>
            <dt>no_change_snapshot</dt>
            <dd>{packChecks.filter((c) => c.check_result === "no_change_snapshot_created").length}</dd>
          </div>
          <div>
            <dt>blocked_not_checked</dt>
            <dd>{packChecks.filter((c) => c.check_result === "blocked_not_checked").length}</dd>
          </div>
          <div>
            <dt>manual_only_not_checked</dt>
            <dd>{packChecks.filter((c) => c.check_result === "manual_only_not_checked").length}</dd>
          </div>
        </dl>
        <p>
          <small>
            <a href="/data/monitoring-runs.json">monitoring-runs.json</a> · Regenerate locally:{" "}
            <code>npm run monitoring:pack</code>
          </small>
        </p>
        <h3>Check results</h3>
        <ul>
          {packChecks.map((c) => (
            <li>
              <span class="mono">{c.source_id}</span> — {humanizeId(c.check_result)}
              {c.adapter_type ? ` (${c.adapter_type})` : ""}
              {c.http_status != null ? ` HTTP ${c.http_status}` : ""}
              {c.requires_human_review ? " · needs review" : ""}
            </li>
          ))}
        </ul>
      </section>
    ) : null
  }

  {
    diffSummary ? (
      <section>
        <h2>Latest diff summary (cycle)</h2>
        <dl class="meta-grid">
          <div><dt>Meaningful changes</dt><dd>{diffSummary.has_meaningful_changes ? "yes" : "no"}</dd></div>
          <div><dt>Real detected changes (diff)</dt><dd>{diffSummary.new_real_detected_change_count}</dd></div>
          <div><dt>Watcher errors</dt><dd>{diffSummary.has_watcher_errors ? "yes" : "no"}</dd></div>
          <div><dt>Recommended action</dt><dd class="mono">{diffSummary.recommended_action}</dd></div>
        </dl>
      </section>
    ) : null
  }

  {
    latest ? (
      <section>
        <h2>Latest monitoring cycle</h2>
        <dl class="meta-grid">
          <div><dt>Run ID</dt><dd class="mono">{latest.monitoring_run_id}</dd></div>
          <div><dt>Date</dt><dd>{latest.run_date}</dd></div>
          <div><dt>Mode</dt><dd>{humanizeId(latest.mode)}</dd></div>
          <div><dt>Overall status</dt><dd>{humanizeId(latest.overall_status ?? "—")}</dd></div>
          <div><dt>Watchers configured</dt><dd>{latest.watchers_configured}</dd></div>
          <div><dt>Watchers checked</dt><dd>{latest.watchers_checked}</dd></div>
          <div><dt>Review queue items</dt><dd>{latest.review_queue_count}</dd></div>
        </dl>
      </section>
    ) : (
      <p>No monitoring cycle reports yet. Run <code>npm run monitoring:cycle</code> locally.</p>
    )
  }

  {
    latestWatcher && (
      <section>
        <h2>Latest watcher run</h2>
        <dl class="meta-grid">
          <div><dt>Run ID</dt><dd class="mono">{latestWatcher.run_id}</dd></div>
          <div><dt>Checked</dt><dd>{latestWatcher.checked_count}</dd></div>
          <div><dt>Errors</dt><dd>{latestWatcher.error_count}</dd></div>
          <div><dt>Changes</dt><dd>{latestWatcher.changed_count}</dd></div>
        </dl>
        <p><a href="/watchers/">View all watchers →</a></p>
      </section>
    )
  }

  <section>
    <h2>Watcher inventory</h2>
    <p>
      {enabledWatchers.length} of {watchers.length} watchers enabled (page, feed, API metadata).
    </p>
    <p><a href="/watchers/">Watchers →</a></p>
  </section>

  <section>
    <h2>Detected changes</h2>
    <p>
      {realDetected.length} real · {simulatedDetected.length} simulated (pipeline validation).
    </p>
    <p><a href="/detected-changes/">Detected changes →</a> · <a href="/review-queue/">Review queue →</a></p>
  </section>

  {
    monitoringRuns.length > 1 && (
      <section>
        <h2>Monitoring cycle history</h2>
        <ul>
          {monitoringRuns.map((r) => (
            <li class="mono">
              {r.monitoring_run_id} — {r.run_date} ({r.mode}, {r.overall_status ?? "—"})
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <p class="prose">
    <small>
      See <a href="/methodology/">Methodology</a> and docs: MONITORING_RUNBOOK.md, SOURCE_ADAPTERS.md,
      SNAPSHOT_AND_DIFF_POLICY.md.
    </small>
  </p>
</BaseLayout>
