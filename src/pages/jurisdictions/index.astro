---
import BaseLayout from "../../layouts/BaseLayout.astro";
import JurisdictionCard from "../../components/JurisdictionCard.astro";
import { getJurisdictions } from "../../lib/data";

const jurisdictions = getJurisdictions();
const high = jurisdictions.filter((j) => j.monitoring_priority === "high");
const other = jurisdictions.filter((j) => j.monitoring_priority !== "high");
---

<BaseLayout title="Jurisdictions" currentPath="/jurisdictions/">
  <h1>Jurisdictions</h1>
  <p class="lead">
    Curated pilot jurisdictions. Coverage is incremental and not exhaustive — verify scope on each profile.
  </p>

  {
    high.length > 0 && (
      <section>
        <h2>High monitoring priority</h2>
        <ul class="card-list">
          {high.map((j) => (
            <JurisdictionCard jurisdiction={j} />
          ))}
        </ul>
      </section>
    )
  }

  {
    other.length > 0 && (
      <section>
        <h2>Other pilot jurisdictions</h2>
        <ul class="card-list">
          {other.map((j) => (
            <JurisdictionCard jurisdiction={j} />
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>
