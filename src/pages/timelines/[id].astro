---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReviewBanner from "../../components/ReviewBanner.astro";
import ReviewStatusBadge from "../../components/ReviewStatusBadge.astro";
import {
  getTimelines,
  getTimeline,
  getJurisdiction,
  getRecord,
  getSource,
} from "../../lib/data";
import { formatDate, humanizeId } from "../../lib/format";

export function getStaticPaths() {
  return getTimelines().map((t) => ({
    params: { id: t.timeline_id },
  }));
}

const { id } = Astro.params;
const timeline = getTimeline(id!);

if (!timeline) {
  return Astro.redirect("/timelines/");
}

const jurisdiction = getJurisdiction(timeline.jurisdiction_id);
const relatedRecord = timeline.related_record_id
  ? getRecord(timeline.related_record_id)
  : undefined;
const events = [...timeline.events].sort((a, b) => a.date.localeCompare(b.date));
const registrySources = timeline.source_ids
  .map((sid) => getSource(sid))
  .filter(Boolean);
---

<BaseLayout title={timeline.title} currentPath="/timelines/">
  <p><a href="/timelines/">← Timelines</a></p>
  <h1>{timeline.title}</h1>
  <div class="card__meta" style="margin-bottom: 1rem;">
    <ReviewStatusBadge status={timeline.review_status} />
  </div>

  <ReviewBanner reviewStatus={timeline.review_status} />

  <dl class="meta-grid">
    <div>
      <dt>Jurisdiction</dt>
      <dd>
        {jurisdiction ? (
          <a href={`/jurisdictions/${jurisdiction.jurisdiction_id}/`}>{jurisdiction.name}</a>
        ) : (
          timeline.jurisdiction_id
        )}
      </dd>
    </div>
    {
      relatedRecord && (
        <div>
          <dt>Related record</dt>
          <dd>
            <a href={`/records/${relatedRecord.record_id}/`}>{relatedRecord.title}</a>
          </dd>
        </div>
      )
    }
  </dl>

  <h2>Events (chronological)</h2>
  <ol class="timeline-events">
    {
      events.map((ev) => {
        const source = getSource(ev.source_id);
        return (
          <li class="card timeline-event">
            <p class="card__meta">
              <time datetime={ev.date}>{formatDate(ev.date)}</time>
              <span class="badge badge--type">{humanizeId(ev.event_type)}</span>
              <ReviewStatusBadge status={ev.review_status} />
              {!ev.verified_on_source && (
                <span class="badge badge--warn">Not verified on source</span>
              )}
            </p>
            <h3>{ev.title}</h3>
            <p>{ev.summary_for_review}</p>
            <p class="card__excerpt">
              <small>
                Source:{" "}
                {source ? (
                  source.official_url ? (
                    <a href={source.official_url} target="_blank" rel="noopener noreferrer">
                      {source.title} ↗
                    </a>
                  ) : (
                    <a href={`/sources/${source.source_id}/`}>{source.title} (URL pending)</a>
                  )
                ) : (
                  ev.source_id
                )}
              </small>
            </p>
            <p class="card__excerpt">
              <small>{ev.legal_safe_note}</small>
            </p>
          </li>
        );
      })
    }
  </ol>

  {
    registrySources.length > 0 && (
      <section>
        <h2>Registry sources</h2>
        <ul>
          {registrySources.map((s) => (
            <li>
              <a href={`/sources/${s!.source_id}/`}>{s!.title}</a>
              {s!.official_url && (
                <>
                  {" · "}
                  <a href={s!.official_url} target="_blank" rel="noopener noreferrer">
                    Official ↗
                  </a>
                </>
              )}
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <h2>Timeline note</h2>
  <div class="prose"><p>{timeline.legal_safe_note}</p></div>
</BaseLayout>
