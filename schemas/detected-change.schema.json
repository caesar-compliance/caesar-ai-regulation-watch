{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/detected-change.schema.json",
  "title": "Caesar AI Regulation Watch — Detected change (pending review)",
  "description": "Watcher-detected metadata diff pending human review. Not a legal conclusion or verified change record.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "detected_change_id",
    "watcher_id",
    "source_id",
    "jurisdiction_id",
    "detected_at",
    "change_type",
    "changed_fields",
    "previous_snapshot_id",
    "current_snapshot_id",
    "previous_value_summary",
    "current_value_summary",
    "previous_snapshot_summary",
    "current_snapshot_summary",
    "change_summary_for_review",
    "significance_level",
    "human_review_required",
    "review_status",
    "review_queue_reason",
    "client_use_allowed",
    "legal_safe_note",
    "minimum_change_policy"
  ],
  "properties": {
    "detected_change_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "watcher_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "source_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "jurisdiction_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "detected_at": {
      "type": "string",
      "format": "date-time"
    },
    "simulation": {
      "type": "boolean",
      "default": false
    },
    "adapter_id": {
      "type": "string",
      "enum": [
        "official_page_metadata",
        "official_rss_or_feed",
        "official_api_metadata",
        "manual_only"
      ]
    },
    "source_adapter_type": {
      "type": "string",
      "enum": [
        "official_page_metadata",
        "official_rss_or_feed",
        "official_api_metadata",
        "manual_only"
      ]
    },
    "error_category": {
      "type": "string",
      "enum": [
        "timeout",
        "dns_error",
        "rate_limited",
        "forbidden",
        "server_error",
        "invalid_feed",
        "invalid_api_response",
        "network_error",
        "unknown_error"
      ]
    },
    "change_type": {
      "type": "string",
      "enum": [
        "metadata_changed",
        "content_hash_changed",
        "normalized_text_hash_changed",
        "title_changed",
        "final_url_changed",
        "redirect_changed",
        "http_status_changed",
        "http_metadata_changed",
        "etag_changed",
        "last_modified_changed",
        "content_length_changed",
        "combined_metadata_change",
        "watcher_error",
        "new_feed_entry",
        "removed_feed_entry",
        "changed_feed_entry_metadata",
        "feed_unreachable",
        "feed_redirected",
        "new_api_result",
        "api_unreachable"
      ]
    },
    "changed_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "metadata_changed",
          "content_hash_changed",
          "normalized_text_hash_changed",
          "title_changed",
          "final_url_changed",
          "redirect_changed",
          "http_status_changed",
          "http_metadata_changed",
          "etag_changed",
          "last_modified_changed",
          "content_length_changed",
          "watcher_error",
          "new_feed_entry",
          "removed_feed_entry",
          "changed_feed_entry_metadata",
          "feed_unreachable",
          "feed_redirected",
          "new_api_result",
          "api_unreachable"
        ]
      }
    },
    "feed_entries_affected": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entry_id"],
        "properties": {
          "entry_id": { "type": "string" },
          "title": { "type": ["string", "null"] },
          "link": { "type": ["string", "null"] },
          "published_at": { "type": ["string", "null"] }
        }
      }
    },
    "api_results_affected": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["result_id"],
        "properties": {
          "result_id": { "type": "string" },
          "title": { "type": ["string", "null"] },
          "link": { "type": ["string", "null"] },
          "publication_date": { "type": ["string", "null"] }
        }
      }
    },
    "previous_snapshot_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "current_snapshot_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "previous_value_summary": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "current_value_summary": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "previous_snapshot_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "current_snapshot_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "ignored_fields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "volatile_field_note": {
      "type": ["string", "null"]
    },
    "minimum_change_policy": {
      "type": "string",
      "minLength": 1
    },
    "change_summary_for_review": {
      "type": "string",
      "minLength": 1
    },
    "significance_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "confidence_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "human_review_required": {
      "type": "boolean",
      "const": true
    },
    "review_status": {
      "type": "string",
      "enum": [
        "draft",
        "pending_review",
        "reviewed",
        "needs_update",
        "rejected_for_client_use",
        "archived"
      ]
    },
    "review_queue_reason": {
      "type": "string",
      "enum": [
        "detected_change_pending_review",
        "simulated_detected_change_pending_review",
        "feed_detected_change_pending_review",
        "simulated_feed_detected_change_pending_review",
        "api_detected_change_pending_review",
        "simulated_api_detected_change_pending_review",
        "watcher_error",
        "human_review_required"
      ]
    },
    "client_use_allowed": {
      "type": "boolean",
      "const": false
    },
    "legal_safe_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
