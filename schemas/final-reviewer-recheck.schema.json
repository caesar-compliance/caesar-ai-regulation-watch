{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/final-reviewer-recheck.schema.json",
  "title": "Caesar AI Regulation Watch — Final reviewer re-check",
  "description": "Internal metadata-only final reviewer re-check after T064 response. Not publication. Not final approval.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "final_reviewer_rechecks_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_live_collection",
    "no_scheduled_monitoring",
    "rechecks"
  ],
  "properties": {
    "final_reviewer_rechecks_id": {
      "type": "string",
      "pattern": "^final-reviewer-rechecks-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_collection": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "rechecks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/recheckRecord" }
    }
  },
  "$defs": {
    "gateState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false }
      }
    },
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_allowed",
        "public_export_allowed",
        "evidence_export_allowed",
        "final_legal_approval_completed",
        "final_source_verification_completed",
        "ready_for_publication_gate_review",
        "metadata_only",
        "stores_full_text",
        "requires_separate_publication_approval",
        "requires_separate_evidence_approval"
      ],
      "properties": {
        "publication_allowed": { "type": "boolean", "const": false },
        "public_export_allowed": { "type": "boolean", "const": false },
        "evidence_export_allowed": { "type": "boolean", "const": false },
        "final_legal_approval_completed": { "type": "boolean", "const": false },
        "final_source_verification_completed": { "type": "boolean", "const": false },
        "ready_for_publication_gate_review": { "type": "boolean" },
        "metadata_only": { "type": "boolean", "const": true },
        "stores_full_text": { "type": "boolean", "const": false },
        "requires_separate_publication_approval": { "type": "boolean", "const": true },
        "requires_separate_evidence_approval": { "type": "boolean", "const": true }
      }
    },
    "recheckScope": {
      "type": "string",
      "const": "internal_final_recheck_only"
    },
    "recheckStatus": {
      "type": "string",
      "enum": ["recorded", "superseded"]
    },
    "recheckResult": {
      "type": "string",
      "enum": ["ready_for_publication_gate_review", "needs_more_changes", "blocked"]
    },
    "reviewedItemRecheckStatus": {
      "type": "string",
      "enum": ["accepted_for_internal_recheck", "still_blocked", "needs_follow_up"]
    },
    "reviewedResponseItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "prior_status", "recheck_status", "recheck_note"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "prior_status": { "type": "string", "minLength": 1 },
        "recheck_status": { "$ref": "#/$defs/reviewedItemRecheckStatus" },
        "recheck_note": { "type": "string", "maxLength": 500 }
      }
    },
    "recheckRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recheck_id",
        "response_id",
        "decision_id",
        "packet_id",
        "draft_update_id",
        "draft_update_path",
        "source_verification_result_id",
        "recheck_scope",
        "recheck_status",
        "recheck_result",
        "recheck_summary",
        "reviewed_response_items",
        "remaining_blockers",
        "next_required_step",
        "checked_by_role",
        "checked_at",
        "created_at",
        "updated_at",
        "gates",
        "safety"
      ],
      "properties": {
        "recheck_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "response_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "packet_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "draft_update_id": { "type": "string", "minLength": 1 },
        "draft_update_path": { "type": "string", "pattern": "^data/regulatory-updates/drafts/" },
        "source_verification_result_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "recheck_scope": { "$ref": "#/$defs/recheckScope" },
        "recheck_status": { "$ref": "#/$defs/recheckStatus" },
        "recheck_result": { "$ref": "#/$defs/recheckResult" },
        "recheck_summary": { "type": "string", "maxLength": 1000 },
        "reviewed_response_items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reviewedResponseItem" }
        },
        "remaining_blockers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "next_required_step": { "type": "string", "minLength": 1 },
        "checked_by_role": { "type": "string", "minLength": 1 },
        "checked_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" },
        "gates": { "$ref": "#/$defs/gateState" },
        "safety": { "$ref": "#/$defs/safetyFlags" }
      }
    }
  }
}
