{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/source-pilot-decision-packets.schema.json",
  "title": "Caesar AI Regulation Watch — Source pilot decision packets export",
  "description": "Offline fixture-based decision packets for operator triage. Metadata only. No secrets or legal text.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "export_id",
    "status",
    "mode",
    "checked_at",
    "source_count",
    "candidate_count",
    "packet_count",
    "packets",
    "runtime_flags",
    "gates",
    "public_note"
  ],
  "properties": {
    "export_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["decision_packets_ready", "empty", "error"]
    },
    "mode": { "type": "string", "const": "fixture_only" },
    "checked_at": { "type": "string", "format": "date-time" },
    "source_count": { "type": "integer", "minimum": 0 },
    "candidate_count": { "type": "integer", "minimum": 0 },
    "packet_count": { "type": "integer", "minimum": 0 },
    "packets": {
      "type": "array",
      "items": { "$ref": "#/$defs/decisionPacket" }
    },
    "runtime_flags": { "$ref": "#/$defs/runtimeFlags" },
    "gates": { "$ref": "#/$defs/gates" },
    "public_note": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "runtimeFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_ingestion_enabled",
        "scheduled_monitoring_enabled",
        "network_execution_enabled"
      ],
      "properties": {
        "live_ingestion_enabled": { "type": "boolean", "const": false },
        "scheduled_monitoring_enabled": { "type": "boolean", "const": false },
        "network_execution_enabled": { "type": "boolean", "const": false }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed",
        "publication_allowed",
        "public_export_allowed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false },
        "publication_allowed": { "type": "boolean", "const": false },
        "public_export_allowed": { "type": "boolean", "const": false }
      }
    },
    "checklistItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "required", "completed_placeholder"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "completed_placeholder": { "type": "boolean" }
      }
    },
    "decisionPlaceholder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "selected_placeholder", "note_placeholder"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "selected_placeholder": { "type": "boolean", "const": false },
        "note_placeholder": { "type": "string", "minLength": 1 }
      }
    },
    "decisionPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "candidate_id",
        "source_id",
        "source_name",
        "jurisdiction",
        "source_type",
        "official_url",
        "candidate_status",
        "reviewer_status",
        "packet_status",
        "packet_created_at",
        "change_type",
        "detected_at",
        "title",
        "metadata_fields_changed",
        "previous_metadata_hash",
        "current_metadata_hash",
        "operator_checklist",
        "manual_review_steps",
        "blocked_until",
        "safety_flags",
        "runtime_flags",
        "decision_placeholders",
        "public_note"
      ],
      "properties": {
        "packet_id": { "type": "string", "minLength": 1 },
        "candidate_id": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "source_name": { "type": "string", "minLength": 1 },
        "jurisdiction": { "type": "string", "minLength": 1 },
        "source_type": { "type": "string", "enum": ["rss", "api", "html", "manual"] },
        "official_url": { "type": "string", "format": "uri" },
        "candidate_status": {
          "type": "string",
          "enum": ["new_metadata_detected", "metadata_fields_changed", "fixture_baseline"]
        },
        "reviewer_status": {
          "type": "string",
          "enum": [
            "pending_review",
            "needs_source_verification",
            "blocked_no_network",
            "ready_for_manual_inspection"
          ]
        },
        "packet_status": {
          "type": "string",
          "enum": [
            "draft_offline_packet",
            "pending_manual_review",
            "blocked_no_network",
            "blocked_no_supabase",
            "ready_for_operator_triage"
          ]
        },
        "packet_created_at": { "type": "string", "format": "date-time" },
        "change_type": {
          "type": "string",
          "enum": ["added", "modified", "removed", "unchanged"]
        },
        "detected_at": { "type": "string", "format": "date-time" },
        "title": { "type": ["string", "null"], "maxLength": 500 },
        "metadata_fields_changed": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "previous_metadata_hash": { "type": "string", "minLength": 8 },
        "current_metadata_hash": { "type": "string", "minLength": 8 },
        "operator_checklist": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/checklistItem" }
        },
        "manual_review_steps": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "blocked_until": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "safety_flags": { "$ref": "#/$defs/gates" },
        "runtime_flags": { "$ref": "#/$defs/runtimeFlags" },
        "decision_placeholders": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mark_for_manual_inspection",
            "request_source_verification_later",
            "keep_blocked",
            "discard_fixture_candidate"
          ],
          "properties": {
            "mark_for_manual_inspection": { "$ref": "#/$defs/decisionPlaceholder" },
            "request_source_verification_later": { "$ref": "#/$defs/decisionPlaceholder" },
            "keep_blocked": { "$ref": "#/$defs/decisionPlaceholder" },
            "discard_fixture_candidate": { "$ref": "#/$defs/decisionPlaceholder" }
          }
        },
        "public_note": { "type": "string", "minLength": 1 }
      }
    }
  }
}
