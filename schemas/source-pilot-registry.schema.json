{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/source-pilot-registry.schema.json",
  "title": "Caesar AI Regulation Watch — Controlled source pilot registry",
  "description": "Metadata-only allowlisted official sources for offline/manual pilot framework. No full text. No live network.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_pilot_registry_id",
    "generated_at",
    "legal_safe_note",
    "no_live_ingestion",
    "no_scheduled_monitoring",
    "no_network_execution",
    "sources"
  ],
  "properties": {
    "source_pilot_registry_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_ingestion": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "no_network_execution": { "type": "boolean", "const": true },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": { "$ref": "#/$defs/sourcePilotEntry" }
    }
  },
  "$defs": {
    "sourcePilotEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_name",
        "jurisdiction",
        "source_type",
        "official_url",
        "monitoring_status",
        "adapter_type",
        "allowed_for_manual_check",
        "allowed_for_network_check",
        "stores_full_text",
        "stores_metadata_only",
        "safety_flags"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "source_name": { "type": "string", "minLength": 1 },
        "jurisdiction": { "type": "string", "minLength": 1 },
        "source_type": {
          "type": "string",
          "enum": ["rss", "atom", "webpage_metadata", "api_metadata"]
        },
        "official_url": { "type": "string", "format": "uri" },
        "monitoring_status": {
          "type": "string",
          "enum": ["design_ready", "manual_only", "disabled"]
        },
        "adapter_type": { "type": "string", "minLength": 1 },
        "allowed_for_manual_check": { "type": "boolean", "const": true },
        "allowed_for_network_check": { "type": "boolean", "const": false },
        "stores_full_text": { "type": "boolean", "const": false },
        "stores_metadata_only": { "type": "boolean", "const": true },
        "notes": { "type": "string" },
        "safety_flags": { "$ref": "#/$defs/safetyFlags" }
      }
    },
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed",
        "publication_allowed",
        "public_export_allowed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false },
        "publication_allowed": { "type": "boolean", "const": false },
        "public_export_allowed": { "type": "boolean", "const": false }
      }
    }
  }
}
