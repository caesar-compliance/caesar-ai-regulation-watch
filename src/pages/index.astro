---
import BaseLayout from "../layouts/BaseLayout.astro";
import DevelopersPanel from "../components/DevelopersPanel.astro";
import StatusBucketBadge from "../components/StatusBucketBadge.astro";
import TrackerMeter from "../components/TrackerMeter.astro";
import { getChanges } from "../lib/data";
import {
  getReviewQueueSummary as getRegulationReviewQueueSummary,
  getOperatorReviewSummary,
  getSignalQualitySummary,
} from "../lib/regulation-review-queue";
import { getAutomationFirstMetrics } from "../lib/tracker-data";
import MetricsStrip from "../components/MetricsStrip.astro";
import { formatDate, truncate } from "../lib/format";
import { PROJECT_PHASE_LABEL, PROJECT_VERSION_LABEL } from "../lib/project-version";
import { getPublicRouteSummary } from "../lib/public-route-summary";
import { getJurisdictionProfileCards } from "../lib/runtime-monitoring-data";
import { getCountryStatus } from "../lib/tracker-data";

const routeSummary = getPublicRouteSummary();
const regulationReviewSummary = getRegulationReviewQueueSummary();
const operatorSummary = getOperatorReviewSummary();
const signalSummary = getSignalQualitySummary();
const profileCards = getJurisdictionProfileCards();
const recentChanges = getChanges().slice(0, 3);
const trackerMetrics = getAutomationFirstMetrics();
---

<BaseLayout title="Home" currentPath="/">
  <h1>Caesar AI Regulation Watch</h1>
  <p class="lead">
    {PROJECT_VERSION_LABEL} — T083 signal quality and review prioritization on backend monitoring
    candidates, with T082 operator decisions and T080 country profiles. Technical pilot — not legal
    advice and not complete global coverage.
  </p>

  <div class="banner banner--review" role="note">
    <strong>T083 Signal Quality and Review Prioritization ({PROJECT_VERSION_LABEL}).</strong>{" "}
    {signalSummary.total_candidates ?? regulationReviewSummary.total} regulation review candidates ·{" "}
    {signalSummary.high_relevance_count ?? 0} high relevance · {signalSummary.noise_count ?? 0} noise ·{" "}
    {signalSummary.source_check_count ?? 0} source-check recommended · Rules{" "}
    <code>{signalSummary.rules_version ?? "—"}</code> · All safety gates closed · cron disabled.{" "}
    <a href="/review-queue/">Review queue →</a> ·{" "}
    <a href="/data/signal-quality-summary.json">signal-quality-summary.json</a>
  </div>

  <div class="banner banner--automation" role="note">
    <strong>T082 Operator Decision Workflow.</strong>{" "}
    {operatorSummary.decision_count ?? 0} operator decisions in local YAML ·{" "}
    {regulationReviewSummary.review_required} review_required ·{" "}
    {regulationReviewSummary.in_review} in_review ·{" "}
    {regulationReviewSummary.needs_source_check} needs source check ·{" "}
    {regulationReviewSummary.accepted_for_tracking} accepted for tracking (not legal verification) ·{" "}
    {regulationReviewSummary.dismissed} dismissed.
  </div>

  <div class="banner banner--automation" role="note">
    <strong>T080 coverage model.</strong> Explore the <a href="/tracker/">global tracker</a>,{" "}
    <a href="/map/">interactive map</a>, <a href="/compare/">jurisdiction comparison</a>,{" "}
    <a href="/updates/">updates feed</a>, and <a href="/countries/">country status cards</a>. Dev
    Worker deployed; scheduled monitoring disabled.
  </div>

  <MetricsStrip metrics={trackerMetrics} />

  <div class="banner banner--review" role="note">
    <strong>
      {PROJECT_VERSION_LABEL} {PROJECT_PHASE_LABEL}.
    </strong>{" "}
    {routeSummary.jurisdictionCount} jurisdictions · {routeSummary.regulationRecordCount} regulation
    records · {routeSummary.monitoredSourceCount} monitored sources ({routeSummary.automatedRssCount}{" "}
    automated RSS, {routeSummary.manualReviewSourceCount} manual review). Not legal advice. No
    compliance guarantee. See <a href="/methodology/">methodology</a> and{" "}
    <a href="/disclaimer/">disclaimer</a>.
  </div>

  <section class="stats" aria-label="Coverage summary">
    <div class="stat">
      <strong>{routeSummary.profileCardCount}</strong>
      <span>Jurisdiction profiles</span>
    </div>
    <div class="stat">
      <strong>{routeSummary.regulationRecordCount}</strong>
      <span>Regulation records</span>
    </div>
    <div class="stat">
      <strong>{routeSummary.monitoredSourceCount}</strong>
      <span>Official sources</span>
    </div>
    <div class="stat">
      <strong>{routeSummary.automatedRssCount}</strong>
      <span>Automated RSS</span>
    </div>
    <div class="stat">
      <strong>{routeSummary.manualReviewSourceCount}</strong>
      <span>Manual-review sources</span>
    </div>
    <div class="stat">
      <strong>{routeSummary.workerDeployed ? "yes" : "no"}</strong>
      <span>Backend worker (dev)</span>
    </div>
  </section>

  <h2>Explore the registry</h2>
  <div class="nav-cards">
    <div class="nav-card nav-card--accent">
      <a href="/tracker/">Global tracker</a>
      <p>T080 dashboard — countries, regulations, monitored sources, worker state</p>
    </div>
    <div class="nav-card nav-card--accent">
      <a href="/map/">Interactive regulation map</a>
      <p>
        {routeSummary.mapMarkerCount} jurisdictions — status, maturity, activity, and freshness meters
      </p>
    </div>
    <div class="nav-card">
      <a href="/compare/">Compare jurisdictions</a>
      <p>Side-by-side tracker metadata for up to {routeSummary.jurisdictionCount} pilot jurisdictions</p>
    </div>
    <div class="nav-card">
      <a href="/updates/">Regulatory updates</a>
      <p>Source-linked update feed with filters</p>
    </div>
    <div class="nav-card">
      <a href="/countries/">Country status</a>
      <p>{routeSummary.profileCardCount} jurisdiction profile cards with regulation counts</p>
    </div>
    <div class="nav-card">
      <a href="/jurisdictions/">Jurisdictions</a>
      <p>
        {routeSummary.jurisdictionCount} jurisdictions grouped by region — incremental global coverage
      </p>
    </div>
    <div class="nav-card">
      <a href="/sources/">Official sources</a>
      <p>{routeSummary.monitoredSourceCount} monitored authority URLs in pilot registry</p>
    </div>
    <div class="nav-card nav-card--accent">
      <a href="/review-queue/">Regulation review queue (T083/T082)</a>
      <p>
        {signalSummary.total_candidates ?? regulationReviewSummary.total} candidates ·{" "}
        {signalSummary.noise_count ?? 0} noise · {operatorSummary.decision_count ?? 0} operator
        decisions — metadata only
      </p>
    </div>
    <div class="nav-card">
      <a href="/timelines/">Timelines</a>
      <p>Milestone views linked to official sources (sample events)</p>
    </div>
    <div class="nav-card">
      <a href="/records/">Laws &amp; guidance</a>
      <p>Filterable sample instrument records</p>
    </div>
    <div class="nav-card">
      <a href="/changes/">Changes</a>
      <p>Manual sample change feed + RSS</p>
    </div>
    <div class="nav-card">
      <a href="/exports/">Export samples</a>
      <p>Regulation-change contract examples (not client evidence)</p>
    </div>
    <div class="nav-card nav-card--accent">
      <a href="/search/">Search</a>
      <p>Search all static pages (after full build)</p>
    </div>
  </div>

  <h2>Jurisdiction profile cards</h2>
  <ul class="country-card-grid">
    {
      profileCards.map((card) => {
        const cs = getCountryStatus(card.jurisdiction_id);
        return (
          <li class="country-card">
            <div class="country-card__head">
              <h3>
                <a href={`/jurisdictions/${card.jurisdiction_id}/`}>{card.display_name}</a>
              </h3>
              {cs && <StatusBucketBadge bucket={cs.status_bucket} label={cs.status_label} />}
            </div>
            <p class="country-card__meta">{card.status_headline}</p>
            <p class="country-card__meta">
              Regulations: {card.regulation_records_count} · Sources: {card.monitored_sources_count} (
              {card.automated_sources_count} auto / {card.manual_sources_count} manual)
            </p>
            <TrackerMeter label="Maturity" score={card.maturity_score} />
            <TrackerMeter label="Activity" score={card.activity_score} />
            <p class="country-card__meta">
              <a href={`/compare/?ids=${card.jurisdiction_id}`}>Compare</a>
              {" · "}
              <a href={`/map/?jurisdiction=${card.jurisdiction_id}`}>Map panel</a>
            </p>
          </li>
        );
      })
    }
  </ul>

  {
    recentChanges.length > 0 && (
      <section>
        <h2>Recent sample changes</h2>
        <ul class="card-list">
          {recentChanges.map((c) => (
            <li class="card">
              <h3>
                <a href={`/changes/${c.change_id}/`}>{c.change_id}</a>
              </h3>
              <p class="card__excerpt">{truncate(c.change_summary_for_review, 120)}</p>
              <p class="card__excerpt">
                <small>
                  {formatDate(c.detected_date)} · {c.jurisdiction_id}
                  {c.requires_human_review ? " · Human review required" : ""}
                </small>
              </p>
            </li>
          ))}
        </ul>
        <p><a href="/changes/">View all changes →</a></p>
      </section>
    )
  }

  <DevelopersPanel />
</BaseLayout>
