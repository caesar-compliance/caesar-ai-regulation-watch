{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/publication-gate-packet.schema.json",
  "title": "Caesar AI Regulation Watch — Publication gate packet",
  "description": "Internal metadata-only publication gate packet. Not publication. Not public export approval.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "publication_gate_packets_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_live_collection",
    "no_scheduled_monitoring",
    "packets"
  ],
  "properties": {
    "publication_gate_packets_id": {
      "type": "string",
      "pattern": "^publication-gate-packets-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_collection": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "packets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/packetRecord" }
    }
  },
  "$defs": {
    "gateState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false }
      }
    },
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publication_allowed",
        "public_export_allowed",
        "evidence_export_allowed",
        "client_use_allowed",
        "final_source_verification_completed",
        "final_legal_approval_completed",
        "metadata_only",
        "stores_full_text",
        "requires_publication_gate_decision",
        "requires_separate_public_export_approval",
        "requires_separate_client_evidence_approval"
      ],
      "properties": {
        "publication_allowed": { "type": "boolean", "const": false },
        "public_export_allowed": { "type": "boolean", "const": false },
        "evidence_export_allowed": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "final_source_verification_completed": { "type": "boolean", "const": false },
        "final_legal_approval_completed": { "type": "boolean", "const": false },
        "metadata_only": { "type": "boolean", "const": true },
        "stores_full_text": { "type": "boolean", "const": false },
        "requires_publication_gate_decision": { "type": "boolean", "const": true },
        "requires_separate_public_export_approval": { "type": "boolean", "const": true },
        "requires_separate_client_evidence_approval": { "type": "boolean", "const": true }
      }
    },
    "packetScope": {
      "type": "string",
      "const": "internal_publication_gate_packet"
    },
    "packetStatus": {
      "type": "string",
      "enum": ["pending_publication_gate_decision", "blocked", "superseded"]
    },
    "gateResult": {
      "type": "string",
      "enum": [
        "blocked_pending_publication_decision",
        "ready_for_publication_gate_decision",
        "rejected"
      ]
    },
    "gateItemStatus": {
      "type": "string",
      "enum": ["ready_for_gate_review", "blocked", "needs_follow_up", "not_applicable"]
    },
    "publicationGateItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "status", "note", "owner_role"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/gateItemStatus" },
        "note": { "type": "string", "maxLength": 500 },
        "owner_role": { "type": "string", "minLength": 1 }
      }
    },
    "packetRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "draft_update_id",
        "draft_update_path",
        "source_verification_result_id",
        "legal_review_packet_id",
        "legal_review_decision_id",
        "legal_review_response_id",
        "final_reviewer_recheck_id",
        "packet_scope",
        "packet_status",
        "gate_result",
        "gate_summary",
        "publication_gate_items",
        "blockers_remaining",
        "next_required_step",
        "created_at",
        "updated_at",
        "gates",
        "safety"
      ],
      "properties": {
        "packet_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "draft_update_id": { "type": "string", "minLength": 1 },
        "draft_update_path": { "type": "string", "pattern": "^data/regulatory-updates/drafts/" },
        "source_verification_result_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "legal_review_packet_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "legal_review_decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "legal_review_response_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "final_reviewer_recheck_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "packet_scope": { "$ref": "#/$defs/packetScope" },
        "packet_status": { "$ref": "#/$defs/packetStatus" },
        "gate_result": { "$ref": "#/$defs/gateResult" },
        "gate_summary": { "type": "string", "maxLength": 1000 },
        "publication_gate_items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/publicationGateItem" }
        },
        "blockers_remaining": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "next_required_step": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" },
        "gates": { "$ref": "#/$defs/gateState" },
        "safety": { "$ref": "#/$defs/safetyFlags" }
      }
    }
  }
}
