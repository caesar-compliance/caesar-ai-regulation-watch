# Caesar AI Regulation Watch — runtime environment (placeholders only)
# Copy to .env.runtime.local and fill in locally. Never commit .env.runtime.local.

SUPABASE_PROJECT_NAME=caesar-regulation-watch-dev
SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_DB_URL=
SUPABASE_SCHEMA=regulation_watch

# Preferred: Supabase publishable/secret API keys (Dashboard → API → API Keys)
SUPABASE_API_KEY_MODE=new
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Optional deprecated fallback (legacy JWT anon/service_role keys)
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

REGWATCH_RUNTIME_ENV=local
REGWATCH_APPLY_SUPABASE_SCHEMA=false
REGWATCH_ENABLE_LIVE_INGESTION=false
REGWATCH_ENABLE_SCHEDULED_MONITORING=false
REGWATCH_ENABLE_NETWORK_EXECUTION=false
