---
import { isPendingReview, needsHumanReview } from "../lib/format";

interface Props {
  reviewStatus?: string;
  recordOrigin?: string;
  requiresHumanReview?: boolean;
  sample?: boolean;
}

const { reviewStatus, recordOrigin, requiresHumanReview, sample = false } = Astro.props;

const show =
  sample ||
  recordOrigin === "manual_sample" ||
  isPendingReview(reviewStatus) ||
  requiresHumanReview === true;
---

{
  show && (
    <div class={`banner ${sample || recordOrigin === "manual_sample" ? "banner--sample" : "banner--review"}`} role="status">
      {sample || recordOrigin === "manual_sample" ? (
        <strong>Manual sample.</strong>
      ) : (
        <strong>Pending review.</strong>
      )}{" "}
      This content supports governance review only. Human review is required before client use. Not legal
      advice.
    </div>
  )
}
