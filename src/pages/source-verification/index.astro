---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getSourceVerificationCockpitCase,
  getSourceVerificationChecklistEntries,
  getSourceVerificationResultEntries,
} from "../../lib/data";
import { humanizeId } from "../../lib/format";
import { PROJECT_VERSION_LABEL } from "../../lib/project-version";

const CHECKLIST_ID = "T060-001";
const RESULT_ID = "T061-001";
const cockpit = getSourceVerificationCockpitCase(CHECKLIST_ID);
const allChecklists = getSourceVerificationChecklistEntries();
const allResults = getSourceVerificationResultEntries();

if (!cockpit) {
  throw new Error(`Source verification cockpit case missing: ${CHECKLIST_ID}`);
}

const { checklist, result, draft, promotion, decision, revision, readinessGate, execution, approval } =
  cockpit;

const timeline = [
  {
    step: "T055",
    label: "Single-source network dry-run",
    id: execution?.execution_id ?? draft?.source_execution_id,
    status: execution?.status,
    detail: approval ? `Approval ${approval.approval_id}` : null,
  },
  {
    step: "T056",
    label: "Manual review promotion",
    id: promotion?.promotion_id ?? draft?.promotion_id,
    status: promotion?.status,
    detail: promotion?.draft_update_path,
  },
  {
    step: "T057",
    label: "Reviewer decision",
    id: decision?.decision_id ?? draft?.latest_review_decision_id,
    status: decision?.decision,
    detail: decision?.decision_scope,
  },
  {
    step: "T058",
    label: "Draft revision packet",
    id: revision?.revision_id ?? draft?.latest_revision_id,
    status: revision?.revision_status,
    detail: draft?.review_status,
  },
  {
    step: "T059",
    label: "Internal draft readiness gate",
    id: readinessGate?.readiness_id ?? draft?.latest_readiness_gate_id,
    status: readinessGate?.readiness_result ?? draft?.readiness_result,
    detail: readinessGate?.next_required_step ?? draft?.next_required_step,
  },
  {
    step: "T060",
    label: "Source verification checklist",
    id: checklist.checklist_id,
    status: checklist.status,
    detail: checklist.next_required_step,
  },
  {
    step: "T061",
    label: "Manual verification results",
    id: result?.result_id ?? draft?.latest_source_verification_result_id,
    status: result?.result_status ?? "—",
    detail: result?.overall_result ?? draft?.source_verification_result,
  },
];

const itemCounts = { pending: 0, local_data_present: 0, blocked: 0 };
for (const item of checklist.checklist_items) {
  if (itemCounts[item.status] !== undefined) itemCounts[item.status] += 1;
}

const resultItemCounts = {
  manual_pass: 0,
  manual_fail: 0,
  needs_follow_up: 0,
  not_checked: 0,
};
if (result) {
  for (const item of result.item_results) {
    if (resultItemCounts[item.result] !== undefined) resultItemCounts[item.result] += 1;
  }
}
---

<BaseLayout
  title="Source Verification Cockpit"
  description="Internal draft source verification checklist — not verified, not published, not legal advice."
  currentPath="/source-verification/"
>
  <h1>Source Verification Cockpit</h1>
  <p class="lead">
    Internal automation pipeline view for draft source verification ({PROJECT_VERSION_LABEL}). Read-only
    metadata — no run controls, no network actions, no publication.
  </p>

  <div class="banner banner--review" role="note">
    <strong>Not verified on source.</strong> Not published. Not legal advice. All evidence and client gates
    remain closed. Checklist status: <code>{checklist.status}</code>. Verification scope:{" "}
    <code>{checklist.verification_scope}</code>.
  </div>

  <section>
    <h2>Case — {checklist.draft_update_id}</h2>
    <dl class="meta-grid">
      <div><dt>Checklist</dt><dd><span class="mono">{checklist.checklist_id}</span></dd></div>
      <div><dt>Draft path</dt><dd><span class="mono">{checklist.draft_update_path}</span></dd></div>
      <div><dt>Source adapter</dt><dd><span class="mono">{checklist.source_adapter_id}</span></dd></div>
      <div><dt>Source</dt><dd><span class="mono">{checklist.source_id}</span></dd></div>
      <div><dt>Source URL</dt><dd><a href={checklist.source_url} rel="noopener noreferrer">{checklist.source_url}</a></dd></div>
      <div><dt>Next step</dt><dd><span class="mono">{checklist.next_required_step}</span></dd></div>
    </dl>
    {
      draft && (
        <>
          <h3>Draft metadata (internal only)</h3>
          <dl class="meta-grid">
            <div><dt>Title</dt><dd>{draft.title}</dd></div>
            <div><dt>Review status</dt><dd>{humanizeId(draft.review_status)}</dd></div>
            <div><dt>Status</dt><dd>{humanizeId(draft.status)}</dd></div>
            <div><dt>Published (metadata)</dt><dd>{draft.source_published_at ?? draft.published_at}</dd></div>
            <div><dt>Jurisdictions</dt><dd>{draft.jurisdiction_ids.join(", ")}</dd></div>
            <div><dt>Topics</dt><dd>{draft.topic_ids.join(", ")}</dd></div>
          </dl>
          <p class="card__excerpt">{draft.summary}</p>
        </>
      )
    }
  </section>

  <section>
    <h2>Pipeline timeline</h2>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Step</th>
            <th>Stage</th>
            <th>Record</th>
            <th>Status</th>
            <th>Detail</th>
          </tr>
        </thead>
        <tbody>
          {
            timeline.map((row) => (
              <tr>
                <td><span class="mono">{row.step}</span></td>
                <td>{row.label}</td>
                <td><span class="mono">{row.id ?? "—"}</span></td>
                <td>{row.status ? humanizeId(String(row.status)) : "—"}</td>
                <td><span class="mono">{row.detail ?? "—"}</span></td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Checklist items</h2>
    <p>
      Item counts: pending {itemCounts.pending}, local data {itemCounts.local_data_present}, blocked{" "}
      {itemCounts.blocked}. No item marked passed or verified.
    </p>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Item</th>
            <th>Status</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          {
            checklist.checklist_items.map((item) => (
              <tr>
                <td><span class="mono">{item.item_key}</span></td>
                <td>
                  <span class={`badge badge--status-${item.status}`}>{item.status}</span>
                </td>
                <td>{item.notes ?? "—"}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  {
    result && (
      <section>
        <h2>Source verification results (T061)</h2>
        <p>
          Item-level manual checks recorded — not final source verification. Result{" "}
          <code>{result.result_id}</code> for checklist <code>{result.checklist_id}</code>.
        </p>
        <dl class="meta-grid">
          <div><dt>Overall result</dt><dd><span class="mono">{result.overall_result}</span></dd></div>
          <div><dt>Result status</dt><dd><span class="mono">{result.result_status}</span></dd></div>
          <div><dt>Result scope</dt><dd><span class="mono">{result.result_scope}</span></dd></div>
          <div><dt>Next step</dt><dd><span class="mono">{result.next_required_step}</span></dd></div>
          <div><dt>Manual pass</dt><dd>{resultItemCounts.manual_pass}</dd></div>
          <div><dt>Needs follow-up</dt><dd>{resultItemCounts.needs_follow_up}</dd></div>
          <div><dt>Manual fail</dt><dd>{resultItemCounts.manual_fail}</dd></div>
          <div><dt>Final verification completed</dt><dd>No</dd></div>
          <div><dt>verified_on_source</dt><dd>false</dd></div>
          <div><dt>Publication allowed</dt><dd>false</dd></div>
        </dl>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Item</th>
                <th>Result</th>
                <th>Checked</th>
                <th>Note</th>
              </tr>
            </thead>
            <tbody>
              {
                result.item_results.map((item) => (
                  <tr>
                    <td><span class="mono">{item.item_id}</span></td>
                    <td>
                      <span class={`badge badge--status-${item.result}`}>{item.result}</span>
                    </td>
                    <td>
                      <span class="mono">{item.checked_by_role}</span>
                      <br />
                      <small>{item.checked_at}</small>
                    </td>
                    <td>{item.note ?? "—"}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
        <h3>Remaining blockers</h3>
        <ul>
          {result.blockers_remaining.map((b) => <li>{b}</li>)}
        </ul>
      </section>
    )
  }

  <section>
    <h2>Blockers</h2>
    <ul>
      {checklist.blockers.map((b) => <li>{b}</li>)}
    </ul>
    {
      readinessGate && readinessGate.blockers.length > 0 && (
        <>
          <h3>Readiness gate blockers ({readinessGate.readiness_id})</h3>
          <ul>
            {readinessGate.blockers.map((b) => <li>{b}</li>)}
          </ul>
        </>
      )
    }
  </section>

  <section>
    <h2>Safety and gates</h2>
    <dl class="meta-grid">
      <div><dt>verified_on_source</dt><dd>false</dd></div>
      <div><dt>client_use_allowed</dt><dd>false</dd></div>
      <div><dt>client_evidence_allowed</dt><dd>false</dd></div>
      <div><dt>final_evidence_allowed</dt><dd>false</dd></div>
      <div><dt>legal_change_claimed</dt><dd>false</dd></div>
      <div><dt>publication_allowed</dt><dd>false</dd></div>
      <div><dt>public_export_allowed</dt><dd>false</dd></div>
      <div><dt>source_verification_completed</dt><dd>false</dd></div>
      <div><dt>final_source_verification_completed</dt><dd>false</dd></div>
      <div><dt>metadata_only</dt><dd>true</dd></div>
      <div><dt>stores_full_text</dt><dd>false</dd></div>
      <div><dt>requires_final_legal_approval</dt><dd>true</dd></div>
    </dl>
  </section>

  <section>
    <h2>Registry</h2>
    <p>Registered checklists: {allChecklists.length} (pilot).</p>
    <p>Recorded results: {allResults.length} (pilot — {RESULT_ID}).</p>
  </section>

  <section>
    <h2>Final legal review</h2>
    <div class="banner banner--review" role="note">
      <strong>Legal reviewer decision recorded.</strong> Decision:{" "}
      <code>request_changes</code> (<code>T063-001</code>). Packet <code>T062-001</code>. Not approved.
      Not published. Publication blocked.
    </div>
    <p><a href="/legal-review/">Open Final Legal Review →</a></p>
  </section>

  <section>
    <h2>Related</h2>
    <ul>
      <li><a href="/legal-review/">Final legal review packet</a></li>
      <li><a href="/source-adapters/">Source adapters pipeline</a></li>
      <li><a href="/updates/">Public regulatory updates feed</a></li>
      <li><a href="/tracker/">Automation-first tracker</a></li>
      <li><a href="/verification/">Batch verification history (separate)</a></li>
    </ul>
  </section>
</BaseLayout>
