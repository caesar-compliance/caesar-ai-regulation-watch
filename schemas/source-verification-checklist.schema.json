{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/source-verification-checklist.schema.json",
  "title": "Caesar AI Regulation Watch — Source verification checklist",
  "description": "Internal source verification checklist for draft updates. Not publication. Not verified on source.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_verification_checklists_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_live_collection",
    "no_scheduled_monitoring",
    "checklists"
  ],
  "properties": {
    "source_verification_checklists_id": {
      "type": "string",
      "pattern": "^source-verification-checklists-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_collection": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "checklists": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/checklistRecord" }
    }
  },
  "$defs": {
    "gateState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false }
      }
    },
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "publication_allowed",
        "public_export_allowed",
        "client_use_allowed",
        "final_evidence_allowed",
        "legal_change_claimed",
        "source_verification_completed",
        "metadata_only",
        "stores_full_text"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "publication_allowed": { "type": "boolean", "const": false },
        "public_export_allowed": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false },
        "source_verification_completed": { "type": "boolean", "const": false },
        "metadata_only": { "type": "boolean", "const": true },
        "stores_full_text": { "type": "boolean", "const": false }
      }
    },
    "checklistItemStatus": {
      "type": "string",
      "enum": ["pending", "local_data_present", "blocked"]
    },
    "checklistItemKey": {
      "type": "string",
      "enum": [
        "source_url_accessibility_check",
        "source_identity_match_check",
        "publication_date_match_check",
        "title_match_check",
        "summary_rewrite_check",
        "topic_jurisdiction_confirmation_check",
        "no_full_text_storage_check",
        "public_export_exclusion_check"
      ]
    },
    "checklistItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_key", "status"],
      "properties": {
        "item_key": { "$ref": "#/$defs/checklistItemKey" },
        "status": { "$ref": "#/$defs/checklistItemStatus" },
        "notes": { "type": "string", "maxLength": 500 }
      }
    },
    "checklistRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checklist_id",
        "draft_update_id",
        "draft_update_path",
        "source_adapter_id",
        "source_id",
        "source_url",
        "status",
        "verification_scope",
        "checklist_items",
        "blockers",
        "next_required_step",
        "created_at",
        "updated_at",
        "gates",
        "safety"
      ],
      "properties": {
        "checklist_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "draft_update_id": { "type": "string", "minLength": 1 },
        "draft_update_path": { "type": "string", "pattern": "^data/regulatory-updates/drafts/" },
        "source_readiness_gate_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "source_adapter_id": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string", "minLength": 1 },
        "source_url": { "type": "string", "format": "uri" },
        "status": {
          "type": "string",
          "enum": ["pending_source_verification", "blocked", "complete"]
        },
        "verification_scope": {
          "type": "string",
          "enum": ["internal_source_check_only"]
        },
        "checklist_items": {
          "type": "array",
          "minItems": 8,
          "items": { "$ref": "#/$defs/checklistItem" }
        },
        "blockers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "next_required_step": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" },
        "gates": { "$ref": "#/$defs/gateState" },
        "safety": { "$ref": "#/$defs/safetyFlags" }
      }
    }
  }
}
