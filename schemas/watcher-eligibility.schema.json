{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/watcher-eligibility.schema.json",
  "title": "Caesar AI Regulation Watch — Watcher eligibility batch",
  "description": "Eligibility metadata for confirmed official sources. Not legal advice. No automated monitoring authorization.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "watcher_eligibility_batch_id",
    "generated_at",
    "access_date",
    "legal_safe_note",
    "no_broad_scraping",
    "no_competitor_source",
    "entries"
  ],
  "properties": {
    "watcher_eligibility_batch_id": {
      "type": "string",
      "pattern": "^watcher-eligibility-[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "access_date": { "type": "string", "format": "date" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_broad_scraping": { "type": "boolean", "const": true },
    "no_competitor_source": { "type": "boolean", "const": true },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/eligibilityEntry" }
    }
  },
  "$defs": {
    "watcherEligibilityFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eligible_basic_url_check",
        "eligible_feed_check",
        "eligible_api_check",
        "manual_review_required",
        "blocked_by_waf_or_bot_protection",
        "excluded_not_official",
        "excluded_unstable"
      ],
      "properties": {
        "eligible_basic_url_check": { "type": "boolean" },
        "eligible_feed_check": { "type": "boolean" },
        "eligible_api_check": { "type": "boolean" },
        "manual_review_required": { "type": "boolean" },
        "blocked_by_waf_or_bot_protection": { "type": "boolean" },
        "excluded_not_official": { "type": "boolean" },
        "excluded_unstable": { "type": "boolean" }
      }
    },
    "eligibilityEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "jurisdiction_id",
        "official_url",
        "source_category",
        "source_discovery_status",
        "watcher_eligibility",
        "eligibility_reason",
        "monitoring_method",
        "allowed_to_fetch",
        "fetch_limits",
        "no_broad_scraping",
        "no_competitor_source",
        "client_use_allowed",
        "final_evidence_allowed",
        "created_from",
        "access_date",
        "limitations"
      ],
      "properties": {
        "source_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "jurisdiction_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "official_url": { "type": "string", "format": "uri" },
        "source_category": {
          "type": "string",
          "enum": [
            "law",
            "guidance",
            "regulator",
            "policy_tracker",
            "implementation",
            "other"
          ]
        },
        "source_discovery_status": {
          "type": "string",
          "enum": [
            "official_source_confirmed",
            "pending_official_review",
            "official_source_unclear",
            "rejected_not_official"
          ]
        },
        "watcher_eligibility": { "$ref": "#/$defs/watcherEligibilityFlags" },
        "eligibility_reason": { "type": "string", "minLength": 1 },
        "monitoring_method": {
          "type": "string",
          "enum": [
            "url_status_check",
            "feed_check",
            "api_check",
            "manual_only",
            "none"
          ]
        },
        "allowed_to_fetch": { "type": "boolean" },
        "fetch_limits": { "type": "string", "minLength": 1 },
        "no_broad_scraping": { "type": "boolean", "const": true },
        "no_competitor_source": { "type": "boolean", "const": true },
        "client_use_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "created_from": { "type": "string", "minLength": 1 },
        "access_date": { "type": "string", "format": "date" },
        "limitations": { "type": "string", "minLength": 1 }
      }
    }
  }
}
