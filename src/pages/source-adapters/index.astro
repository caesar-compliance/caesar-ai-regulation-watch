---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getManualSourceIntakeRunEntries,
  getNetworkDryRunApprovalEntries,
  getSourceAdapterAllowlistEntries,
  getSource,
} from "../../lib/data";
import { humanizeId } from "../../lib/format";
import { PROJECT_VERSION_LABEL } from "../../lib/project-version";

const adapters = getSourceAdapterAllowlistEntries();
const intakeRuns = getManualSourceIntakeRunEntries();
const networkApprovals = getNetworkDryRunApprovalEntries();
const disabledCount = adapters.filter((a) => a.status === "disabled").length;
const draftCount = adapters.filter((a) => a.status === "draft").length;
---

<BaseLayout title="Source adapters" currentPath="/source-adapters/">
  <h1>Source adapter allowlist</h1>
  <p class="lead">
    T052 manual-gated registry for future RSS/API metadata adapters ({PROJECT_VERSION_LABEL}).
    Read-only planning surface — not live collection, not scheduled monitoring, not legal advice.
  </p>

  <div class="banner banner--review" role="note">
    <strong>Draft / disabled — metadata-only.</strong> No “run now” controls. No broad crawl. No full legal
    text storage. <code>verified_on_source</code>, <code>client_use_allowed</code>,{" "}
    <code>final_evidence_allowed</code>, and <code>legal_change_claimed</code> remain closed. Future network
    runs require separate Control Tower approval per adapter.
  </div>

  <section>
    <h2>Summary</h2>
    <dl class="meta-grid">
      <div><dt>Registered adapters</dt><dd>{adapters.length}</dd></div>
      <div><dt>Disabled</dt><dd>{disabledCount}</dd></div>
      <div><dt>Draft</dt><dd>{draftCount}</dd></div>
      <div><dt>JSON export</dt><dd><a href="/data/source-adapter-allowlist.json">source-adapter-allowlist.json</a></dd></div>
    </dl>
    <p>
      <small>
        See <code>docs/SOURCE_ADAPTER_ALLOWLIST.md</code>, <code>docs/MANUAL_SOURCE_INTAKE_RUNNER.md</code>,{" "}
        <code>docs/NETWORK_DRY_RUN_APPROVAL_MODEL.md</code>, and <code>docs/RSS_API_ADAPTER_SAFETY_MODEL.md</code>.
        Fixture parser:{" "}
        <code>npm run build:source-adapter-fixtures</code> (local only). Manual intake:{" "}
        <code>npm run run:manual-source-intake</code> (CLI only; no run button on this page).
      </small>
    </p>
  </section>

  <section>
    <h2>Adapter candidates</h2>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Adapter</th>
            <th>Source</th>
            <th>Type</th>
            <th>Status</th>
            <th>Collection</th>
            <th>Jurisdictions</th>
            <th>Safety</th>
          </tr>
        </thead>
        <tbody>
          {
            adapters.map((a) => {
              const source = getSource(a.source_id);
              return (
                <tr>
                  <td>
                    <span class="mono">{a.adapter_id}</span>
                    <br />
                    <small>{humanizeId(a.adapter_kind)}</small>
                  </td>
                  <td>
                    {source ? (
                      <a href={`/sources/${a.source_id}/`}>{a.source_name}</a>
                    ) : (
                      a.source_name
                    )}
                    <br />
                    <small class="mono">{a.source_id}</small>
                  </td>
                  <td>{humanizeId(a.source_type)}</td>
                  <td>
                    <span class={`badge badge--status-${a.status}`}>{a.status}</span>
                  </td>
                  <td>
                    <span class="mono">{a.collection_mode}</span>
                    {a.schedule_enabled ? (
                      <span class="badge badge--warn">schedule</span>
                    ) : (
                      <span class="badge">no schedule</span>
                    )}
                  </td>
                  <td>{a.jurisdiction_ids.join(", ")}</td>
                  <td>
                    <ul class="inline-flags">
                      <li>metadata only</li>
                      {a.paywall_login_required ? <li class="warn">paywall</li> : null}
                      {a.captcha_or_waf_risk ? <li class="warn">WAF risk</li> : null}
                      {a.broad_crawl_allowed ? <li class="warn">broad crawl</li> : <li>no broad crawl</li>}
                    </ul>
                  </td>
                </tr>
              );
            })
          }
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Manual intake runs</h2>
    <p>
      T053 fixture-first manual intake registry — read-only. No live collection controls on this page.
    </p>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Run</th>
            <th>Adapter</th>
            <th>Mode</th>
            <th>Status</th>
            <th>Network</th>
            <th>Schedule</th>
            <th>Output path</th>
          </tr>
        </thead>
        <tbody>
          {
            intakeRuns.map((r) => (
              <tr>
                <td><span class="mono">{r.run_id}</span></td>
                <td>
                  <span class="mono">{r.adapter_id}</span>
                  <br />
                  <small class="mono">{r.source_id}</small>
                </td>
                <td><span class="mono">{r.mode}</span></td>
                <td>
                  <span class={`badge badge--status-${r.status}`}>{r.status}</span>
                </td>
                <td>{r.network_allowed ? "allowed" : "false"}</td>
                <td>{r.schedule_enabled ? "enabled" : "false"}</td>
                <td><span class="mono">{r.output_path}</span></td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Network dry-run approval packets</h2>
    <p>
      T054 planning-only registry for a future single-source network dry-run — read-only. No run buttons. No
      endpoint preview. Control Tower approval required before any T055 execution.
    </p>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Approval</th>
            <th>Adapter</th>
            <th>Status</th>
            <th>Mode</th>
            <th>Network</th>
            <th>Schedule</th>
            <th>Limits</th>
            <th>Paths</th>
            <th>CT approval</th>
          </tr>
        </thead>
        <tbody>
          {
            networkApprovals.map((a) => (
              <tr>
                <td>
                  <span class="mono">{a.approval_id}</span>
                  <br />
                  <small class="mono">run {a.run_id}</small>
                </td>
                <td><span class="mono">{a.adapter_id}</span></td>
                <td>
                  <span class={`badge badge--status-${a.status}`}>{a.status}</span>
                </td>
                <td><span class="mono">{a.mode}</span></td>
                <td>{a.network_execution_allowed ? "allowed" : "false"}</td>
                <td>{a.schedule_enabled ? "enabled" : "false"}</td>
                <td>
                  max {a.max_items} items / {a.max_bytes} bytes / {a.timeout_seconds}s
                </td>
                <td>
                  <span class="mono">{a.output_path}</span>
                  <br />
                  <span class="mono">{a.dry_run_plan_path}</span>
                </td>
                <td>{a.control_tower_approval_required ? "required" : "false"}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Related</h2>
    <ul>
      <li><a href="/sources/">Official sources registry</a></li>
      <li><a href="/monitoring/">Monitoring (separate pilot)</a></li>
      <li><a href="/watchers/">Watchers (offline fixtures)</a></li>
      <li><a href="/exports/">Export samples</a></li>
    </ul>
  </section>
</BaseLayout>
