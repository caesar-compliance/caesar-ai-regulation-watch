---
import type { RegulationRecord } from "../lib/data";
import StatusBadge from "./StatusBadge.astro";
import ReviewStatusBadge from "./ReviewStatusBadge.astro";
import { truncate } from "../lib/format";

interface Props {
  record: RegulationRecord;
}

const { record } = Astro.props;
---

<li class="card">
  <div class="card__meta">
    <span class="badge badge--type">{record.record_type}</span>
    <StatusBadge status={record.status} />
    <ReviewStatusBadge status={record.review_status} />
  </div>
  <h3><a href={`/records/${record.record_id}/`}>{record.title}</a></h3>
  <p class="card__excerpt">{truncate(record.summary_for_review, 140)}</p>
</li>
