{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/monitoring-run.schema.json",
  "title": "Caesar AI Regulation Watch — Monitoring cycle run",
  "description": "Report from a monitoring cycle (manual, scheduled, or CI). Not a legal conclusion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "monitoring_run_id",
    "run_date",
    "mode",
    "watchers_configured",
    "watchers_checked",
    "watcher_success_count",
    "watcher_soft_error_count",
    "detected_changes_created",
    "real_detected_changes",
    "simulated_detected_changes",
    "validation_status",
    "build_status",
    "review_queue_count",
    "legal_safe_note"
  ],
  "properties": {
    "monitoring_run_id": {
      "type": "string",
      "pattern": "^monitoring-cycle-[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "run_date": {
      "type": "string",
      "format": "date"
    },
    "mode": {
      "type": "string",
      "enum": ["dry_run", "write", "report_only"]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "watchers_configured": {
      "type": "integer",
      "minimum": 0
    },
    "watchers_checked": {
      "type": "integer",
      "minimum": 0
    },
    "watcher_success_count": {
      "type": "integer",
      "minimum": 0
    },
    "watcher_soft_error_count": {
      "type": "integer",
      "minimum": 0
    },
    "watcher_run_id": {
      "type": ["string", "null"],
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "detected_changes_created": {
      "type": "integer",
      "minimum": 0
    },
    "real_detected_changes": {
      "type": "integer",
      "minimum": 0
    },
    "simulated_detected_changes": {
      "type": "integer",
      "minimum": 0
    },
    "validation_status": {
      "type": "string",
      "enum": ["passed", "failed", "skipped", "not_run"]
    },
    "build_status": {
      "type": "string",
      "enum": ["passed", "failed", "skipped", "not_run"]
    },
    "exports_status": {
      "type": "string",
      "enum": ["passed", "failed", "skipped", "not_run"]
    },
    "watchers_status": {
      "type": "string",
      "enum": ["passed", "failed", "skipped", "not_run"]
    },
    "overall_status": {
      "type": "string",
      "enum": ["passed", "failed", "partial", "report_only"]
    },
    "review_queue_count": {
      "type": "integer",
      "minimum": 0
    },
    "errors_by_category": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "phase_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "error_message": {
      "type": ["string", "null"]
    },
    "legal_safe_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
