---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReviewStatusBadge from "../../components/ReviewStatusBadge.astro";
import DevelopersPanel from "../../components/DevelopersPanel.astro";
import { getExportSamples, getJurisdiction, getChange, getRecord } from "../../lib/data";
import { truncate } from "../../lib/format";

const exports = getExportSamples();
---

<BaseLayout title="Export samples" currentPath="/exports/">
  <h1>Regulation-change export samples</h1>
  <p class="lead">
    Illustrative export records for the Caesar AI Evidence contract. <strong>Not client evidence</strong> —
    no records were created in caesar-ai-evidence or Governance OS.
  </p>

  <div class="banner banner--sample" role="alert">
    <strong>Sample-only — not client evidence.</strong> Draft <code>regulation_watch.control.*</code> and{" "}
    <code>regulation_watch.evidence.*</code> refs are pending alignment with caesar-ai-evidence. Download{" "}
    <a href="/data/export-samples.json">export-samples.json</a> (marked <code>sample_only: true</code>).
    T048 tracker exports: <a href="/data/country-status.json">country-status.json</a>,{" "}
    <a href="/data/regulatory-updates.json">regulatory-updates.json</a>,{" "}
    <a href="/data/automation-first-metrics.json">automation-first-metrics.json</a>.
    Human review required before any client use.
  </div>

  <ul class="card-list">
    {
      exports.map((exp) => {
        const jurisdiction = getJurisdiction(exp.jurisdiction_id);
        const change = getChange(exp.source_change_id);
        const record = getRecord(exp.related_record_id);
        return (
          <li class="card card--export">
            <div class="card__meta">
              <span class="badge badge--type">{exp.export_type}</span>
              <span class="badge badge--sample-only">Sample only</span>
              <ReviewStatusBadge status={exp.review_status} />
            </div>
            <h3 class="mono">{exp.export_record_id}</h3>
            <p class="card__excerpt">{truncate(exp.summary_for_review, 160)}</p>
            <dl class="meta-grid meta-grid--compact">
              <div>
                <dt>Source change</dt>
                <dd>
                  <a href={`/changes/${exp.source_change_id}/`}>{exp.source_change_id}</a>
                  {change?.requires_human_review ? " · Human review required" : ""}
                </dd>
              </div>
              <div>
                <dt>Jurisdiction</dt>
                <dd>
                  {jurisdiction ? (
                    <a href={`/jurisdictions/${jurisdiction.jurisdiction_id}/`}>{jurisdiction.name}</a>
                  ) : (
                    exp.jurisdiction_id
                  )}
                </dd>
              </div>
              <div>
                <dt>Related record</dt>
                <dd>
                  <a href={`/records/${exp.related_record_id}/`}>
                    {record?.title ?? exp.related_record_id}
                  </a>
                </dd>
              </div>
              <div>
                <dt>Created from</dt>
                <dd>{exp.created_from.replace(/_/g, " ")}</dd>
              </div>
            </dl>
            <p class="card__refs">
              <strong>May affect controls:</strong>{" "}
              {exp.may_affect_controls.map((c) => c.control_ref).join(", ")}
            </p>
            <p class="card__refs">
              <strong>May affect evidence:</strong>{" "}
              {exp.may_affect_evidence.map((e) => e.evidence_ref).join(", ")}
            </p>
            <p class="card__excerpt card__excerpt--note">
              <small>{exp.legal_safe_note}</small>
            </p>
          </li>
        );
      })
    }
  </ul>

  <p>
    Full contract: repository <code>docs/EVIDENCE_EXPORT_CONTRACT.md</code> and{" "}
    <code>exports/samples/regulation-change-export.sample.yml</code>.
  </p>

  <DevelopersPanel />
</BaseLayout>
