{
  "name": "caesar-ai-regulation-watch",
  "type": "module",
  "version": "0.8.0",
  "private": true,
  "description": "Read-only static site for Caesar AI Regulation Watch pilot data",
  "scripts": {
    "validate:data": "node scripts/validate-data.mjs",
    "generate:exports": "node scripts/generate-static-exports.mjs",
    "dev": "astro dev",
    "build:site": "astro build",
    "build:search": "pagefind --site dist",
    "check:urls": "node scripts/check-official-urls.mjs",
    "watch:official": "node scripts/run-official-source-watchers.mjs",
    "watch:simulate-change": "node scripts/simulate-watcher-change.mjs",
    "watch:simulate-feed-change": "node scripts/simulate-feed-change.mjs",
    "watch:simulate-api-change": "node scripts/simulate-api-change.mjs",
    "monitoring:report": "node scripts/run-monitoring-cycle.mjs --mode=report_only",
    "monitoring:cycle": "node scripts/run-monitoring-cycle.mjs --mode=write",
    "monitoring:cycle:dry-run": "node scripts/run-monitoring-cycle.mjs --mode=dry-run",
    "build": "npm run validate:data && npm run generate:exports && npm run build:site && npm run build:search",
    "preview": "astro preview"
  },
  "dependencies": {
    "astro": "^5.7.10",
    "fast-xml-parser": "^4.5.6",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "pagefind": "^1.3.0"
  }
}
