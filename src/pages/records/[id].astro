---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReviewBanner from "../../components/ReviewBanner.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import ReviewStatusBadge from "../../components/ReviewStatusBadge.astro";
import {
  getRecords,
  getRecord,
  getSource,
  getJurisdiction,
  changesForRecord,
  timelinesForRecord,
  latestVerificationForItem,
  latestUrlCheckForItem,
} from "../../lib/data";
import {
  formatDate,
  humanizeId,
  recordTypeLabel,
  verificationCheckLabel,
  urlCheckResultLabel,
  contentReviewStatusLabel,
} from "../../lib/format";

export function getStaticPaths() {
  return getRecords().map((r) => ({
    params: { id: r.record_id },
  }));
}

const { id } = Astro.params;
const record = getRecord(id!);

if (!record) {
  return Astro.redirect("/records/");
}

const source = getSource(record.source_id);
const jurisdiction = getJurisdiction(record.jurisdiction_id);
const relatedChanges = changesForRecord(record.record_id);
const relatedTimelines = timelinesForRecord(record.record_id);
const verification = latestVerificationForItem(record.record_id);
const urlCheck =
  latestUrlCheckForItem("law", record.record_id) ??
  latestUrlCheckForItem("guidance", record.record_id);
const keyDates = "key_dates" in record ? record.key_dates : [];
---

<BaseLayout title={record.title} currentPath="/records/">
  <p><a href="/records/">← Records</a></p>
  <h1>{record.title}</h1>
  <div class="card__meta" style="margin-bottom: 1rem;">
    <span class="badge badge--type">{recordTypeLabel(record.record_type)}</span>
    {record.verified_on_source === false && (
      <span class="badge badge--warn">Not verified on source</span>
    )}
    <StatusBadge status={record.status} />
    <ReviewStatusBadge status={record.review_status} />
  </div>

  <ReviewBanner
    reviewStatus={record.review_status}
    recordOrigin={record.record_origin}
    sample={record.record_origin === "manual_sample"}
  />

  {
    record.review_status === "pending_review" && (
      <div class="banner banner--review" role="note">
        <strong>Pending human review.</strong> Do not use for client deliverables until verified on the
        official source.
      </div>
    )
  }

  {
    urlCheck && (
      <section>
        <h2>Technical URL status</h2>
        <dl class="meta-grid">
          <div><dt>Check result</dt><dd>{urlCheckResultLabel(urlCheck.check_result)}</dd></div>
          <div><dt>Checked date</dt><dd>{formatDate(urlCheck.checked_date)}</dd></div>
          <div><dt>HTTP status</dt><dd>{urlCheck.http_status ?? "—"}</dd></div>
          <div>
            <dt>Content review</dt>
            <dd>{contentReviewStatusLabel(urlCheck.content_review_status)}</dd>
          </div>
          <div>
            <dt>Client use allowed</dt>
            <dd>{urlCheck.client_use_allowed ? "Yes" : "No"}</dd>
          </div>
        </dl>
        {urlCheck.technical_note && <p class="card__excerpt">{urlCheck.technical_note}</p>}
        {(urlCheck.check_result === "reachable" ||
          urlCheck.check_result === "reachable_redirected") && (
          <p class="banner banner--review" role="note">
            Reachable URL does not mean this record is legally reviewed or approved for client use.
          </p>
        )}
      </section>
    )
  }

  {
    verification && (
      <section>
        <h2>Human source verification</h2>
        <dl class="meta-grid">
          <div><dt>Check result</dt><dd>{verificationCheckLabel(verification.check_result)}</dd></div>
          <div><dt>Verified date</dt><dd>{formatDate(verification.verified_date)}</dd></div>
          <div>
            <dt>Client use allowed</dt>
            <dd>{verification.client_use_allowed ? "Yes" : "No"}</dd>
          </div>
        </dl>
        {verification.notes && <p class="card__excerpt">{verification.notes}</p>}
        <p><a href="/verification/">All verifications →</a></p>
      </section>
    )
  }

  <p>
    <a class="btn-primary" href={record.official_url} target="_blank" rel="noopener noreferrer">
      View official source ↗
    </a>
  </p>

  <dl class="meta-grid">
    <div><dt>Record ID</dt><dd class="mono">{record.record_id}</dd></div>
    <div>
      <dt>Jurisdiction</dt>
      <dd>
        {jurisdiction ? (
          <a href={`/jurisdictions/${jurisdiction.jurisdiction_id}/`}>{jurisdiction.name}</a>
        ) : (
          record.jurisdiction_id
        )}
      </dd>
    </div>
    <div>
      <dt>Registry source</dt>
      <dd>
        {source ? (
          <a href={`/sources/${source.source_id}/`}>{source.title}</a>
        ) : (
          record.source_id
        )}
      </dd>
    </div>
    <div><dt>Origin</dt><dd>{record.record_origin.replace(/_/g, " ")}</dd></div>
  </dl>

  <h2>Summary for review</h2>
  <div class="prose"><p>{record.summary_for_review}</p></div>

  {
    keyDates.length > 0 && (
      <>
        <h2>Key dates</h2>
        <p class="card__excerpt"><small>Verify all dates on the official source before client use.</small></p>
        <table class="data-table">
          <thead>
            <tr>
              <th>Label</th>
              <th>Date</th>
              <th>Verified on source</th>
            </tr>
          </thead>
          <tbody>
            {keyDates.map((d) => (
              <tr>
                <td>{d.label}</td>
                <td>{formatDate(d.date)}</td>
                <td>{d.verified_on_source ? "Yes" : "No — verify"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )
  }

  <h2>Affected topics</h2>
  <ul>
    {record.affected_topics.map((t) => (
      <li>{humanizeId(t)}</li>
    ))}
  </ul>

  {
    relatedTimelines.length > 0 && (
      <>
        <h2>Related timelines</h2>
        <ul>
          {relatedTimelines.map((t) => (
            <li>
              <a href={`/timelines/${t.timeline_id}/`}>{t.title}</a>
            </li>
          ))}
        </ul>
      </>
    )
  }

  {
    relatedChanges.length > 0 && (
      <>
        <h2>Related sample changes</h2>
        <ul>
          {relatedChanges.map((c) => (
            <li>
              <a href={`/changes/${c.change_id}/`}>{c.change_id}</a> — {formatDate(c.detected_date)}
            </li>
          ))}
        </ul>
      </>
    )
  }

  <h2>Legal-safe note</h2>
  <div class="prose"><p>{record.legal_safe_note}</p></div>
</BaseLayout>
