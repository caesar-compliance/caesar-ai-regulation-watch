{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/manual-source-verification-intake.schema.json",
  "title": "Caesar AI Regulation Watch — Manual source verification intake batch",
  "description": "Controlled human browser observation intake for blocked official sources. Does not set verified_on_source. Not legal advice. Not client evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manual_source_verification_intake_batch_id",
    "intake_date",
    "verifier_type",
    "legal_safe_note",
    "intakes"
  ],
  "properties": {
    "manual_source_verification_intake_batch_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "intake_date": {
      "type": "string",
      "format": "date"
    },
    "verifier_type": {
      "type": "string",
      "enum": ["human_reviewer", "automated_check_pending", "curator_batch"]
    },
    "legal_safe_note": {
      "type": "string",
      "minLength": 1
    },
    "intakes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "intake_id",
          "intake_status",
          "related_source_id",
          "official_url",
          "verification_target",
          "access_method",
          "reviewer_role",
          "access_date",
          "browser_observation",
          "source_identity_confirmed",
          "full_instrument_identity_confirmed",
          "content_not_copied",
          "no_legal_advice",
          "no_full_text_storage",
          "client_use_allowed",
          "final_evidence_allowed",
          "verified_on_source_requested",
          "verified_on_source_approved",
          "limitations",
          "next_action",
          "legal_safe_note"
        ],
        "properties": {
          "intake_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "intake_status": {
            "type": "string",
            "enum": [
              "pending_human_browser_input",
              "observation_recorded",
              "identity_confirmed_pending_control_tower",
              "submitted_for_control_tower",
              "closed_no_verification"
            ]
          },
          "related_source_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "related_record_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "related_candidate_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "related_verification_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "official_url": {
            "type": "string",
            "format": "uri"
          },
          "verification_target": {
            "type": "string",
            "enum": [
              "source_identity",
              "legal_instrument_identity",
              "guidance_page_identity",
              "metadata_confirmation"
            ]
          },
          "access_method": {
            "type": "string",
            "enum": [
              "human_browser",
              "human_browser_with_js",
              "official_pdf",
              "official_alternative"
            ]
          },
          "reviewer_role": {
            "type": "string",
            "enum": ["operator", "control_tower", "qualified_reviewer", "counsel"]
          },
          "access_date": {
            "type": "string",
            "format": "date"
          },
          "browser_observation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["page_loaded"],
            "properties": {
              "page_loaded": {
                "type": ["boolean", "null"]
              },
              "visible_title": {
                "type": ["string", "null"],
                "maxLength": 300
              },
              "visible_publisher": {
                "type": ["string", "null"],
                "maxLength": 200
              },
              "visible_date": {
                "type": ["string", "null"],
                "maxLength": 80
              },
              "celex_or_official_identifier": {
                "type": ["string", "null"],
                "maxLength": 80
              },
              "final_url": {
                "type": ["string", "null"],
                "format": "uri"
              }
            }
          },
          "source_identity_confirmed": {
            "type": "boolean"
          },
          "full_instrument_identity_confirmed": {
            "type": "boolean"
          },
          "content_not_copied": {
            "type": "boolean",
            "const": true
          },
          "no_legal_advice": {
            "type": "boolean",
            "const": true
          },
          "no_full_text_storage": {
            "type": "boolean",
            "const": true
          },
          "client_use_allowed": {
            "type": "boolean",
            "const": false
          },
          "final_evidence_allowed": {
            "type": "boolean",
            "const": false
          },
          "verified_on_source_requested": {
            "type": "boolean",
            "const": false
          },
          "verified_on_source_approved": {
            "type": "boolean",
            "const": false
          },
          "limitations": {
            "type": "string",
            "minLength": 1,
            "maxLength": 800
          },
          "reviewer_note": {
            "type": "string",
            "maxLength": 500
          },
          "next_action": {
            "type": "string",
            "enum": [
              "await_qualified_human_browser",
              "record_browser_observation",
              "submit_to_control_tower",
              "no_verified_on_source_in_this_release",
              "counsel_review_if_high_risk"
            ]
          },
          "legal_safe_note": {
            "type": "string",
            "minLength": 1,
            "maxLength": 800
          }
        }
      }
    }
  }
}
