{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/evidence-export-record.schema.json",
  "title": "Caesar AI Regulation Watch — Evidence export record (contract)",
  "description": "Future regulation-change export shape for Caesar AI Evidence / Governance OS. Sample only; no export logic.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "export_record_id",
    "source_change_id",
    "jurisdiction_id",
    "related_record_id",
    "export_type",
    "summary_for_review",
    "may_affect_controls",
    "may_affect_evidence",
    "suggested_review_actions",
    "human_review_required",
    "legal_safe_note",
    "created_from",
    "review_status"
  ],
  "properties": {
    "export_record_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "source_change_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "jurisdiction_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "related_record_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "export_type": {
      "type": "string",
      "enum": ["regulation_change"]
    },
    "summary_for_review": {
      "type": "string",
      "minLength": 1
    },
    "may_affect_controls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["control_ref", "rationale", "reference_alignment"],
        "properties": {
          "control_ref": {
            "type": "string",
            "pattern": "^regulation_watch\\.control\\.[a-z][a-z0-9_]*$"
          },
          "rationale": { "type": "string", "minLength": 1 },
          "reference_alignment": {
            "type": "string",
            "enum": ["draft_pending_caesar_ai_evidence", "aligned", "deprecated"]
          }
        }
      }
    },
    "may_affect_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_ref", "rationale", "reference_alignment"],
        "properties": {
          "evidence_ref": {
            "type": "string",
            "pattern": "^regulation_watch\\.evidence\\.[a-z][a-z0-9_]*$"
          },
          "rationale": { "type": "string", "minLength": 1 },
          "reference_alignment": {
            "type": "string",
            "enum": ["draft_pending_caesar_ai_evidence", "aligned", "deprecated"]
          }
        }
      }
    },
    "suggested_review_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action_type", "rationale"],
        "properties": {
          "action_type": {
            "type": "string",
            "enum": [
              "review_control",
              "review_evidence",
              "verify_on_official_source",
              "update_internal_register",
              "consult_qualified_advisor"
            ]
          },
          "target_ref": { "type": "string" },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "human_review_required": { "type": "boolean" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "created_from": {
      "type": "string",
      "enum": [
        "manual_sample",
        "regulation_watch_mapping",
        "future_watcher_pipeline"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "draft",
        "pending_review",
        "reviewed",
        "needs_update",
        "rejected_for_client_use",
        "archived"
      ]
    }
  }
}
