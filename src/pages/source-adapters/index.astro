---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getManualSourceIntakeRunEntries,
  getNetworkDryRunApprovalEntries,
  getSingleNetworkDryRunExecutionEntries,
  getManualReviewPromotionEntries,
  getManualReviewDecisionEntries,
  getDraftRegulatoryUpdateRevisionEntries,
  getInternalDraftReadinessGateEntries,
  getSourceVerificationChecklistEntries,
  getSourceVerificationResultEntries,
  getSourceAdapterAllowlistEntries,
  getSource,
} from "../../lib/data";
import { humanizeId } from "../../lib/format";
import { PROJECT_VERSION_LABEL } from "../../lib/project-version";

const adapters = getSourceAdapterAllowlistEntries();
const intakeRuns = getManualSourceIntakeRunEntries();
const networkApprovals = getNetworkDryRunApprovalEntries();
const networkExecutions = getSingleNetworkDryRunExecutionEntries();
const manualReviewPromotions = getManualReviewPromotionEntries();
const manualReviewDecisions = getManualReviewDecisionEntries();
const draftRevisions = getDraftRegulatoryUpdateRevisionEntries();
const readinessGates = getInternalDraftReadinessGateEntries();
const verificationChecklists = getSourceVerificationChecklistEntries();
const verificationResults = getSourceVerificationResultEntries();
const pilotChecklist = verificationChecklists.find((c) => c.checklist_id === "T060-001");
const pilotResult = verificationResults.find((r) => r.result_id === "T061-001");
const disabledCount = adapters.filter((a) => a.status === "disabled").length;
const draftCount = adapters.filter((a) => a.status === "draft").length;
---

<BaseLayout title="Source adapters" currentPath="/source-adapters/">
  <h1>Source adapter allowlist</h1>
  <p class="lead">
    T052 manual-gated registry for future RSS/API metadata adapters ({PROJECT_VERSION_LABEL}).
    Read-only planning surface — not live collection, not scheduled monitoring, not legal advice.
  </p>

  <div class="banner banner--review" role="note">
    <strong>Draft / disabled — metadata-only.</strong> No “run now” controls. No broad crawl. No full legal
    text storage. <code>verified_on_source</code>, <code>client_use_allowed</code>,{" "}
    <code>final_evidence_allowed</code>, and <code>legal_change_claimed</code> remain closed. Future network
    runs require separate Control Tower approval per adapter.
  </div>

  <section>
    <h2>Summary</h2>
    <dl class="meta-grid">
      <div><dt>Registered adapters</dt><dd>{adapters.length}</dd></div>
      <div><dt>Disabled</dt><dd>{disabledCount}</dd></div>
      <div><dt>Draft</dt><dd>{draftCount}</dd></div>
      <div><dt>JSON export</dt><dd><a href="/data/source-adapter-allowlist.json">source-adapter-allowlist.json</a></dd></div>
    </dl>
    <p>
      <small>
        See <code>docs/SOURCE_ADAPTER_ALLOWLIST.md</code>, <code>docs/MANUAL_SOURCE_INTAKE_RUNNER.md</code>,{" "}
        <code>docs/NETWORK_DRY_RUN_APPROVAL_MODEL.md</code>, and <code>docs/RSS_API_ADAPTER_SAFETY_MODEL.md</code>.
        Fixture parser:{" "}
        <code>npm run build:source-adapter-fixtures</code> (local only). Manual intake:{" "}
        <code>npm run run:manual-source-intake</code> (CLI only; no run button on this page).
      </small>
    </p>
  </section>

  <section>
    <h2>Adapter candidates</h2>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Adapter</th>
            <th>Source</th>
            <th>Type</th>
            <th>Status</th>
            <th>Collection</th>
            <th>Jurisdictions</th>
            <th>Safety</th>
          </tr>
        </thead>
        <tbody>
          {
            adapters.map((a) => {
              const source = getSource(a.source_id);
              return (
                <tr>
                  <td>
                    <span class="mono">{a.adapter_id}</span>
                    <br />
                    <small>{humanizeId(a.adapter_kind)}</small>
                  </td>
                  <td>
                    {source ? (
                      <a href={`/sources/${a.source_id}/`}>{a.source_name}</a>
                    ) : (
                      a.source_name
                    )}
                    <br />
                    <small class="mono">{a.source_id}</small>
                  </td>
                  <td>{humanizeId(a.source_type)}</td>
                  <td>
                    <span class={`badge badge--status-${a.status}`}>{a.status}</span>
                  </td>
                  <td>
                    <span class="mono">{a.collection_mode}</span>
                    {a.schedule_enabled ? (
                      <span class="badge badge--warn">schedule</span>
                    ) : (
                      <span class="badge">no schedule</span>
                    )}
                  </td>
                  <td>{a.jurisdiction_ids.join(", ")}</td>
                  <td>
                    <ul class="inline-flags">
                      <li>metadata only</li>
                      {a.paywall_login_required ? <li class="warn">paywall</li> : null}
                      {a.captcha_or_waf_risk ? <li class="warn">WAF risk</li> : null}
                      {a.broad_crawl_allowed ? <li class="warn">broad crawl</li> : <li>no broad crawl</li>}
                    </ul>
                  </td>
                </tr>
              );
            })
          }
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Manual intake runs</h2>
    <p>
      T053 fixture-first manual intake registry — read-only. No live collection controls on this page.
    </p>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Run</th>
            <th>Adapter</th>
            <th>Mode</th>
            <th>Status</th>
            <th>Network</th>
            <th>Schedule</th>
            <th>Output path</th>
          </tr>
        </thead>
        <tbody>
          {
            intakeRuns.map((r) => (
              <tr>
                <td><span class="mono">{r.run_id}</span></td>
                <td>
                  <span class="mono">{r.adapter_id}</span>
                  <br />
                  <small class="mono">{r.source_id}</small>
                </td>
                <td><span class="mono">{r.mode}</span></td>
                <td>
                  <span class={`badge badge--status-${r.status}`}>{r.status}</span>
                </td>
                <td>{r.network_allowed ? "allowed" : "false"}</td>
                <td>{r.schedule_enabled ? "enabled" : "false"}</td>
                <td><span class="mono">{r.output_path}</span></td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Network dry-run approval packets</h2>
    <p>
      T054 planning-only registry for a future single-source network dry-run — read-only. No run buttons. No
      endpoint preview. Control Tower approval required before any T055 execution.
    </p>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Approval</th>
            <th>Adapter</th>
            <th>Status</th>
            <th>Mode</th>
            <th>Network</th>
            <th>Schedule</th>
            <th>Limits</th>
            <th>Paths</th>
            <th>CT approval</th>
          </tr>
        </thead>
        <tbody>
          {
            networkApprovals.map((a) => (
              <tr>
                <td>
                  <span class="mono">{a.approval_id}</span>
                  <br />
                  <small class="mono">run {a.run_id}</small>
                </td>
                <td><span class="mono">{a.adapter_id}</span></td>
                <td>
                  <span class={`badge badge--status-${a.status}`}>{a.status}</span>
                </td>
                <td><span class="mono">{a.mode}</span></td>
                <td>{a.network_execution_allowed ? "allowed" : "false"}</td>
                <td>{a.schedule_enabled ? "enabled" : "false"}</td>
                <td>
                  max {a.max_items} items / {a.max_bytes} bytes / {a.timeout_seconds}s
                </td>
                <td>
                  <span class="mono">{a.output_path}</span>
                  <br />
                  <span class="mono">{a.dry_run_plan_path}</span>
                </td>
                <td>{a.control_tower_approval_required ? "required" : "false"}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Single-source dry-run execution controls</h2>
    <p>
      T055 one-off network dry-run execution registry — read-only. Control Tower approval required for each
      live run. No run buttons. No endpoint preview. No generated candidate preview.
    </p>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Execution</th>
            <th>Approval</th>
            <th>Adapter</th>
            <th>Status</th>
            <th>Max requests</th>
            <th>Max items</th>
            <th>Schedule</th>
            <th>Publication</th>
            <th>Paths</th>
            <th>CT approval</th>
          </tr>
        </thead>
        <tbody>
          {
            networkExecutions.map((e) => (
              <tr>
                <td><span class="mono">{e.execution_id}</span></td>
                <td><span class="mono">{e.approval_id}</span></td>
                <td><span class="mono">{e.adapter_id}</span></td>
                <td>
                  <span class={`badge badge--status-${e.status}`}>{e.status}</span>
                </td>
                <td>{e.max_network_requests}</td>
                <td>{e.max_items}</td>
                <td>{e.schedule_enabled ? "enabled" : "false"}</td>
                <td>{e.legal_text_publication_allowed ? "allowed" : "false"}</td>
                <td>
                  <span class="mono">{e.output_path}</span>
                  <br />
                  <span class="mono">{e.report_path}</span>
                </td>
                <td>required / one-off only</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Manual review promotions</h2>
    <p>
      T056 draft promotion registry — read-only. No approve, publish, or source-verification controls.
      Candidate content is not previewed on this page.
    </p>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Promotion</th>
            <th>Source execution</th>
            <th>Adapter</th>
            <th>Status</th>
            <th>Review</th>
            <th>Draft path</th>
            <th>Publication</th>
            <th>Gates</th>
          </tr>
        </thead>
        <tbody>
          {
            manualReviewPromotions.map((p) => (
              <tr>
                <td>
                  <span class="mono">{p.promotion_id}</span>
                  <br />
                  <small class="mono">candidate {p.candidate_id}</small>
                </td>
                <td><span class="mono">{p.source_execution_id}</span></td>
                <td>
                  <span class="mono">{p.source_adapter_id}</span>
                  <br />
                  <small class="mono">{p.source_id}</small>
                </td>
                <td>
                  <span class={`badge badge--status-${p.status}`}>{p.status}</span>
                </td>
                <td>{p.review_required ? "required" : "false"}</td>
                <td><span class="mono">{p.draft_update_path}</span></td>
                <td>{p.safety.publication_allowed ? "allowed" : "false"}</td>
                <td>
                  <span class="mono">verified/client/evidence/legal: false</span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Manual review decisions</h2>
    <p>
      T057 reviewer decision registry — read-only. No approve, publish, or source-verification controls.
      Decisions are metadata-only and internal-draft-only.
    </p>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Decision</th>
            <th>Promotion</th>
            <th>Draft</th>
            <th>Decision</th>
            <th>Scope</th>
            <th>Publication</th>
            <th>Source verification</th>
            <th>Gates</th>
          </tr>
        </thead>
        <tbody>
          {
            manualReviewDecisions.map((d) => (
              <tr>
                <td>
                  <span class="mono">{d.decision_id}</span>
                  <br />
                  <small>{d.decision_status}</small>
                </td>
                <td><span class="mono">{d.promotion_id}</span></td>
                <td>
                  <span class="mono">{d.draft_update_id}</span>
                  <br />
                  <small class="mono">{d.draft_update_path}</small>
                </td>
                <td>
                  <span class={`badge badge--status-${d.decision}`}>{d.decision}</span>
                </td>
                <td><span class="mono">{d.decision_scope}</span></td>
                <td>{d.safety.publication_allowed ? "allowed" : "false"}</td>
                <td>{d.safety.source_verification_completed ? "completed" : "false"}</td>
                <td>
                  <span class="mono">verified/client/evidence/legal: false</span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Draft revision packets</h2>
    <p>
      T058 draft revision registry — read-only. No approve, publish, or source-verification controls.
      Revisions apply metadata-only edits after reviewer request_changes.
    </p>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Revision</th>
            <th>Draft</th>
            <th>Source decision</th>
            <th>Status</th>
            <th>Scope</th>
            <th>Follow-up</th>
            <th>Publication</th>
            <th>Source verification</th>
            <th>Gates</th>
          </tr>
        </thead>
        <tbody>
          {
            draftRevisions.map((r) => (
              <tr>
                <td>
                  <span class="mono">{r.revision_id}</span>
                  <br />
                  <small>{r.revision_status}</small>
                </td>
                <td>
                  <span class="mono">{r.draft_update_id}</span>
                  <br />
                  <small class="mono">{r.draft_update_path}</small>
                </td>
                <td><span class="mono">{r.source_decision_id}</span></td>
                <td>
                  <span class={`badge badge--status-${r.revision_status}`}>{r.revision_status}</span>
                </td>
                <td><span class="mono">{r.revision_scope}</span></td>
                <td>{r.reviewer_followup_required ? "required" : "false"}</td>
                <td>{r.safety.publication_allowed ? "allowed" : "false"}</td>
                <td>{r.safety.source_verification_completed ? "completed" : "false"}</td>
                <td>
                  <span class="mono">verified/client/evidence/legal: false</span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2>Internal draft readiness gates</h2>
    <p>
      T059 readiness registry — read-only. No approve, publish, or source-verification controls.
      Records conservative readiness after draft revision; does not claim source verification.
    </p>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Readiness</th>
            <th>Draft</th>
            <th>Result</th>
            <th>Next step</th>
            <th>Blockers</th>
            <th>Source verification</th>
            <th>Publication</th>
            <th>Gates</th>
          </tr>
        </thead>
        <tbody>
          {
            readinessGates.map((g) => (
              <tr>
                <td>
                  <span class="mono">{g.readiness_id}</span>
                  <br />
                  <small>{g.gate_status}</small>
                </td>
                <td>
                  <span class="mono">{g.draft_update_id}</span>
                  <br />
                  <small class="mono">{g.draft_update_path}</small>
                </td>
                <td>
                  <span class={`badge badge--status-${g.readiness_result}`}>{g.readiness_result}</span>
                </td>
                <td><span class="mono">{g.next_required_step}</span></td>
                <td>{(g.blockers ?? []).length}</td>
                <td>{g.safety.source_verification_completed ? "completed" : "false"}</td>
                <td>{g.safety.publication_allowed ? "allowed" : "false"}</td>
                <td>
                  <span class="mono">verified/client/evidence/legal: false</span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section class="card">
    <h2>Source verification cockpit</h2>
    <p>
      T060 internal draft verification checklist — read-only case view for pipeline blockers and manual
      source URL checks. Not verified. Not published.
    </p>
    <dl class="meta-grid">
      <div>
        <dt>Checklist (T060)</dt>
        <dd>{pilotChecklist ? <span class="mono">{pilotChecklist.checklist_id}</span> : "—"}</dd>
      </div>
      <div>
        <dt>Manual result (T061)</dt>
        <dd>
          {pilotResult ? (
            <>
              <span class="mono">{pilotResult.result_id}</span> — {pilotResult.overall_result}
            </>
          ) : (
            "not recorded"
          )}
        </dd>
      </div>
      <div>
        <dt>Final verification</dt>
        <dd>pending — verified_on_source false</dd>
      </div>
      <div>
        <dt>Next step</dt>
        <dd><span class="mono">{pilotResult?.next_required_step ?? pilotChecklist?.next_required_step ?? "—"}</span></dd>
      </div>
    </dl>
    <p><a href="/source-verification/">Open Source Verification Cockpit →</a></p>
  </section>

  <section>
    <h2>Final legal review (T062 / T063 / T064 / T065)</h2>
    <dl class="meta-grid">
      <div>
        <dt>Legal review packet</dt>
        <dd><span class="mono">T062-001</span> — pending_final_legal_review</dd>
      </div>
      <div>
        <dt>Legal review decision</dt>
        <dd><span class="mono">T063-001</span> — request_changes recorded</dd>
      </div>
      <div>
        <dt>Revision response</dt>
        <dd><span class="mono">T064-001</span> — ready_for_reviewer_recheck</dd>
      </div>
      <div>
        <dt>Final reviewer re-check</dt>
        <dd><span class="mono">T065-001</span> — ready_for_publication_gate_review (internal only)</dd>
      </div>
      <div>
        <dt>Next step</dt>
        <dd><span class="mono">publication_gate_packet</span></dd>
      </div>
      <div>
        <dt>Publication</dt>
        <dd>Blocked — publication gate required; no publication approval</dd>
      </div>
      <div>
        <dt>Approved / published</dt>
        <dd>No — gates closed</dd>
      </div>
    </dl>
    <p><a href="/legal-review/">Open Final Legal Review →</a></p>
  </section>

  <section>
    <h2>Related</h2>
    <ul>
      <li><a href="/legal-review/">Final legal review packet</a></li>
      <li><a href="/source-verification/">Source verification cockpit</a></li>
      <li><a href="/sources/">Official sources registry</a></li>
      <li><a href="/monitoring/">Monitoring (separate pilot)</a></li>
      <li><a href="/watchers/">Watchers (offline fixtures)</a></li>
      <li><a href="/exports/">Export samples</a></li>
    </ul>
  </section>
</BaseLayout>
