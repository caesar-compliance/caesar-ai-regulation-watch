---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getContentReviewBatches,
  getContentReviews,
  getRecords,
  getDetectedChanges,
} from "../../lib/data";
import {
  formatDate,
  contentReviewResultLabel,
  contentReviewStatusLabel,
  sourceSupportLevelLabel,
  humanizeId,
} from "../../lib/format";

const batches = getContentReviewBatches();
const reviews = getContentReviews();
const records = getRecords();
const detectedChanges = getDetectedChanges();

const notChecked = reviews.filter((r) => r.review_result === "not_checked");
const needsUpdate = reviews.filter(
  (r) =>
    r.review_result === "needs_update" ||
    r.content_review_status_after_check === "needs_update",
);
const reviewed = reviews.filter(
  (r) => r.content_review_status_after_check === "reviewed_content_summary",
);
const verifiedOnSource = reviews.filter((r) => r.verified_on_source_after_check);
const clientUseAllowed = reviews.filter((r) => r.client_use_allowed);

function pageHref(cr: (typeof reviews)[0]) {
  if (cr.item_type === "detected_change") {
    return `/detected-changes/${cr.item_id}/`;
  }
  const recordTypes = ["law", "guidance", "policy_framework", "implementation_update"];
  if (recordTypes.includes(cr.item_type)) {
    return `/records/${cr.item_id}/`;
  }
  return `/sources/${cr.source_id}/`;
}
---

<BaseLayout title="Content Review" currentPath="/content-review/">
  <h1>Content review</h1>
  <p class="lead">
    Human review of summaries, dates, statuses, and detected-change relevance against official sources.
    Separate from technical URL checks and source identity review. Not legal advice.
  </p>

  <div class="banner banner--review" role="note">
    <strong>v0.8.2.</strong> Batch: {batches[0]?.content_review_batch_id ?? "—"}. Items in batch:{" "}
    {reviews.length}. Not checked (browser review pending): {notChecked.length}. Client use allowed:{" "}
    {clientUseAllowed.length} (expected 0). See repository docs CONTENT_REVIEW_WORKFLOW.md.
  </div>

  <dl class="meta-grid">
    <div><dt>Batches</dt><dd>{batches.length}</dd></div>
    <div><dt>Total reviews logged</dt><dd>{reviews.length}</dd></div>
    <div><dt>Not checked</dt><dd>{notChecked.length}</dd></div>
    <div><dt>Needs update</dt><dd>{needsUpdate.length}</dd></div>
    <div><dt>Content-reviewed (summary)</dt><dd>{reviewed.length}</dd></div>
    <div><dt>verified_on_source (batch)</dt><dd>{verifiedOnSource.length}</dd></div>
    <div><dt>client_use_allowed</dt><dd>{clientUseAllowed.length}</dd></div>
  </dl>

  <p>
    <a href="/data/content-reviews.json">content-reviews.json</a> ·{" "}
    <a href="/data/verifications.json">verifications.json</a> ·{" "}
    <a href="/review-queue/">Review queue →</a>
  </p>

  <h2>Review batches</h2>
  <ul class="card-list">
    {
      batches.map((b) => (
        <li class="card">
          <strong>{b.content_review_batch_id}</strong>
          <p class="card__excerpt">
            {formatDate(b.review_date)} · {b.content_reviews.length} item(s) · {b.verifier_type}
          </p>
        </li>
      ))
    }
  </ul>

  <h2>All content review entries</h2>
  <table class="data-table">
    <thead>
      <tr>
        <th>Item</th>
        <th>Type</th>
        <th>Result</th>
        <th>Support</th>
        <th>Status after</th>
        <th>On source</th>
        <th>Client use</th>
        <th>Next action</th>
      </tr>
    </thead>
    <tbody>
      {
        reviews.map((cr) => (
          <tr>
            <td>
              <a href={pageHref(cr)}>{cr.item_id}</a>
              <br />
              <a href={`/sources/${cr.source_id}/`} class="muted">
                {cr.source_id}
              </a>
            </td>
            <td>{humanizeId(cr.item_type)}</td>
            <td>{contentReviewResultLabel(cr.review_result)}</td>
            <td>{sourceSupportLevelLabel(cr.source_support_level)}</td>
            <td>{contentReviewStatusLabel(cr.content_review_status_after_check)}</td>
            <td>{cr.verified_on_source_after_check ? "Yes" : "No"}</td>
            <td>{cr.client_use_allowed ? "Yes" : "No"}</td>
            <td>{humanizeId(cr.recommended_next_action)}</td>
          </tr>
        ))
      }
    </tbody>
  </table>

  {
    notChecked.length > 0 && (
      <section>
        <h2>Not checked — browser review required</h2>
        <ul class="card-list">
          {notChecked.map((cr) => (
            <li class="card">
              <a href={pageHref(cr)}>{cr.item_id}</a>
              <p class="card__excerpt">{cr.summary_review_note}</p>
              <p>
                <a href={cr.official_url_checked} target="_blank" rel="noopener noreferrer">
                  Official URL ↗
                </a>
              </p>
              {cr.fields_needing_update.length > 0 && (
                <p>
                  <strong>Fields needing update:</strong>{" "}
                  {cr.fields_needing_update.join(", ")}
                </p>
              )}
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <h2>Registry cross-reference</h2>
  <p class="card__excerpt">
    Records with content_review_status: {records.filter((r) => r.content_review_status).length} of{" "}
    {records.length}. Detected changes with content review fields:{" "}
    {detectedChanges.filter((d) => d.content_review_status).length} of {detectedChanges.length}.
  </p>
</BaseLayout>
