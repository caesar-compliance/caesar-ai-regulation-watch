---
import BaseLayout from "../../layouts/BaseLayout.astro";
import StatusBucketBadge from "../../components/StatusBucketBadge.astro";
import { buildTopicSummaries } from "../../lib/tracker-drilldown";
import { STATUS_BUCKET_LABELS } from "../../lib/tracker-data";

const topics = buildTopicSummaries();
---

<BaseLayout
  title="Topics"
  currentPath="/topics/"
  description="Topic drilldowns across pilot AI regulation tracker jurisdictions."
>
  <h1>Topics</h1>
  <p class="lead">
    Cross-cutting regulatory themes from pilot tracker seeds. Topic tags link jurisdictions and
    updates — not a complete taxonomy. Not legal advice.
  </p>

  <ul class="drilldown-index">
    {
      topics.map((t) => (
        <li class="drilldown-card">
          <h2>
            <a href={t.route}>{t.label}</a>
          </h2>
          {t.description && <p>{t.description}</p>}
          <p class="drilldown-card__meta">
            {t.jurisdiction_count} jurisdiction(s) · {t.update_count} update(s) · Regions:{" "}
            {t.regions.join(", ") || "—"}
          </p>
          <div class="drilldown-card__buckets">
            {Object.entries(t.status_bucket_counts).map(([bucket, count]) => (
              <span class="drilldown-card__bucket">
                <StatusBucketBadge
                  bucket={bucket as keyof typeof STATUS_BUCKET_LABELS}
                  label={`${STATUS_BUCKET_LABELS[bucket as keyof typeof STATUS_BUCKET_LABELS] ?? bucket} (${count})`}
                />
              </span>
            ))}
          </div>
          <p>
            <a href={t.route}>Topic detail →</a>
            {" · "}
            <a href={`/updates/?topic=${encodeURIComponent(t.topic_id)}`}>Updates →</a>
            {" · "}
            <a href={`/countries/?topic=${encodeURIComponent(t.topic_id)}`}>Countries →</a>
          </p>
        </li>
      ))
    }
  </ul>

  <p>
    <a href="/tracker/">Tracker</a> · <a href="/regions/">Regions</a>
  </p>
</BaseLayout>
