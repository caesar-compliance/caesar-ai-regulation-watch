---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PROJECT_VERSION_LABEL } from "../lib/project-version";
import {
  getReviewQueueCards,
  getReviewQueueSummary,
  getSourceFreshnessSummary,
  getOperatorReviewSummary,
  getSignalQualitySummary,
  getRegulationReviewQueue,
  getOperatorQueueCards,
  getIngressFilterSummary,
  getSuppressedQueueSummary,
  INGRESS_DECISION_LABELS,
  REVIEW_STATUS_LABELS,
  RELEVANCE_LABELS,
  SIGNAL_CATEGORY_LABELS,
  RECOMMENDED_ACTION_LABELS,
} from "../lib/regulation-review-queue";
import { getJurisdictions } from "../lib/data";
import { humanizeId } from "../lib/format";

const allCards = getReviewQueueCards();
const cards = getOperatorQueueCards();
const suppressedSummary = getSuppressedQueueSummary();
const ingressSummary = getIngressFilterSummary();
const summary = getReviewQueueSummary();
const signalSummary = getSignalQualitySummary();
const queueMeta = getRegulationReviewQueue();
const freshnessSummary = getSourceFreshnessSummary();
const operatorSummary = getOperatorReviewSummary();
const jurisdictions = getJurisdictions();
const jMap = Object.fromEntries(jurisdictions.map((j) => [j.jurisdiction_id, j.name]));

const priorities = ["high", "medium", "low"];
const statuses = [
  "review_required",
  "in_review",
  "needs_source_check",
  "needs_legal_review",
  "accepted_for_tracking",
  "dismissed",
].filter((s) => cards.some((c) => c.review_status === s));
const sources = [...new Set(cards.map((c) => c.source_key))].sort();
const topics = [...new Set(cards.flatMap((c) => c.topic_tags))].sort();
const relevances = ["high", "medium", "low", "noise"].filter((r) =>
  cards.some((c) => c.ai_regulation_relevance === r),
);
const signalCategories = [...new Set(cards.map((c) => c.signal_category).filter(Boolean))].sort();
const recommendedActions = [...new Set(cards.map((c) => c.recommended_operator_action).filter(Boolean))].sort();
const decisionCounts = operatorSummary.decision_counts ?? {};
const rulesVersion =
  queueMeta.signal_quality_rules_version ?? signalSummary.rules_version ?? "—";
---

<BaseLayout
  title="Regulation review queue"
  currentPath="/review-queue/"
  description="Read-only regulation monitoring review queue with source freshness signals — metadata only, not legal advice."
>
  <div data-filter-page>
    <h1>Regulation review queue</h1>
    <p class="lead">
      {PROJECT_VERSION_LABEL} — Ingress filtering (T084) and signal quality (T083) on backend candidates
      with operator decision state (T082). Default view shows operator-visible cards only; not legal
      verification.
    </p>

    <div class="banner banner--review" role="note">
      <strong>{cards.length} operator-visible</strong> / {allCards.length} total ·{" "}
      {ingressSummary.suppress_noise_count ?? 0} noise suppressed ·{" "}
      {ingressSummary.suppress_duplicate_count ?? 0} duplicate suppressed ·{" "}
      <strong>{summary.total} candidates</strong> · {summary.review_required} review_required ·{" "}
      {summary.in_review} in_review · {summary.needs_source_check} needs source check ·{" "}
      {summary.accepted_for_tracking} tracking only · {summary.dismissed} dismissed · Cron:{" "}
      <strong>disabled</strong> · Not legal advice.
    </div>

    <section class="tracker-section">
      <h2>Ingress filter (T084)</h2>
      <div class="metrics-strip metrics-strip--monitoring">
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{ingressSummary.candidate_review_now_count ?? 0}</span>
          <span class="metrics-strip__label">Review now</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{ingressSummary.candidate_source_check_count ?? 0}</span>
          <span class="metrics-strip__label">Source check</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{ingressSummary.candidate_manual_later_count ?? 0}</span>
          <span class="metrics-strip__label">Manual later</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{ingressSummary.suppress_noise_count ?? 0}</span>
          <span class="metrics-strip__label">Suppress noise</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{ingressSummary.suppress_duplicate_count ?? 0}</span>
          <span class="metrics-strip__label">Suppress duplicate</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{ingressSummary.automated_source_count ?? 0}</span>
          <span class="metrics-strip__label">Automated sources</span>
        </div>
      </div>
      <p>
        Rules version <code>{ingressSummary.rules_version ?? rulesVersion}</code> ·{" "}
        <a href="/data/ingress-filter-summary.json">ingress-filter-summary.json</a>
      </p>
    </section>

    <section class="tracker-section">
      <h2>Signal quality (T083)</h2>
      <div class="metrics-strip metrics-strip--monitoring">
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{signalSummary.high_relevance_count ?? 0}</span>
          <span class="metrics-strip__label">High relevance</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{signalSummary.medium_relevance_count ?? 0}</span>
          <span class="metrics-strip__label">Medium</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{signalSummary.low_relevance_count ?? 0}</span>
          <span class="metrics-strip__label">Low</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{signalSummary.noise_count ?? 0}</span>
          <span class="metrics-strip__label">Noise</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{signalSummary.review_now_count ?? 0}</span>
          <span class="metrics-strip__label">Review now</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{signalSummary.dismiss_recommended_count ?? 0}</span>
          <span class="metrics-strip__label">Dismiss recommended</span>
        </div>
      </div>
      <p>
        Rules version <code>{rulesVersion}</code> · Deterministic keyword routing — metadata only.{" "}
        <a href="/data/signal-quality-summary.json">signal-quality-summary.json</a>
      </p>
    </section>

    <section class="tracker-section">
      <h2>Operator decisions (T082)</h2>
      <div class="metrics-strip metrics-strip--monitoring">
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{operatorSummary.decision_count ?? 0}</span>
          <span class="metrics-strip__label">Local decisions</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{summary.with_operator_decision ?? 0}</span>
          <span class="metrics-strip__label">Applied to queue</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{decisionCounts.mark_in_review ?? 0}</span>
          <span class="metrics-strip__label">Mark in review</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{decisionCounts.needs_source_check ?? 0}</span>
          <span class="metrics-strip__label">Needs source check</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{decisionCounts.accept_for_tracking ?? 0}</span>
          <span class="metrics-strip__label">Accept tracking</span>
        </div>
      </div>
      <p>
        Edit <code>data/runtime/operator-review-decisions.yml</code> then rebuild exports.
        Operator guide: <code>docs/OPERATOR_REVIEW_WORKFLOW.md</code> in the repository.
      </p>
      <p>
        <a href="/data/operator-review-summary.json">operator-review-summary.json</a> ·{" "}
        <a href="/data/review-packets-index.json">review-packets-index.json</a>
      </p>
    </section>

    <section class="tracker-section">
      <h2>Source freshness summary</h2>
      <div class="metrics-strip metrics-strip--monitoring">
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{freshnessSummary.fresh ?? 0}</span>
          <span class="metrics-strip__label">Fresh (automated)</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{freshnessSummary.aging ?? 0}</span>
          <span class="metrics-strip__label">Aging</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{freshnessSummary.stale ?? 0}</span>
          <span class="metrics-strip__label">Stale</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{freshnessSummary.manual_review_needed ?? 0}</span>
          <span class="metrics-strip__label">Manual review needed</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{freshnessSummary.not_automated ?? 0}</span>
          <span class="metrics-strip__label">Not automated</span>
        </div>
      </div>
      <p>
        <a href="/runtime-health/">Runtime health</a> ·{" "}
        <a href="/data/source-freshness.json">source-freshness.json</a> ·{" "}
        <a href="/data/regulation-review-queue.json">regulation-review-queue.json</a>
      </p>
    </section>

    <div class="filter-bar">
      <label>
        Priority
        <select data-filter-key="priority">
          <option value="">All</option>
          {priorities.map((p) => (
            <option value={p}>{humanizeId(p)}</option>
          ))}
        </select>
      </label>
      <label>
        Review status
        <select data-filter-key="status">
          <option value="">All</option>
          {statuses.map((s) => (
            <option value={s}>{REVIEW_STATUS_LABELS[s] ?? humanizeId(s)}</option>
          ))}
        </select>
      </label>
      <label>
        Has operator decision
        <select data-filter-key="hasDecision">
          <option value="">All</option>
          <option value="yes">With decision</option>
          <option value="no">No decision yet</option>
        </select>
      </label>
      <label>
        Jurisdiction
        <select data-filter-key="jurisdiction">
          <option value="">All</option>
          {jurisdictions.map((j) => (
            <option value={j.jurisdiction_id}>{j.name}</option>
          ))}
        </select>
      </label>
      <label>
        Source
        <select data-filter-key="source">
          <option value="">All</option>
          {sources.map((s) => (
            <option value={s}>{s}</option>
          ))}
        </select>
      </label>
      <label>
        Topic
        <select data-filter-key="topic">
          <option value="">All</option>
          {topics.map((t) => (
            <option value={t}>{humanizeId(t)}</option>
          ))}
        </select>
      </label>
      <label>
        AI relevance
        <select data-filter-key="relevance">
          <option value="">All</option>
          {relevances.map((r) => (
            <option value={r}>{RELEVANCE_LABELS[r] ?? humanizeId(r)}</option>
          ))}
        </select>
      </label>
      <label>
        Signal category
        <select data-filter-key="signalCategory">
          <option value="">All</option>
          {signalCategories.map((c) => (
            <option value={c}>{SIGNAL_CATEGORY_LABELS[c] ?? humanizeId(c)}</option>
          ))}
        </select>
      </label>
      <label>
        Recommended action
        <select data-filter-key="recommendedAction">
          <option value="">All</option>
          {recommendedActions.map((a) => (
            <option value={a}>{RECOMMENDED_ACTION_LABELS[a] ?? humanizeId(a)}</option>
          ))}
        </select>
      </label>
      <p class="filter-bar__count" data-filter-count />
    </div>

    <ul class="card-list" data-regulation-review-queue-list>
      {
        cards.map((card) => {
          const op = card.operator_decision;
          const statusLabel =
            REVIEW_STATUS_LABELS[card.review_status] ?? humanizeId(card.review_status);
          return (
            <li
              class="card filter-item"
              data-filter-item
              data-priority={card.priority}
              data-status={card.review_status}
              data-jurisdiction={card.jurisdiction_id}
              data-source={card.source_key}
              data-topic={card.topic_tags.join(" ")}
              data-has-decision={op ? "yes" : "no"}
              data-signal-score={card.signal_score ?? ""}
              data-relevance={card.ai_regulation_relevance ?? ""}
              data-signal-category={card.signal_category ?? ""}
              data-recommended-action={card.recommended_operator_action ?? ""}
              data-ingress-decision={card.ingress_decision ?? ""}
              data-reason-codes={(card.reason_codes ?? []).join(",")}
            >
              <div class="card__meta">
                <span class="badge badge--type" title="signal_score">
                  signal_score {card.signal_score ?? "—"}
                </span>
                <span
                  class={`badge badge--relevance-${card.ai_regulation_relevance ?? "unknown"}`}
                  title="ai_regulation_relevance"
                >
                  ai_regulation_relevance:{" "}
                  {RELEVANCE_LABELS[card.ai_regulation_relevance ?? ""] ??
                    humanizeId(card.ai_regulation_relevance ?? "unknown")}
                </span>
                <span class="badge badge--type" title="signal_category">
                  signal_category:{" "}
                  {SIGNAL_CATEGORY_LABELS[card.signal_category ?? ""] ??
                    humanizeId(card.signal_category ?? "unknown")}
                </span>
                <span class={`badge badge--${card.priority === "high" ? "warn" : "type"}`}>
                  {card.priority} priority
                </span>
                <span class={`badge badge--decision-${card.review_status}`}>
                  {statusLabel}
                </span>
                {
                  card.review_status === "accepted_for_tracking" && (
                    <span class="badge badge--tracking-only">Tracking only — not legal verification</span>
                  )
                }
                {
                  card.review_required && card.review_status !== "dismissed" && (
                    <span class="badge badge--review">Review required</span>
                  )
                }
                {op && <span class="badge badge--type">Operator: {humanizeId(op.decision)}</span>}
                <span class="badge badge--review" title="recommended_operator_action">
                  recommended_operator_action:{" "}
                  {RECOMMENDED_ACTION_LABELS[card.recommended_operator_action ?? ""] ??
                    humanizeId(card.recommended_operator_action ?? "")}
                </span>
                <span class="badge badge--type" title="ingress_decision">
                  ingress_decision:{" "}
                  {INGRESS_DECISION_LABELS[card.ingress_decision ?? ""] ??
                    humanizeId(card.ingress_decision ?? "")}
                </span>
              </div>
              {
                op && (
                  <p class="card__excerpt">
                    <small>
                      <strong>Operator decision overrides signal recommendation</strong> — automated
                      priority/action is advisory only.
                    </small>
                  </p>
                )
              }
              <h2 class="card__title-sm">{card.title}</h2>
              <p class="card__excerpt">
                <small>
                  {jMap[card.jurisdiction_id] ?? card.jurisdiction_id} · {card.source_title} ·{" "}
                  <span class="mono">{card.change_type}</span>
                  {card.detected_at && ` · ${card.detected_at.slice(0, 10)}`}
                </small>
              </p>
              {card.metadata_summary && <p>{card.metadata_summary}</p>}
              {
                (card.reason_codes?.length ?? 0) > 0 && (
                  <p class="card__excerpt">
                    <small>
                      <strong>reason_codes:</strong> {card.reason_codes?.join(", ")}
                    </small>
                  </p>
                )
              }
              {
                card.signal_quality_note && (
                  <p class="card__excerpt">
                    <small>{card.signal_quality_note}</small>
                  </p>
                )
              }
              {
                op?.public_note && (
                  <p class="card__excerpt">
                    <strong>Public note:</strong> {op.public_note}
                  </p>
                )
              }
              {
                op?.rationale && (
                  <p class="card__excerpt">
                    <small>
                      <strong>Rationale:</strong> {op.rationale}
                    </small>
                  </p>
                )
              }
              {
                card.review_status === "needs_source_check" && (
                  <p class="card__excerpt warn-text">
                    <strong>Source check needed</strong> — confirm official URL before any tracker change.
                    {op?.source_checked_url && (
                      <>
                        {" "}
                        <a href={op.source_checked_url} target="_blank" rel="noopener noreferrer">
                          Checked URL ↗
                        </a>
                      </>
                    )}
                  </p>
                )
              }
              {
                card.source_url && (
                  <p>
                    <a href={card.source_url} target="_blank" rel="noopener noreferrer">
                      Official source ↗
                    </a>
                  </p>
                )
              }
              <p class="card__excerpt">
                <small>{card.safety_notes}</small>
              </p>
            </li>
          );
        })
      }
    </ul>

    {
      cards.length === 0 && (
        <p>No operator-visible regulation review candidates in current export. Run a bounded worker pilot and rebuild exports.</p>
      )
    }

    <details class="tracker-section ingress-suppressed">
      <summary>
        Suppressed / noise summary ({suppressedSummary.length} items — metadata only, collapsed by default)
      </summary>
      {
        suppressedSummary.length === 0 ? (
          <p>No suppressed items in current export.</p>
        ) : (
          <ul class="card-list">
            {
              suppressedSummary.map((item) => (
                <li class="card">
                  <p class="card__excerpt">
                    <small>
                      {item.candidate_id} · {item.source_key} · signal {item.signal_score ?? "—"} ·{" "}
                      {INGRESS_DECISION_LABELS[item.ingress_decision] ?? item.ingress_decision}
                      {item.suppression_reason && ` · ${item.suppression_reason}`}
                    </small>
                  </p>
                  <p class="card__title-sm">{item.title}</p>
                  {
                    (item.reason_codes?.length ?? 0) > 0 && (
                      <p class="card__excerpt">
                        <small>reason_codes: {item.reason_codes?.join(", ")}</small>
                      </p>
                    )
                  }
                </li>
              ))
            }
          </ul>
        )
      }
    </details>
  </div>

  <section class="tracker-section">
    <h2>Registry human review queue (legacy)</h2>
    <p>
      Curated registry URL/content verification items remain in{" "}
      <a href="/data/review-queue.json">review-queue.json</a> and{" "}
      <a href="/content-review/">content review</a> — separate from backend monitoring candidates above.
    </p>
  </section>

  <script is:inline src="/scripts/regulation-review-queue-filter.js"></script>
</BaseLayout>

<style>
  .warn-text {
    color: var(--color-warn-text, #8a4510);
  }
</style>
