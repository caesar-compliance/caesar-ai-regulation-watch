{
  "name": "caesar-ai-regulation-watch",
  "type": "module",
  "version": "0.5.1",
  "private": true,
  "description": "Read-only static site for Caesar AI Regulation Watch pilot data",
  "scripts": {
    "validate:data": "node scripts/validate-data.mjs",
    "generate:exports": "node scripts/generate-static-exports.mjs",
    "dev": "astro dev",
    "build:site": "astro build",
    "build:search": "pagefind --site dist",
    "build": "npm run validate:data && npm run generate:exports && npm run build:site && npm run build:search",
    "preview": "astro preview"
  },
  "dependencies": {
    "astro": "^5.7.10",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "pagefind": "^1.3.0"
  }
}
