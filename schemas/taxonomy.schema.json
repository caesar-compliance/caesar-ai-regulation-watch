{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/taxonomy.schema.json",
  "title": "Caesar AI Regulation Watch — Taxonomy file",
  "description": "Canonical allowed values for regulation-watch data fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taxonomy_id",
    "title",
    "version",
    "last_updated",
    "description",
    "values"
  ],
  "properties": {
    "taxonomy_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "last_updated": { "type": "string", "format": "date" },
    "description": { "type": "string", "minLength": 1 },
    "values": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["value_id", "label", "description"],
        "properties": {
          "value_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_.-]*$"
          },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "reference_convention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "alignment_status", "legal_safe_note"],
      "properties": {
        "pattern": { "type": "string", "minLength": 1 },
        "alignment_status": { "type": "string", "minLength": 1 },
        "legal_safe_note": { "type": "string", "minLength": 1 }
      }
    }
  }
}
