{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/live-metadata-pilot.schema.json",
  "title": "Caesar AI Regulation Watch — Live metadata pilot allowlist",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pilot_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_crawl",
    "no_full_text_storage",
    "no_competitor_source",
    "client_use_allowed",
    "final_evidence_allowed",
    "sources"
  ],
  "properties": {
    "pilot_id": {
      "type": "string",
      "pattern": "^live-metadata-pilot-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "access_date": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "previous_reference_run_id": {
      "type": "string",
      "pattern": "^monitoring-run-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_crawl": { "type": "boolean", "const": true },
    "no_full_text_storage": { "type": "boolean", "const": true },
    "no_competitor_source": { "type": "boolean", "const": true },
    "client_use_allowed": { "type": "boolean", "const": false },
    "final_evidence_allowed": { "type": "boolean", "const": false },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/pilotSource" }
    }
  },
  "$defs": {
    "pilotSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "official_url",
        "request_method",
        "max_requests_per_run",
        "fetch_scope",
        "allowed_to_fetch",
        "no_crawl",
        "no_full_text_storage",
        "no_competitor_source",
        "client_use_allowed",
        "final_evidence_allowed",
        "verified_on_source"
      ],
      "properties": {
        "source_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "official_url": { "type": "string", "format": "uri" },
        "request_method": { "type": "string", "enum": ["HEAD", "GET"] },
        "max_requests_per_run": { "type": "integer", "const": 1 },
        "fetch_scope": { "type": "string", "const": "metadata_only" },
        "allowed_to_fetch": { "type": "boolean", "const": true },
        "no_crawl": { "type": "boolean", "const": true },
        "no_full_text_storage": { "type": "boolean", "const": true },
        "no_competitor_source": { "type": "boolean", "const": true },
        "client_use_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "verified_on_source": { "type": "boolean", "const": false }
      }
    }
  }
}
