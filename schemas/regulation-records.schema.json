{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RegulationRecordsExport",
  "type": "object",
  "required": ["records", "record_count", "generated_at", "review_required"],
  "properties": {
    "generated_at": { "type": "string" },
    "review_required": { "const": true },
    "legal_change_claimed": { "const": false },
    "record_count": { "type": "integer", "minimum": 0 },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "regulation_id",
          "jurisdiction_id",
          "title",
          "source_url",
          "status",
          "review_required"
        ],
        "properties": {
          "regulation_id": { "type": "string" },
          "jurisdiction_id": { "type": "string" },
          "title": { "type": "string" },
          "source_url": { "type": "string", "format": "uri" },
          "status": { "type": "string" },
          "review_required": { "const": true }
        }
      }
    }
  }
}
