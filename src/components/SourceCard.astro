---
import type { Source } from "../lib/data";
import CredibilityBadge from "./CredibilityBadge.astro";
import ReviewStatusBadge from "./ReviewStatusBadge.astro";
import { truncate } from "../lib/format";

interface Props {
  source: Source;
  filterable?: boolean;
}

const { source, filterable = false } = Astro.props;
---

<li
  class:list={["card", filterable && "filter-item"]}
  data-filter-item={filterable ? true : undefined}
  data-jurisdiction={filterable ? source.jurisdiction_id : undefined}
  data-credibility={filterable ? source.credibility_level : undefined}
  data-review={filterable ? source.review_status : undefined}
>
  <div class="card__meta">
    <CredibilityBadge level={source.credibility_level} />
    <ReviewStatusBadge status={source.review_status} />
  </div>
  <h3><a href={`/sources/${source.source_id}/`}>{source.title}</a></h3>
  <p class="card__excerpt">
    {truncate(source.monitoring_scope, 140)}
  </p>
</li>
