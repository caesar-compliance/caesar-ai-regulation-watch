{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/watcher-monitoring-run.schema.json",
  "title": "Caesar AI Regulation Watch — Deterministic watcher monitoring run",
  "description": "Local/offline monitoring run for watcher-eligible confirmed sources. Not a legal conclusion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "monitoring_run_id",
    "run_date",
    "run_timestamp",
    "mode",
    "watcher_eligibility_batch_id",
    "legal_safe_note",
    "no_broad_scraping",
    "no_competitor_source",
    "client_use_allowed",
    "final_evidence_allowed",
    "checks"
  ],
  "properties": {
    "monitoring_run_id": {
      "type": "string",
      "pattern": "^monitoring-run-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "run_date": { "type": "string", "format": "date" },
    "run_timestamp": { "type": "string", "format": "date-time" },
    "mode": {
      "type": "string",
      "enum": ["deterministic_local", "dry_run", "report_only"]
    },
    "run_mode": {
      "type": "string",
      "enum": ["deterministic_local", "dry_run", "report_only"]
    },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "monitoring_source_config_batch_id": {
      "type": "string",
      "pattern": "^source-configs-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "watcher_eligibility_batch_id": {
      "type": "string",
      "pattern": "^watcher-eligibility-[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_broad_scraping": { "type": "boolean", "const": true },
    "no_competitor_source": { "type": "boolean", "const": true },
    "client_use_allowed": { "type": "boolean", "const": false },
    "final_evidence_allowed": { "type": "boolean", "const": false },
    "overall_status": {
      "type": "string",
      "enum": ["completed", "partial", "report_only"]
    },
    "change_detected_count": { "type": "integer", "minimum": 0 },
    "requires_human_review_count": { "type": "integer", "minimum": 0 },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/monitoringCheck" }
    }
  },
  "$defs": {
    "monitoringCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "url",
        "monitoring_method",
        "check_result",
        "change_detected",
        "requires_human_review",
        "notes",
        "client_use_allowed",
        "final_evidence_allowed"
      ],
      "properties": {
        "source_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "url": { "type": "string", "format": "uri" },
        "adapter_type": {
          "type": "string",
          "enum": ["static_page", "feed", "official_api", "manual_only"]
        },
        "monitoring_method": {
          "type": "string",
          "enum": [
            "url_status_check",
            "page_metadata_check",
            "feed_check",
            "api_check",
            "manual_only",
            "none"
          ]
        },
        "fetch_scope": {
          "type": "string",
          "enum": [
            "status_only",
            "metadata_only",
            "feed_entries",
            "api_metadata",
            "not_fetched"
          ]
        },
        "check_result": {
          "type": "string",
          "enum": [
            "no_change_snapshot_created",
            "status_check_ok",
            "metadata_snapshot_created",
            "status_check_failed",
            "fetch_failed_needs_review",
            "manual_only_not_checked",
            "blocked_not_checked"
          ]
        },
        "http_status": { "type": ["integer", "null"], "minimum": 0 },
        "title": { "type": ["string", "null"] },
        "last_modified": { "type": ["string", "null"] },
        "etag": { "type": ["string", "null"] },
        "content_hash": { "type": ["string", "null"] },
        "run_timestamp": { "type": "string", "format": "date-time" },
        "change_detected": { "type": "boolean" },
        "detected_change_id": { "type": ["string", "null"] },
        "requires_human_review": { "type": "boolean" },
        "notes": { "type": "string", "minLength": 1 },
        "client_use_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false }
      }
    }
  }
}
