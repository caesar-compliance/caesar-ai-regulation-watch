{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/content-review.schema.json",
  "title": "Caesar AI Regulation Watch — Content review batch",
  "description": "Human content review log for summaries, dates, statuses, and detected changes. Not legal advice. Does not approve client use.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "content_review_batch_id",
    "review_date",
    "verifier_type",
    "content_reviews",
    "legal_safe_note"
  ],
  "properties": {
    "content_review_batch_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "review_date": {
      "type": "string",
      "format": "date"
    },
    "verifier_type": {
      "type": "string",
      "enum": ["human_reviewer", "automated_check_pending", "curator_batch"]
    },
    "content_reviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "content_review_id",
          "review_date",
          "reviewer_type",
          "item_type",
          "item_id",
          "jurisdiction_id",
          "source_id",
          "official_url_checked",
          "review_scope",
          "review_result",
          "source_support_level",
          "reviewed_fields",
          "fields_needing_update",
          "summary_review_note",
          "date_review_note",
          "status_review_note",
          "recommended_next_action",
          "content_review_status_after_check",
          "verified_on_source_after_check",
          "client_use_allowed",
          "legal_safe_note"
        ],
        "properties": {
          "content_review_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "review_date": {
            "type": "string",
            "format": "date"
          },
          "reviewer_type": {
            "type": "string",
            "enum": ["human_reviewer", "automated_check_pending", "curator_batch"]
          },
          "item_type": {
            "type": "string",
            "enum": [
              "law",
              "guidance",
              "policy_framework",
              "implementation_update",
              "detected_change",
              "timeline_event"
            ]
          },
          "item_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "jurisdiction_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "source_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "official_url_checked": {
            "type": "string",
            "format": "uri"
          },
          "review_scope": {
            "type": "string",
            "minLength": 1
          },
          "review_result": {
            "type": "string",
            "enum": [
              "matches_source_at_high_level",
              "partially_matches_source",
              "source_support_unclear",
              "needs_update",
              "rejected_for_client_use",
              "not_checked"
            ]
          },
          "source_support_level": {
            "type": "string",
            "enum": ["high", "medium", "low", "unclear"]
          },
          "reviewed_fields": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "fields_needing_update": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "summary_review_note": {
            "type": "string"
          },
          "date_review_note": {
            "type": "string"
          },
          "status_review_note": {
            "type": "string"
          },
          "recommended_next_action": {
            "type": "string",
            "enum": [
              "keep_pending_review",
              "convert_to_change_record",
              "update_existing_record",
              "ignore_noise",
              "needs_human_legal_review",
              "human_browser_content_review_required",
              "no_action_until_human_review"
            ]
          },
          "content_review_status_after_check": {
            "type": "string",
            "enum": [
              "not_reviewed",
              "reviewed_content_summary",
              "needs_update",
              "rejected_for_client_use"
            ]
          },
          "verified_on_source_after_check": {
            "type": "boolean"
          },
          "client_use_allowed": {
            "type": "boolean"
          },
          "legal_safe_note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "legal_safe_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
