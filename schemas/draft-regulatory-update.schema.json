{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/draft-regulatory-update.schema.json",
  "title": "Caesar AI Regulation Watch — Draft regulatory update (manual review only)",
  "description": "Draft/manual-review-only regulatory update candidate. Excluded from public exports until separately approved.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "draft_id",
    "update_id",
    "title",
    "source_url",
    "source_id",
    "jurisdiction_ids",
    "topic_ids",
    "published_at",
    "summary",
    "status",
    "intake_method",
    "source_execution_id",
    "source_approval_id",
    "source_adapter_id",
    "review_required",
    "verified_on_source",
    "client_use_allowed",
    "client_evidence_allowed",
    "final_evidence_allowed",
    "legal_change_claimed",
    "publication_allowed",
    "public_export_allowed",
    "evidence_export_allowed",
    "review_status",
    "latest_review_decision_id",
    "latest_revision_id",
    "source_verification_required_before_publication",
    "topic_jurisdiction_confirmation_required",
    "notes"
  ],
  "properties": {
    "draft_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "update_id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "title": { "type": "string", "minLength": 1, "maxLength": 500 },
    "source_url": { "type": "string", "format": "uri" },
    "source_id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "jurisdiction_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" }
    },
    "topic_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" }
    },
    "published_at": { "type": "string", "minLength": 1 },
    "source_published_at": { "type": "string" },
    "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "status": { "type": "string", "const": "draft_manual_review" },
    "review_status": {
      "type": "string",
      "enum": [
        "pending_review",
        "revised_after_request_changes",
        "awaiting_source_verification",
        "awaiting_publication_review"
      ]
    },
    "latest_review_decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "latest_revision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "source_verification_required_before_publication": { "type": "boolean", "const": true },
    "topic_jurisdiction_confirmation_required": { "type": "boolean", "const": true },
    "intake_method": { "type": "string", "const": "single_source_network_dry_run" },
    "source_execution_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "source_approval_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "source_adapter_id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "promotion_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "candidate_id": { "type": "string", "minLength": 1 },
    "review_required": { "type": "boolean", "const": true },
    "verified_on_source": { "type": "boolean", "const": false },
    "client_use_allowed": { "type": "boolean", "const": false },
    "client_evidence_allowed": { "type": "boolean", "const": false },
    "final_evidence_allowed": { "type": "boolean", "const": false },
    "legal_change_claimed": { "type": "boolean", "const": false },
    "publication_allowed": { "type": "boolean", "const": false },
    "public_export_allowed": { "type": "boolean", "const": false },
    "evidence_export_allowed": { "type": "boolean", "const": false },
    "notes": { "type": "string", "minLength": 1 }
  }
}
