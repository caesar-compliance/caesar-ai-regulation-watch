{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/draft-regulatory-update.schema.json",
  "title": "Caesar AI Regulation Watch — Draft regulatory update (manual review only)",
  "description": "Draft/manual-review-only regulatory update candidate. Excluded from public exports until separately approved.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "draft_id",
    "update_id",
    "title",
    "source_url",
    "source_id",
    "jurisdiction_ids",
    "topic_ids",
    "published_at",
    "summary",
    "status",
    "intake_method",
    "source_execution_id",
    "source_approval_id",
    "source_adapter_id",
    "review_required",
    "verified_on_source",
    "client_use_allowed",
    "client_evidence_allowed",
    "final_evidence_allowed",
    "legal_change_claimed",
    "publication_allowed",
    "public_export_allowed",
    "evidence_export_allowed",
    "review_status",
    "latest_review_decision_id",
    "latest_revision_id",
    "latest_readiness_gate_id",
    "readiness_result",
    "next_required_step",
    "source_verification_required_before_publication",
    "legal_review_required_before_publication",
    "separate_publication_approval_required",
    "topic_jurisdiction_confirmation_required",
    "notes"
  ],
  "properties": {
    "draft_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "update_id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "title": { "type": "string", "minLength": 1, "maxLength": 500 },
    "source_url": { "type": "string", "format": "uri" },
    "source_id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "jurisdiction_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" }
    },
    "topic_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" }
    },
    "published_at": { "type": "string", "minLength": 1 },
    "source_published_at": { "type": "string" },
    "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "status": { "type": "string", "const": "draft_manual_review" },
    "review_status": {
      "type": "string",
      "enum": [
        "pending_review",
        "revised_after_request_changes",
        "awaiting_source_verification",
        "awaiting_publication_review"
      ]
    },
    "latest_review_decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "latest_revision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "latest_readiness_gate_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "readiness_result": {
      "type": "string",
      "enum": [
        "not_ready_for_publication_review",
        "ready_for_source_verification_checklist",
        "ready_for_future_publication_review"
      ]
    },
    "next_required_step": { "type": "string", "minLength": 1 },
    "source_verification_required_before_publication": { "type": "boolean", "const": true },
    "legal_review_required_before_publication": { "type": "boolean", "const": true },
    "separate_publication_approval_required": { "type": "boolean", "const": true },
    "topic_jurisdiction_confirmation_required": { "type": "boolean", "const": true },
    "intake_method": { "type": "string", "const": "single_source_network_dry_run" },
    "source_execution_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "source_approval_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "source_adapter_id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
    "promotion_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "candidate_id": { "type": "string", "minLength": 1 },
    "review_required": { "type": "boolean", "const": true },
    "verified_on_source": { "type": "boolean", "const": false },
    "client_use_allowed": { "type": "boolean", "const": false },
    "client_evidence_allowed": { "type": "boolean", "const": false },
    "final_evidence_allowed": { "type": "boolean", "const": false },
    "legal_change_claimed": { "type": "boolean", "const": false },
    "publication_allowed": { "type": "boolean", "const": false },
    "public_export_allowed": { "type": "boolean", "const": false },
    "evidence_export_allowed": { "type": "boolean", "const": false },
    "latest_source_verification_result_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "source_verification_result": {
      "type": "string",
      "enum": ["partial_pass_needs_follow_up", "blocked", "ready_for_final_legal_review"]
    },
    "final_source_verification_completed": { "type": "boolean", "const": false },
    "latest_final_legal_review_packet_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "latest_final_legal_review_decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "final_legal_review_decision": {
      "type": "string",
      "enum": ["request_changes", "reject", "approve_internal_review_only"]
    },
    "latest_final_legal_review_response_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "final_legal_review_response_status": {
      "type": "string",
      "enum": ["draft_response_recorded", "ready_for_reviewer_recheck", "blocked"]
    },
    "latest_final_reviewer_recheck_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "final_reviewer_recheck_status": {
      "type": "string",
      "enum": ["recorded", "superseded"]
    },
    "final_reviewer_recheck_result": {
      "type": "string",
      "enum": ["ready_for_publication_gate_review", "needs_more_changes", "blocked"]
    },
    "ready_for_publication_gate_review": { "type": "boolean" },
    "latest_publication_gate_packet_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "publication_gate_status": {
      "type": "string",
      "enum": ["pending_publication_gate_decision", "blocked", "superseded"]
    },
    "publication_gate_result": {
      "type": "string",
      "enum": [
        "blocked_pending_publication_decision",
        "ready_for_publication_gate_decision",
        "rejected"
      ]
    },
    "latest_publication_gate_decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "publication_gate_decision": {
      "type": "string",
      "enum": ["approve_for_publication_staging", "request_changes", "reject"]
    },
    "publication_gate_decision_status": {
      "type": "string",
      "enum": ["recorded", "superseded"]
    },
    "publication_staging_allowed": { "type": "boolean" },
    "latest_publication_staging_preview_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "publication_staging_preview_status": {
      "type": "string",
      "enum": ["generated_internal_preview", "superseded", "blocked"]
    },
    "publication_staging_preview_route": { "type": "string", "minLength": 1 },
    "staging_preview_created": { "type": "boolean" },
    "noindex_requested": { "type": "boolean" },
    "latest_public_export_release_gate_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "public_export_release_gate_status": {
      "type": "string",
      "enum": ["pending_public_export_approval", "blocked", "superseded"]
    },
    "public_export_release_gate_result": {
      "type": "string",
      "enum": [
        "ready_for_public_export_approval",
        "blocked_pending_fixes",
        "rejected"
      ]
    },
    "public_export_gate_ready": { "type": "boolean" },
    "ready_for_public_export_approval": { "type": "boolean" },
    "latest_public_export_approval_decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "public_export_approval_decision": {
      "type": "string",
      "enum": [
        "approve_non_public_export_preview",
        "request_changes",
        "reject"
      ]
    },
    "public_export_approval_status": {
      "type": "string",
      "enum": ["recorded", "superseded"]
    },
    "non_public_export_preview_allowed": { "type": "boolean" },
    "non_public_export_preview_artifact_path": {
      "type": "string",
      "pattern": "^generated/public-export-preview/"
    },
    "latest_public_update_release_decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
    "public_update_release_decision": {
      "type": "string",
      "enum": [
        "hold_publication_pending_explicit_release_approval",
        "approve_publication_release",
        "reject_publication_release",
        "request_changes"
      ]
    },
    "public_update_release_decision_status": {
      "type": "string",
      "enum": ["recorded", "superseded"]
    },
    "public_update_release_decision_recorded": { "type": "boolean" },
    "proposed_public_update_route": { "type": "string", "pattern": "^/updates/" },
    "public_data_inclusion_allowed": { "type": "boolean" },
    "public_update_route_created": { "type": "boolean" },
    "proposed_public_update_id": { "type": "string", "minLength": 1 },
    "final_legal_review_status": {
      "type": "string",
      "enum": [
        "pending_final_legal_review",
        "request_changes_recorded",
        "revision_response_recorded",
        "reviewer_recheck_recorded",
        "reject_recorded",
        "approve_internal_review_only_recorded",
        "blocked",
        "superseded"
      ]
    },
    "conservative_summary_revision_applied": { "type": "boolean" },
    "final_legal_approval_completed": { "type": "boolean", "const": false },
    "final_legal_approval_required": { "type": "boolean", "const": true },
    "notes": { "type": "string", "minLength": 1 }
  }
}
