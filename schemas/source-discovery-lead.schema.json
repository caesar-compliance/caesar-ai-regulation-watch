{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/source-discovery-lead.schema.json",
  "title": "Caesar AI Regulation Watch — Source discovery lead batch",
  "description": "Competitor-assisted official source discovery leads. Competitor URLs are navigation aids only; not authority sources.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_discovery_batch_id",
    "generated_at",
    "legal_safe_note",
    "no_competitor_text_copied",
    "no_bulk_extraction",
    "leads"
  ],
  "properties": {
    "source_discovery_batch_id": {
      "type": "string",
      "pattern": "^source-discovery-[a-z0-9-]+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date"
    },
    "legal_safe_note": {
      "type": "string",
      "minLength": 1
    },
    "no_competitor_text_copied": {
      "type": "boolean",
      "const": true
    },
    "no_bulk_extraction": {
      "type": "boolean",
      "const": true
    },
    "leads": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "lead_id",
          "discovered_from_type",
          "discovered_from_url",
          "candidate_official_url",
          "jurisdiction_id",
          "source_category",
          "official_source_verified",
          "verification_status",
          "access_date",
          "notes",
          "no_competitor_text_copied",
          "no_bulk_extraction"
        ],
        "properties": {
          "lead_id": {
            "type": "string",
            "pattern": "^lead-[a-z0-9-]+$"
          },
          "discovered_from_type": {
            "type": "string",
            "enum": [
              "competitor_tracker",
              "official_site",
              "manual_research"
            ]
          },
          "discovered_from_url": {
            "type": "string",
            "format": "uri"
          },
          "competitor_name": {
            "type": "string",
            "minLength": 1
          },
          "lead_found_via": {
            "type": "string",
            "format": "uri"
          },
          "candidate_official_url": {
            "type": "string",
            "format": "uri"
          },
          "jurisdiction_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "source_category": {
            "type": "string",
            "enum": [
              "law",
              "guidance",
              "regulator",
              "policy_tracker",
              "implementation",
              "official_news",
              "other"
            ]
          },
          "official_source_verified": {
            "type": "boolean"
          },
          "verification_status": {
            "type": "string",
            "enum": [
              "pending_official_review",
              "official_source_confirmed",
              "official_source_unclear",
              "rejected_not_official"
            ]
          },
          "verified_title": {
            "type": "string",
            "minLength": 1
          },
          "http_status": {
            "type": "integer",
            "minimum": 100,
            "maximum": 599
          },
          "access_date": {
            "type": "string",
            "format": "date"
          },
          "promoted_source_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "existing_source_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "notes": {
            "type": "string",
            "minLength": 1
          },
          "no_competitor_text_copied": {
            "type": "boolean",
            "const": true
          },
          "no_bulk_extraction": {
            "type": "boolean",
            "const": true
          }
        },
        "allOf": [
          {
            "if": {
              "properties": { "official_source_verified": { "const": true } },
              "required": ["official_source_verified"]
            },
            "then": {
              "required": ["verified_title", "http_status"],
              "properties": {
                "verification_status": { "const": "official_source_confirmed" }
              }
            }
          },
          {
            "if": {
              "properties": { "verification_status": { "const": "official_source_confirmed" } },
              "required": ["verification_status"]
            },
            "then": {
              "required": ["verified_title", "http_status"],
              "properties": { "official_source_verified": { "const": true } }
            }
          }
        ]
      }
    }
  }
}
