{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/automation-runtime.schema.json",
  "title": "Caesar AI Regulation Watch — Automation runtime config",
  "description": "Design-time runtime manifest for live monitoring architecture. No secrets. Not live ingestion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runtime_id",
    "status",
    "live_ingestion_enabled",
    "scheduled_monitoring_enabled",
    "network_execution_enabled",
    "backend_target",
    "worker_target",
    "public_site_target",
    "source_policy",
    "planned_tables",
    "first_source_candidates",
    "gates"
  ],
  "properties": {
    "runtime_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "design_ready",
        "backend_bootstrap_ready",
        "source_pilot_framework_ready",
        "source_pilot_reviewer_ready",
        "source_pilot_decision_packets_ready",
        "source_pilot_operator_handoff_ready",
        "services_onboarding_ready",
        "runtime_foundation_ready",
        "bootstrap_ready",
        "live_disabled",
        "live_pilot"
      ]
    },
    "live_ingestion_enabled": { "type": "boolean", "const": false },
    "scheduled_monitoring_enabled": { "type": "boolean", "const": false },
    "network_execution_enabled": { "type": "boolean", "const": false },
    "backend_target": {
      "type": "string",
      "enum": ["supabase_postgres", "postgres", "none"]
    },
    "worker_target": {
      "type": "string",
      "enum": ["cloudflare_workers", "none"]
    },
    "public_site_target": {
      "type": "string",
      "enum": ["github_pages", "static_host"]
    },
    "source_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowlisted_sources_only",
        "no_broad_crawl",
        "no_paywall_bypass",
        "no_captcha_bypass",
        "metadata_only",
        "full_text_storage_allowed"
      ],
      "properties": {
        "allowlisted_sources_only": { "type": "boolean", "const": true },
        "no_broad_crawl": { "type": "boolean", "const": true },
        "no_paywall_bypass": { "type": "boolean", "const": true },
        "no_captcha_bypass": { "type": "boolean", "const": true },
        "metadata_only": { "type": "boolean", "const": true },
        "full_text_storage_allowed": { "type": "boolean", "const": false }
      }
    },
    "planned_tables": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "first_source_candidates": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verified_on_source", "client_use_allowed", "legal_change_claimed"],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false }
      }
    }
  }
}
