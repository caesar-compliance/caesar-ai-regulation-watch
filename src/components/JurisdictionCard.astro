---
import type { Jurisdiction } from "../lib/data";
import ReviewStatusBadge from "./ReviewStatusBadge.astro";
import { truncate } from "../lib/format";

interface Props {
  jurisdiction: Jurisdiction;
}

const { jurisdiction } = Astro.props;
---

<li class="card">
  <div class="card__meta">
    <span class="badge badge--type">{jurisdiction.type.replace(/_/g, " ")}</span>
    <ReviewStatusBadge status={jurisdiction.review_status} />
  </div>
  <h3><a href={`/jurisdictions/${jurisdiction.jurisdiction_id}/`}>{jurisdiction.name}</a></h3>
  <p class="card__excerpt">{truncate(jurisdiction.notes, 160)}</p>
</li>
