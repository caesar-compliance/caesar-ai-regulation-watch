---
import { getTaxonomies, taxonomyLabel } from "../lib/data";

interface Props {
  status: string;
  kind?: "regulatory" | "generic";
}

const { status, kind = "regulatory" } = Astro.props;
const taxonomies = getTaxonomies();
const label =
  kind === "regulatory"
    ? taxonomyLabel(taxonomies, "regulatory-statuses", status)
    : status.replace(/_/g, " ");
---

<span class={`badge badge--status`} title={status}>{label}</span>
