---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FilterBar from "../../components/FilterBar.astro";
import SourceCard from "../../components/SourceCard.astro";
import { getSources } from "../../lib/data";
import { sourceFilterOptions, groupSourcesByRegion } from "../../lib/filters";
import { getSourceFreshnessRows } from "../../lib/regulation-review-queue";
import { getMonitoringStatus } from "../../lib/runtime-monitoring-data";
import { PROJECT_VERSION_LABEL } from "../../lib/project-version";

const monitoring = getMonitoringStatus();

const sources = getSources();
const pilotFreshness = getSourceFreshnessRows();
const automatedPilot = pilotFreshness.filter((s) => s.automated);
const manualPilot = pilotFreshness.filter((s) => !s.automated);
const opts = sourceFilterOptions();
const groupedByRegion = groupSourcesByRegion(sources);
---

<BaseLayout title="Official sources" currentPath="/sources/">
  <div data-filter-page>
    <h1>Official sources</h1>
    <p class="lead">
      Official and authoritative source registry (global expansion v0.5.0). Primary truth is always the
      official source — not this summary.
    </p>

    <div class="banner banner--review" role="note">
      New entries require human review. URLs marked pending must be verified before client use. Future RSS/API
      adapter candidates: <a href="/source-adapters/">source adapter allowlist</a> (T052 — disabled/draft, no live
      collection).
    </div>

    <section class="tracker-section">
      <h2>Monitoring pilot registry ({PROJECT_VERSION_LABEL})</h2>
      <p>
        T086 DB alignment <strong>{monitoring.db_registry_alignment_status ?? "—"}</strong> (
        {monitoring.automated_registry_row_count ?? "—"}/6 automated rows) · T085 Worker allowlist{" "}
        <strong>{monitoring.worker_allowlist_source_count ?? 6}</strong> · last run success{" "}
        <strong>{monitoring.worker_run_source_success_count ?? "—"}</strong> · failure{" "}
        <strong>{monitoring.worker_run_source_failure_count ?? "—"}</strong> · T084 registry{" "}
        <strong>{automatedPilot.length} automated</strong> vs{" "}
        <strong>{manualPilot.length} manual-review</strong> · metadata-only; cron disabled.
      </p>
      <p>
        <a href="/data/source-freshness.json">source-freshness.json</a> ·{" "}
        <a href="/runtime-health/">Runtime health</a>
      </p>
      <table class="data-table">
        <thead>
          <tr>
            <th>Source</th>
            <th>Mode</th>
            <th>Fetch risk</th>
            <th>Freshness</th>
          </tr>
        </thead>
        <tbody>
          {
            pilotFreshness.map((s) => (
              <tr>
                <td>
                  <span class="mono">{s.source_key}</span>
                  <br />
                  <small>{s.source_title}</small>
                </td>
                <td>{s.automation_mode ?? (s.automated ? "automated_rss" : "manual_review")}</td>
                <td>{s.fetch_risk ?? "—"}</td>
                <td>{s.freshness_status}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <FilterBar
      filters={[
        { key: "jurisdiction", label: "Jurisdiction", options: opts.jurisdiction },
        { key: "credibility", label: "Credibility", options: opts.credibility },
        { key: "review", label: "Review", options: opts.review },
      ]}
    />

    {
      groupedByRegion.map((regionGroup) => (
        <section class="group-section">
          <h2 class="group-section__title">{regionGroup.region}</h2>
          {regionGroup.jurisdictions.map((group) => (
            <section>
              <h3 class="group-section__subtitle">
                <a href={`/jurisdictions/${group.id}/`}>{group.name}</a>
              </h3>
              <ul class="card-list" data-filter-list>
                {group.items.map((s) => (
                  <SourceCard source={s} filterable />
                ))}
              </ul>
            </section>
          ))}
        </section>
      ))
    }
  </div>

  <script is:inline src="/scripts/filter-list.js"></script>
</BaseLayout>
