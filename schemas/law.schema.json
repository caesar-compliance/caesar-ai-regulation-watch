{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/law.schema.json",
  "title": "Caesar AI Regulation Watch — Law record (sample)",
  "description": "Manual sample law/instrument record for data-model testing. Not legal advice.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id",
    "record_type",
    "title",
    "jurisdiction_id",
    "source_id",
    "legal_status",
    "official_url",
    "summary_for_review",
    "key_dates",
    "affected_topics",
    "review_status",
    "legal_safe_note"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "record_type": {
      "type": "string",
      "const": "law"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "jurisdiction_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "source_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "legal_status": {
      "type": "string",
      "enum": [
        "proposed",
        "adopted",
        "in_force",
        "guidance",
        "voluntary",
        "withdrawn",
        "monitoring"
      ]
    },
    "official_url": {
      "type": "string",
      "format": "uri"
    },
    "summary_for_review": {
      "type": "string",
      "minLength": 1
    },
    "key_dates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "date"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "date": { "type": "string", "format": "date" },
          "verified_on_source": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "affected_topics": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "review_status": {
      "type": "string",
      "enum": ["pending_review", "reviewed", "archived"]
    },
    "legal_safe_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
