---
interface FilterOption {
  value: string;
  label: string;
}

interface Filter {
  key: string;
  label: string;
  options: FilterOption[];
}

interface Props {
  filters: Filter[];
}

const { filters } = Astro.props;
---

<div class="filter-bar" role="search">
  {filters.map((f) => (
    <label class="filter-bar__field">
      <span class="filter-bar__label">{f.label}</span>
      <select data-filter-key={f.key} class="filter-bar__select">
        <option value="">All</option>
        {f.options.map((o) => (
          <option value={o.value}>{o.label}</option>
        ))}
      </select>
    </label>
  ))}
  <p class="filter-bar__count" data-filter-count aria-live="polite"></p>
</div>
