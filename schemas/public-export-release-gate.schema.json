{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/public-export-release-gate.schema.json",
  "title": "Caesar AI Regulation Watch — Public export release gate",
  "description": "Internal public export release gate record. Not publication. Not public export.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "public_export_release_gates_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_live_collection",
    "no_scheduled_monitoring",
    "gates"
  ],
  "properties": {
    "public_export_release_gates_id": {
      "type": "string",
      "pattern": "^public-export-release-gates-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_collection": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/gateRecord" }
    }
  },
  "$defs": {
    "gateState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false }
      }
    },
    "candidateMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "proposed_public_update_id",
        "proposed_route",
        "source_url",
        "source_id",
        "source_adapter_id",
        "jurisdiction_ids",
        "topic_ids"
      ],
      "properties": {
        "candidate_id": { "type": "string", "minLength": 1 },
        "proposed_public_update_id": { "type": "string", "minLength": 1 },
        "proposed_route": { "type": "string", "minLength": 1 },
        "source_url": { "type": "string", "format": "uri" },
        "source_id": { "type": "string", "minLength": 1 },
        "source_adapter_id": { "type": "string", "minLength": 1 },
        "jurisdiction_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "topic_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "releaseGateItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "status", "note", "owner_role"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": [
            "ready_for_approval_review",
            "blocked",
            "needs_follow_up",
            "not_applicable"
          ]
        },
        "note": { "type": "string", "minLength": 1 },
        "owner_role": { "type": "string", "minLength": 1 }
      }
    },
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_export_gate_ready",
        "ready_for_public_export_approval",
        "publication_allowed",
        "public_export_allowed",
        "evidence_export_allowed",
        "client_use_allowed",
        "metadata_only",
        "stores_full_text",
        "requires_public_export_approval_decision",
        "requires_publication_release_approval",
        "requires_client_evidence_approval"
      ],
      "properties": {
        "public_export_gate_ready": { "type": "boolean", "const": true },
        "ready_for_public_export_approval": { "type": "boolean", "const": true },
        "publication_allowed": { "type": "boolean", "const": false },
        "public_export_allowed": { "type": "boolean", "const": false },
        "evidence_export_allowed": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "metadata_only": { "type": "boolean", "const": true },
        "stores_full_text": { "type": "boolean", "const": false },
        "requires_public_export_approval_decision": { "type": "boolean", "const": true },
        "requires_publication_release_approval": { "type": "boolean", "const": true },
        "requires_client_evidence_approval": { "type": "boolean", "const": true }
      }
    },
    "gateScope": {
      "type": "string",
      "const": "internal_public_export_release_gate"
    },
    "gateStatus": {
      "type": "string",
      "enum": ["pending_public_export_approval", "blocked", "superseded"]
    },
    "gateResult": {
      "type": "string",
      "enum": [
        "ready_for_public_export_approval",
        "blocked_pending_fixes",
        "rejected"
      ]
    },
    "gateRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "staging_preview_id",
        "publication_gate_decision_id",
        "publication_gate_packet_id",
        "draft_update_id",
        "draft_update_path",
        "gate_scope",
        "gate_status",
        "gate_result",
        "gate_summary",
        "release_gate_items",
        "candidate_metadata",
        "blockers_remaining",
        "next_required_step",
        "created_at",
        "updated_at",
        "gates",
        "safety"
      ],
      "properties": {
        "gate_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "staging_preview_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "publication_gate_decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "publication_gate_packet_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "draft_update_id": { "type": "string", "minLength": 1 },
        "draft_update_path": { "type": "string", "pattern": "^data/regulatory-updates/drafts/" },
        "gate_scope": { "$ref": "#/$defs/gateScope" },
        "gate_status": { "$ref": "#/$defs/gateStatus" },
        "gate_result": { "$ref": "#/$defs/gateResult" },
        "gate_summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "release_gate_items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/releaseGateItem" }
        },
        "candidate_metadata": { "$ref": "#/$defs/candidateMetadata" },
        "blockers_remaining": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "next_required_step": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" },
        "gates": { "$ref": "#/$defs/gateState" },
        "safety": { "$ref": "#/$defs/safetyFlags" }
      }
    }
  }
}
