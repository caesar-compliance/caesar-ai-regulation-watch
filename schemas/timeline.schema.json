{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/timeline.schema.json",
  "title": "Caesar AI Regulation Watch — Regulatory timeline",
  "description": "Curated milestone timeline for governance review. Not legal advice.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "timeline_id",
    "title",
    "jurisdiction_id",
    "source_ids",
    "events",
    "review_status",
    "legal_safe_note"
  ],
  "properties": {
    "timeline_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "jurisdiction_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "related_record_id": {
      "type": ["string", "null"],
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_-]*$"
      },
      "uniqueItems": true
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id",
          "date",
          "event_type",
          "title",
          "summary_for_review",
          "source_id",
          "verified_on_source",
          "review_status",
          "legal_safe_note"
        ],
        "properties": {
          "event_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "event_type": {
            "type": "string",
            "enum": [
              "publication",
              "entry_into_force",
              "deadline",
              "guidance",
              "implementation",
              "policy_announcement",
              "monitoring",
              "other"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary_for_review": {
            "type": "string",
            "minLength": 1
          },
          "source_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "verified_on_source": {
            "type": "boolean"
          },
          "review_status": {
            "type": "string",
            "enum": [
              "draft",
              "pending_review",
              "reviewed",
              "needs_update",
              "rejected_for_client_use",
              "archived"
            ]
          },
          "legal_safe_note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "review_status": {
      "type": "string",
      "enum": [
        "draft",
        "pending_review",
        "reviewed",
        "needs_update",
        "rejected_for_client_use",
        "archived"
      ]
    },
    "legal_safe_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
