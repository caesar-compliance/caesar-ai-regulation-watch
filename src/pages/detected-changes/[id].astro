---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReviewStatusBadge from "../../components/ReviewStatusBadge.astro";
import {
  getDetectedChanges,
  getDetectedChange,
  getSource,
  getJurisdiction,
  getWatcher,
  getSnapshots,
} from "../../lib/data";
import { humanizeId } from "../../lib/format";

export function getStaticPaths() {
  return getDetectedChanges().map((d) => ({
    params: { id: d.detected_change_id },
  }));
}

const { id } = Astro.params;
const change = getDetectedChange(id!);

if (!change) {
  return Astro.redirect("/detected-changes/");
}

const source = getSource(change.source_id);
const jurisdiction = getJurisdiction(change.jurisdiction_id);
const watcher = getWatcher(change.watcher_id);
const snapshots = getSnapshots();
const prev = snapshots.find((s) => s.snapshot_id === change.previous_snapshot_id);
const curr = snapshots.find((s) => s.snapshot_id === change.current_snapshot_id);
---

<BaseLayout title={change.detected_change_id} currentPath="/detected-changes/">
  <p><a href="/detected-changes/">← Detected changes</a></p>
  <h1>{change.detected_change_id}</h1>

  {
    change.simulation && (
      <div class="banner banner--warn" role="alert">
        <strong>Simulation only.</strong> This detected change was created from local fixtures for
        pipeline validation. It is not an official source update.
      </div>
    )
  }

  <div class="banner banner--review" role="note">
    <strong>Not legal advice.</strong> Pending human review. This entry does not verify regulatory
    content or approve client use.
  </div>

  <div class="card__meta" style="margin-bottom: 1rem;">
    <ReviewStatusBadge status={change.review_status} />
    <span class="badge badge--type">{humanizeId(change.change_type)}</span>
    <span class="badge">Significance: {change.significance_level}</span>
    {change.human_review_required && <span class="badge">Human review required</span>}
    {change.client_use_allowed === false && (
      <span class="badge badge--warn">Client use not allowed</span>
    )}
  </div>

  <dl class="meta-grid">
    <div><dt>Watcher</dt><dd><a href={`/watchers/${change.watcher_id}/`}>{change.watcher_id}</a></dd></div>
    <div>
      <dt>Source</dt>
      <dd>
        {source ? (
          <a href={`/sources/${source.source_id}/`}>{source.title}</a>
        ) : (
          change.source_id
        )}
      </dd>
    </div>
    <div>
      <dt>Jurisdiction</dt>
      <dd>
        {jurisdiction ? (
          <a href={`/jurisdictions/${jurisdiction.jurisdiction_id}/`}>{jurisdiction.name}</a>
        ) : (
          change.jurisdiction_id
        )}
      </dd>
    </div>
    <div><dt>Detected at</dt><dd>{change.detected_at}</dd></div>
    {change.adapter_id && (
      <div><dt>Adapter</dt><dd>{humanizeId(change.adapter_id)}</dd></div>
    )}
    <div>
      <dt>Official URL</dt>
      <dd class="mono" style="word-break: break-all;">
        {watcher?.official_url ?? source?.official_url ?? "—"}
      </dd>
    </div>
    <div>
      <dt>Changed fields</dt>
      <dd>{change.changed_fields.map((f) => humanizeId(f)).join(", ")}</dd>
    </div>
    <div>
      <dt>Review queue reason</dt>
      <dd>{humanizeId(change.review_queue_reason)}</dd>
    </div>
  </dl>

  <h2>Summary for review</h2>
  <div class="prose"><p>{change.change_summary_for_review}</p></div>

  {
    change.feed_entries_affected && change.feed_entries_affected.length > 0 && (
      <section>
        <h2>Feed entries affected (metadata only)</h2>
        <p class="card__excerpt">
          <small>Title/link/date only. No article body stored or fetched.</small>
        </p>
        <ul>
          {change.feed_entries_affected.map((e) => (
            <li>
              <strong>{e.title ?? e.entry_id}</strong>
              {e.link && (
                <>
                  {" "}
                  — <a href={e.link} target="_blank" rel="noopener noreferrer">link</a>
                </>
              )}
              {e.published_at && <small> ({e.published_at})</small>}
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    change.volatile_field_note && (
      <p class="card__excerpt">
        <small>{change.volatile_field_note}</small>
      </p>
    )
  }

  <section>
    <h2>Field value summary (no full page body)</h2>
    <div class="grid-2">
      <div>
        <h3>Previous values</h3>
        <dl class="meta-grid">
          {
            Object.entries(change.previous_value_summary).map(([k, v]) => (
              <div>
                <dt>{humanizeId(k)}</dt>
                <dd class="mono">{v}</dd>
              </div>
            ))
          }
        </dl>
      </div>
      <div>
        <h3>Current values</h3>
        <dl class="meta-grid">
          {
            Object.entries(change.current_value_summary).map(([k, v]) => (
              <div>
                <dt>{humanizeId(k)}</dt>
                <dd class="mono">{v}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <section>
    <h2>Snapshot comparison (metadata only)</h2>
    <p class="card__excerpt">
      <small>No full page bodies stored. Compare hashes and HTTP metadata on the official site.</small>
    </p>
    <div class="grid-2">
      {
        (prev || change.previous_snapshot_summary) && (
          <div>
            <h3>Previous</h3>
            <dl class="meta-grid">
              <div>
                <dt>ID</dt>
                <dd class="mono">{change.previous_snapshot_id}</dd>
              </div>
              {
                Object.entries(change.previous_snapshot_summary ?? {}).map(([k, v]) => (
                  <div>
                    <dt>{humanizeId(k)}</dt>
                    <dd class="mono">{String(v ?? "—")}</dd>
                  </div>
                ))
              }
            </dl>
          </div>
        )
      }
      {
        (curr || change.current_snapshot_summary) && (
          <div>
            <h3>Current</h3>
            <dl class="meta-grid">
              <div>
                <dt>ID</dt>
                <dd class="mono">{change.current_snapshot_id}</dd>
              </div>
              {
                Object.entries(change.current_snapshot_summary ?? {}).map(([k, v]) => (
                  <div>
                    <dt>{humanizeId(k)}</dt>
                    <dd class="mono">{String(v ?? "—")}</dd>
                  </div>
                ))
              }
            </dl>
          </div>
        )
      }
    </div>
  </section>

  <p class="prose"><small>{change.legal_safe_note}</small></p>
</BaseLayout>
