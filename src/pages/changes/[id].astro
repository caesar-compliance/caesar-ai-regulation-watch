---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReviewBanner from "../../components/ReviewBanner.astro";
import ReviewStatusBadge from "../../components/ReviewStatusBadge.astro";
import {
  getChanges,
  getChange,
  getRecord,
  getSource,
  getJurisdiction,
  getTaxonomies,
  taxonomyLabel,
} from "../../lib/data";
import { formatDate } from "../../lib/format";

export function getStaticPaths() {
  return getChanges().map((c) => ({
    params: { id: c.change_id },
  }));
}

const { id } = Astro.params;
const change = getChange(id!);

if (!change) {
  return Astro.redirect("/changes/");
}

const record = getRecord(change.related_record_id);
const source = getSource(change.source_id);
const jurisdiction = getJurisdiction(change.jurisdiction_id);
const taxonomies = getTaxonomies();
---

<BaseLayout title={change.change_id} currentPath="/changes/">
  <p><a href="/changes/">← Changes</a></p>
  <h1>{change.change_id}</h1>
  <div class="card__meta" style="margin-bottom: 1rem;">
    <span class="badge badge--type">
      {taxonomyLabel(taxonomies, "change-types", change.change_type)}
    </span>
    <span class="badge badge--confidence">{change.confidence_level} confidence</span>
    <ReviewStatusBadge status={change.review_status} />
  </div>

  <ReviewBanner
    reviewStatus={change.review_status}
    recordOrigin={change.record_origin}
    requiresHumanReview={change.requires_human_review}
    sample={change.record_origin === "manual_sample"}
  />

  <dl class="meta-grid">
    <div><dt>Detected (sample)</dt><dd>{formatDate(change.detected_date)}</dd></div>
    <div>
      <dt>Jurisdiction</dt>
      <dd>
        {jurisdiction ? (
          <a href={`/jurisdictions/${jurisdiction.jurisdiction_id}/`}>{jurisdiction.name}</a>
        ) : (
          change.jurisdiction_id
        )}
      </dd>
    </div>
    <div>
      <dt>Related record</dt>
      <dd>
        {record ? (
          <a href={`/records/${record.record_id}/`}>{record.title}</a>
        ) : (
          change.related_record_id
        )}
      </dd>
    </div>
    <div>
      <dt>Source</dt>
      <dd>
        {source ? (
          <a href={`/sources/${source.source_id}/`}>{source.title}</a>
        ) : (
          change.source_id
        )}
      </dd>
    </div>
  </dl>

  <h2>Change summary for review</h2>
  <div class="prose"><p>{change.change_summary_for_review}</p></div>

  <h2>Possible impact</h2>
  <div class="prose"><p>{change.possible_impact}</p></div>

  {
    change.requires_human_review && (
      <div class="banner banner--review" role="alert">
        <strong>Human review required.</strong> Do not treat this sample as confirmation that a substantive
        legal change occurred.
      </div>
    )
  }

  <h2>Legal-safe note</h2>
  <div class="prose"><p>{change.legal_safe_note}</p></div>
</BaseLayout>
