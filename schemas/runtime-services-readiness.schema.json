{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/runtime-services-readiness.schema.json",
  "title": "Caesar AI Regulation Watch — Runtime services readiness export",
  "description": "Public-safe external services onboarding readiness. No secrets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "checked_at",
    "account_allocation",
    "live_ingestion_enabled",
    "scheduled_monitoring_enabled",
    "network_execution_enabled",
    "supabase_key_mode",
    "supabase_publishable_key_present",
    "supabase_secret_key_present",
    "supabase_legacy_anon_key_present",
    "supabase_legacy_service_role_key_present",
    "readiness",
    "services",
    "safety_flags",
    "local_env_files",
    "next_required_action",
    "public_note"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "onboarding_incomplete",
        "partial",
        "ready_for_manual_schema_review",
        "ready_for_manual_worker_review",
        "local_credentials_present_safety_disabled",
        "unsafe_local_flags"
      ]
    },
    "checked_at": { "type": "string", "format": "date-time" },
    "account_allocation": { "type": "string", "const": "account_a" },
    "live_ingestion_enabled": { "type": "boolean", "const": false },
    "scheduled_monitoring_enabled": { "type": "boolean", "const": false },
    "network_execution_enabled": { "type": "boolean", "const": false },
    "supabase_key_mode": {
      "type": "string",
      "enum": ["new", "legacy", "missing", "mixed"]
    },
    "supabase_publishable_key_present": { "type": "boolean" },
    "supabase_secret_key_present": { "type": "boolean" },
    "supabase_legacy_anon_key_present": { "type": "boolean" },
    "supabase_legacy_service_role_key_present": { "type": "boolean" },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supabase_project_ready",
        "supabase_new_keys_ready",
        "supabase_legacy_keys_ready",
        "supabase_key_mode",
        "supabase_publishable_key_present",
        "supabase_secret_key_present",
        "supabase_legacy_anon_key_present",
        "supabase_legacy_service_role_key_present",
        "cloudflare_ready",
        "github_optional_ready",
        "uptime_manual_setup_required"
      ],
      "properties": {
        "supabase_project_ready": { "type": "boolean" },
        "supabase_new_keys_ready": { "type": "boolean" },
        "supabase_legacy_keys_ready": { "type": "boolean" },
        "supabase_key_mode": {
          "type": "string",
          "enum": ["new", "legacy", "missing", "mixed"]
        },
        "supabase_publishable_key_present": { "type": "boolean" },
        "supabase_secret_key_present": { "type": "boolean" },
        "supabase_legacy_anon_key_present": { "type": "boolean" },
        "supabase_legacy_service_role_key_present": { "type": "boolean" },
        "cloudflare_ready": { "type": "boolean" },
        "github_optional_ready": { "type": "boolean" },
        "uptime_manual_setup_required": { "type": "boolean", "const": true }
      }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["service", "role", "fields"],
        "properties": {
          "service": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["key", "present"],
              "properties": {
                "key": { "type": "string", "minLength": 1 },
                "present": { "type": "boolean" }
              }
            }
          }
        }
      }
    },
    "safety_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "regwatch_apply_supabase_schema",
        "regwatch_enable_live_ingestion",
        "regwatch_enable_scheduled_monitoring",
        "regwatch_enable_network_execution",
        "cloudflare_enable_worker_deploy",
        "cloudflare_enable_cron_trigger"
      ],
      "properties": {
        "regwatch_apply_supabase_schema": { "type": "boolean", "const": false },
        "regwatch_enable_live_ingestion": { "type": "boolean", "const": false },
        "regwatch_enable_scheduled_monitoring": { "type": "boolean", "const": false },
        "regwatch_enable_network_execution": { "type": "boolean", "const": false },
        "cloudflare_enable_worker_deploy": { "type": "boolean", "const": false },
        "cloudflare_enable_cron_trigger": { "type": "boolean", "const": false }
      }
    },
    "local_env_files": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "env_runtime_local",
        "env_cloudflare_local",
        "env_github_local"
      ],
      "properties": {
        "env_runtime_local": { "type": "boolean" },
        "env_cloudflare_local": { "type": "boolean" },
        "env_github_local": { "type": "boolean" }
      }
    },
    "next_required_action": { "type": "string", "minLength": 1 },
    "public_note": { "type": "string", "minLength": 1 }
  }
}
