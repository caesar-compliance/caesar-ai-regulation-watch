---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FilterBar from "../../components/FilterBar.astro";
import ReviewStatusBadge from "../../components/ReviewStatusBadge.astro";
import { getChanges, getTaxonomies, taxonomyLabel } from "../../lib/data";
import { changeFilterOptions, groupByJurisdiction } from "../../lib/filters";
import { formatDate, truncate } from "../../lib/format";

const changes = getChanges();
const taxonomies = getTaxonomies();
const opts = changeFilterOptions();
const grouped = groupByJurisdiction(changes);
---

<BaseLayout title="Changes" currentPath="/changes/">
  <div data-filter-page>
    <h1>Regulatory changes</h1>
    <p class="lead">
      Manual sample change records for governance review. Not automated detections — human verification
      required.
    </p>

    <div class="banner banner--sample" role="note">
      <strong>Sample data only.</strong> Subscribe via <a href="/feeds/changes.xml">RSS</a> (samples). Future
      watcher output will use <code>record_origin: future_watcher_output</code>.
    </div>

    <FilterBar
      filters={[
        { key: "jurisdiction", label: "Jurisdiction", options: opts.jurisdiction },
        { key: "change-type", label: "Change type", options: opts.changeType },
        { key: "confidence", label: "Confidence", options: opts.confidence },
        { key: "review", label: "Review", options: opts.review },
        {
          key: "human-review",
          label: "Human review",
          options: opts.humanReview,
        },
      ]}
    />

    {
      grouped.map((group) => (
        <section class="group-section">
          <h2 class="group-section__title">
            <a href={`/jurisdictions/${group.id}/`}>{group.name}</a>
          </h2>
          <div class="table-wrap">
            <table class="data-table" data-filter-list>
              <thead>
                <tr>
                  <th>Change</th>
                  <th>Date</th>
                  <th>Type</th>
                  <th>Confidence</th>
                  <th>Review</th>
                  <th>Human review</th>
                </tr>
              </thead>
              <tbody>
                {group.items.map((c) => (
                  <tr
                    class="filter-item"
                    data-filter-item
                    data-jurisdiction={c.jurisdiction_id}
                    data-change-type={c.change_type}
                    data-confidence={c.confidence_level}
                    data-review={c.review_status}
                    data-human-review={String(c.requires_human_review)}
                  >
                    <td>
                      <a href={`/changes/${c.change_id}/`}>{c.change_id}</a>
                      <br />
                      <small>{truncate(c.change_summary_for_review, 72)}</small>
                    </td>
                    <td>{formatDate(c.detected_date)}</td>
                    <td>{taxonomyLabel(taxonomies, "change-types", c.change_type)}</td>
                    <td>
                      <span class="badge badge--confidence">{c.confidence_level}</span>
                    </td>
                    <td>
                      <ReviewStatusBadge status={c.review_status} />
                    </td>
                    <td>{c.requires_human_review ? "Required" : "—"}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      ))
    }
  </div>

  <script is:inline src="/scripts/filter-list.js"></script>
</BaseLayout>
