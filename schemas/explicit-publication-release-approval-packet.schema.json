{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/explicit-publication-release-approval-packet.schema.json",
  "title": "Caesar AI Regulation Watch — Explicit publication release approval packet",
  "description": "Explicit publication release approval packet. Prepares authorization review only — not publication.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "explicit_publication_release_approval_packets_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_live_collection",
    "no_scheduled_monitoring",
    "packets"
  ],
  "properties": {
    "explicit_publication_release_approval_packets_id": {
      "type": "string",
      "pattern": "^explicit-publication-release-approval-packets-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_collection": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "packets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/packetRecord" }
    }
  },
  "$defs": {
    "gateState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false }
      }
    },
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "explicit_publication_approval_packet_created",
        "control_tower_authorization_required",
        "operator_confirmation_required",
        "publication_release_authorized",
        "publication_allowed",
        "public_export_allowed",
        "public_data_inclusion_allowed",
        "public_update_route_created",
        "evidence_export_allowed",
        "client_use_allowed",
        "metadata_only",
        "stores_full_text",
        "requires_separate_client_evidence_approval"
      ],
      "properties": {
        "explicit_publication_approval_packet_created": { "type": "boolean" },
        "control_tower_authorization_required": { "type": "boolean", "const": true },
        "operator_confirmation_required": { "type": "boolean", "const": true },
        "publication_release_authorized": { "type": "boolean", "const": false },
        "publication_allowed": { "type": "boolean", "const": false },
        "public_export_allowed": { "type": "boolean", "const": false },
        "public_data_inclusion_allowed": { "type": "boolean", "const": false },
        "public_update_route_created": { "type": "boolean", "const": false },
        "evidence_export_allowed": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "metadata_only": { "type": "boolean", "const": true },
        "stores_full_text": { "type": "boolean", "const": false },
        "requires_separate_client_evidence_approval": { "type": "boolean", "const": true }
      }
    },
    "packetScope": {
      "type": "string",
      "const": "explicit_publication_release_approval_packet"
    },
    "packetStatus": {
      "type": "string",
      "enum": ["awaiting_control_tower_authorization", "blocked", "superseded"]
    },
    "operatorConfirmationStatus": {
      "type": "string",
      "enum": ["pending", "not_requested", "superseded"]
    },
    "preReleaseCheckStatus": {
      "type": "string",
      "enum": ["ready_for_authorization_review", "blocked", "needs_follow_up"]
    },
    "preReleaseCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "status", "note", "owner_role"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/preReleaseCheckStatus" },
        "note": { "type": "string", "minLength": 1 },
        "owner_role": { "type": "string", "minLength": 1 }
      }
    },
    "packetRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "public_update_release_decision_id",
        "public_export_approval_decision_id",
        "release_gate_id",
        "staging_preview_id",
        "draft_update_id",
        "draft_update_path",
        "proposed_public_update_id",
        "proposed_route",
        "packet_scope",
        "packet_status",
        "operator_confirmation_status",
        "approval_summary",
        "pre_release_checks",
        "authorization_requirements",
        "blockers_remaining",
        "next_required_step",
        "created_at",
        "updated_at",
        "gates",
        "safety"
      ],
      "properties": {
        "packet_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "public_update_release_decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "public_export_approval_decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "release_gate_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "staging_preview_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "draft_update_id": { "type": "string", "minLength": 1 },
        "draft_update_path": { "type": "string", "pattern": "^data/regulatory-updates/drafts/" },
        "proposed_public_update_id": { "type": "string", "minLength": 1 },
        "proposed_route": { "type": "string", "pattern": "^/updates/" },
        "packet_scope": { "$ref": "#/$defs/packetScope" },
        "packet_status": { "$ref": "#/$defs/packetStatus" },
        "operator_confirmation_status": { "$ref": "#/$defs/operatorConfirmationStatus" },
        "approval_summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "pre_release_checks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/preReleaseCheck" }
        },
        "authorization_requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "blockers_remaining": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "next_required_step": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" },
        "gates": { "$ref": "#/$defs/gateState" },
        "safety": { "$ref": "#/$defs/safetyFlags" }
      }
    }
  }
}
