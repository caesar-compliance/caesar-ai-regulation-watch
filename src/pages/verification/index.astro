---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReviewStatusBadge from "../../components/ReviewStatusBadge.astro";
import {
  getRecordContentVerifications,
  getSourceIdentityVerifications,
  getUrlChecks,
  getUrlCheckBatches,
  getSources,
} from "../../lib/data";
import {
  formatDate,
  verificationCheckLabel,
  urlCheckResultLabel,
  contentReviewStatusLabel,
  humanizeId,
} from "../../lib/format";

const identityVerifications = getSourceIdentityVerifications();
const recordVerifications = getRecordContentVerifications();
const urlChecks = getUrlChecks();
const urlBatches = getUrlCheckBatches();
const sources = getSources();
const sourceMap = Object.fromEntries(sources.map((s) => [s.source_id, s]));

const identityReviewed = identityVerifications.filter(
  (v) => v.review_status_after_check === "reviewed_source_identity_only",
);
const identityNeedsHuman = identityVerifications.filter(
  (v) => v.review_status_after_check === "needs_human_review",
);
const recordNotChecked = recordVerifications.filter((v) => v.check_result === "not_checked");

const urlReachable = urlChecks.filter((c) => c.check_result === "reachable").length;
const urlRedirected = urlChecks.filter((c) => c.check_result === "reachable_redirected").length;
const urlUnreachable = urlChecks.filter((c) => c.check_result === "unreachable").length;
const urlNetworkErrors = urlChecks.filter((c) =>
  ["timeout", "dns_error", "network_error"].includes(c.check_result),
).length;
const urlNotChecked = urlChecks.filter(
  (c) => c.check_result === "not_checked" || c.check_result === "uncertain",
).length;

const unresolvedUrlIssues =
  urlUnreachable + urlNetworkErrors + urlNotChecked;

function pageHrefForCheck(check: (typeof urlChecks)[0]) {
  if (check.item_type === "source") return `/sources/${check.item_id}/`;
  if (check.item_type === "law" || check.item_type === "guidance") {
    return `/records/${check.item_id}/`;
  }
  return "/verification/";
}
---

<BaseLayout title="Verification" currentPath="/verification/">
  <h1>Verification</h1>
  <p class="lead">
    Three separate layers: technical URL reachability, official source identity review, and
    record content/legal review. None of these imply client-use approval.
  </p>

  <div class="banner banner--review" role="note">
    <strong>v0.6.2.</strong> Source identity reviewed: {identityReviewed.length} of{" "}
    {identityVerifications.length}. Record content review: {recordNotChecked.length} still not
    checked. Client use allowed: 0. See <a href="/docs/URL_REMEDIATION_LOG.md">URL remediation log</a>{" "}
    (repository).
  </div>

  <h2>1. Technical URL checks</h2>
  <p class="card__excerpt">
    Automated HEAD/GET from <code>npm run check:urls</code> (not run in CI). Last batch:{" "}
    {urlBatches[0]?.url_check_batch_id ?? "—"}.
  </p>
  <dl class="meta-grid">
    <div><dt>Total checked</dt><dd>{urlChecks.length}</dd></div>
    <div><dt>Reachable</dt><dd>{urlReachable}</dd></div>
    <div><dt>Redirected</dt><dd>{urlRedirected}</dd></div>
    <div><dt>Unreachable (HTTP)</dt><dd>{urlUnreachable}</dd></div>
    <div><dt>Timeout / network / DNS</dt><dd>{urlNetworkErrors}</dd></div>
    <div><dt>Unresolved issues</dt><dd>{unresolvedUrlIssues}</dd></div>
    <div>
      <dt>Content review (URL batch)</dt>
      <dd>{urlChecks.filter((c) => c.content_review_status === "not_reviewed").length} not reviewed</dd>
    </div>
  </dl>
  <p>
    <a href="/data/url-checks.json">url-checks.json</a>
  </p>

  {
    identityNeedsHuman.length > 0 && (
      <section>
        <h3>Sources with technical or access issues</h3>
        <ul class="card-list">
          {identityNeedsHuman.map((v) => (
            <li class="card">
              <a href={`/sources/${v.source_id}/`}>{sourceMap[v.source_id]?.title ?? v.source_id}</a>
              <p class="card__excerpt">{verificationCheckLabel(v.check_result)} · {v.notes}</p>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <h2>2. Source identity review</h2>
  <p class="card__excerpt">
    Confirms official authority URL and domain only. Does <strong>not</strong> review summaries,
    dates, or legal accuracy.
  </p>
  <dl class="meta-grid">
    <div><dt>Sources reviewed (identity only)</dt><dd>{identityReviewed.length}</dd></div>
    <div><dt>Needs human review</dt><dd>{identityNeedsHuman.length}</dd></div>
    <div><dt>Client use allowed</dt><dd>0</dd></div>
  </dl>

  <table class="data-table">
    <thead>
      <tr>
        <th>Source</th>
        <th>Identity check</th>
        <th>Status</th>
        <th>URL checked</th>
      </tr>
    </thead>
    <tbody>
      {identityVerifications.map((v) => (
        <tr>
          <td>
            <a href={`/sources/${v.source_id}/`}>{sourceMap[v.source_id]?.title ?? v.source_id}</a>
          </td>
          <td>{verificationCheckLabel(v.check_result)}</td>
          <td>{humanizeId(v.review_status_after_check)}</td>
          <td>
            <a href={v.official_url_checked} target="_blank" rel="noopener noreferrer">
              Link ↗
            </a>
          </td>
        </tr>
      ))}
    </tbody>
  </table>

  <h2>3. Record content review (not completed)</h2>
  <p class="card__excerpt">
    Prior batch tracks curated <strong>records</strong> awaiting full human review on official
    sources. No record marked content-reviewed in this release.
  </p>
  <dl class="meta-grid">
    <div><dt>Record verifications pending</dt><dd>{recordNotChecked.length}</dd></div>
    <div><dt>Content-reviewed records</dt><dd>0</dd></div>
    <div><dt>Client use allowed</dt><dd>0</dd></div>
  </dl>

  {
    recordNotChecked.length > 0 && (
      <table class="data-table">
        <thead>
          <tr>
            <th>Record</th>
            <th>Check result</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          {recordNotChecked.map((v) => (
            <tr>
              <td>
                <a href={`/records/${v.item_id}/`}>{v.item_id}</a>
              </td>
              <td>{verificationCheckLabel(v.check_result)}</td>
              <td>{formatDate(v.verified_date)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )
  }

  <p>
    <a href="/data/verifications.json">verifications.json</a> ·{" "}
    <a href="/review-queue/">Human review queue →</a>
  </p>

  {
    urlChecks.length > 0 && (
      <section>
        <h2>Technical URL detail table</h2>
        <table class="data-table">
          <thead>
            <tr>
              <th>Item</th>
              <th>Technical result</th>
              <th>HTTP</th>
              <th>Content review</th>
            </tr>
          </thead>
          <tbody>
            {urlChecks.map((c) => (
              <tr>
                <td>
                  <a href={pageHrefForCheck(c)}>{c.item_id}</a>
                </td>
                <td>{urlCheckResultLabel(c.check_result)}</td>
                <td>{c.http_status ?? "—"}</td>
                <td>{contentReviewStatusLabel(c.content_review_status)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )
  }
</BaseLayout>
