---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MetricsStrip from "../../components/MetricsStrip.astro";
import TrackerChoroplethMap from "../../components/TrackerChoroplethMap.astro";
import TrackerFilterForm from "../../components/TrackerFilterForm.astro";
import UpdateFeedCard from "../../components/UpdateFeedCard.astro";
import {
  getAutomationFirstMetrics,
  getTrackerTopics,
  filterCountryStatuses,
  filterRegulatoryUpdates,
  getCountryStatuses,
  getRegulatoryUpdates,
  getEnrichedCountryStatuses,
} from "../../lib/tracker-data";
import {
  getMonitoringStatus,
  getDetectedChanges,
  getReviewCandidates,
  getTrackerSummary,
} from "../../lib/runtime-monitoring-data";
import {
  getReviewQueueSummary,
  getReviewQueueCards,
  getSourceFreshnessSummary,
  getOperatorReviewSummary,
} from "../../lib/regulation-review-queue";

const metrics = getAutomationFirstMetrics();
const monitoring = getMonitoringStatus();
const trackerSummary = getTrackerSummary();
const allDetectedChanges = getDetectedChanges();
const detectedChanges = allDetectedChanges.slice(0, 5);
const allReviewCandidates = getReviewCandidates();
const reviewCandidates = allReviewCandidates;
const detectedChangesCount =
  monitoring.detected_changes_count ?? allDetectedChanges.length;
const reviewCandidatesCount =
  monitoring.review_candidates_count ?? allReviewCandidates.length;
const reviewQueueSummary = getReviewQueueSummary();
const reviewQueueCards = getReviewQueueCards();
const freshnessSummary = getSourceFreshnessSummary();
const operatorSummary = getOperatorReviewSummary();
const automatedRssCount =
  monitoring.automated_rss_source_count ?? monitoring.automated_source_count ?? 0;
const topics = getTrackerTopics();
const allStatuses = getCountryStatuses();
const enrichedStatuses = getEnrichedCountryStatuses();
const regions = [...new Set(allStatuses.map((c) => c.region))].sort();

const region = Astro.url.searchParams.get("region");
const status = Astro.url.searchParams.get("status");
const topic = Astro.url.searchParams.get("topic");

const filteredStatuses = filterCountryStatuses({ region, status, topic });
const allUpdates = getRegulatoryUpdates();
const adapterCount = allUpdates.filter(
  (u) => u.automation_method === "offline_metadata_adapter",
).length;
const automationMethod = Astro.url.searchParams.get("automation_method");

const latestUpdates = filterRegulatoryUpdates({
  region,
  status,
  topic,
  automationMethod,
}).slice(0, 8);
---

<BaseLayout
  title="Global tracker"
  currentPath="/tracker/"
  description="Automation-first AI regulation tracker skeleton — map, country status, and source-linked updates."
>
  <h1>Global AI regulation tracker</h1>
  <p class="lead">
    Automation-first public tracker with choropleth-style status panel (T050) and source-linked
    updates from curated pilot data — not legal advice and not complete global coverage.
  </p>

  <div class="banner banner--automation" role="note">
    <strong>Technical tracker pilot.</strong> Manual seeds plus {adapterCount} offline metadata
    adapter record(s) from repository monitoring data — no live scraping. Evidence and client-use
    gates remain closed. Human review is optional for future premium workflows.
  </div>

  <MetricsStrip metrics={metrics} />

  <section class="tracker-section">
    <h2>Product tracker dashboard (T080)</h2>
    <div class="metrics-strip metrics-strip--monitoring">
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">{trackerSummary.countries_covered ?? allStatuses.length}</span>
        <span class="metrics-strip__label">Countries covered</span>
      </div>
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">{trackerSummary.regulations_tracked ?? 0}</span>
        <span class="metrics-strip__label">Regulations tracked</span>
      </div>
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">{monitoring.monitored_source_count ?? 0}</span>
        <span class="metrics-strip__label">Monitored sources</span>
      </div>
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">{automatedRssCount}</span>
        <span class="metrics-strip__label">Automated RSS</span>
      </div>
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">{detectedChangesCount}</span>
        <span class="metrics-strip__label">Detected changes</span>
      </div>
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">{reviewCandidatesCount}</span>
        <span class="metrics-strip__label">Review candidates</span>
      </div>
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">{monitoring.worker_deployed ? "yes" : "no"}</span>
        <span class="metrics-strip__label">Worker (dev)</span>
      </div>
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">off</span>
        <span class="metrics-strip__label">Scheduled monitoring</span>
      </div>
    </div>
    <p>
      <a href="/map/">Interactive map</a> · <a href="/countries/">Country cards</a> ·{" "}
      <a href="/review-queue/">Review queue</a> · <a href="/runtime-health/">Runtime health</a> ·{" "}
      <a href="/data/tracker-summary.json">tracker-summary.json</a>
    </p>
  </section>

  <section class="tracker-section">
    <h2>Review queue &amp; source freshness (T081)</h2>
    <div class="metrics-strip metrics-strip--monitoring">
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">{reviewQueueSummary.high_priority ?? 0}</span>
        <span class="metrics-strip__label">High priority</span>
      </div>
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">{reviewQueueSummary.review_required ?? 0}</span>
        <span class="metrics-strip__label">Review required</span>
      </div>
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">{freshnessSummary.fresh ?? 0}</span>
        <span class="metrics-strip__label">Fresh sources</span>
      </div>
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">{freshnessSummary.stale ?? 0}</span>
        <span class="metrics-strip__label">Stale sources</span>
      </div>
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">{operatorSummary.decision_count ?? 0}</span>
        <span class="metrics-strip__label">Operator decisions</span>
      </div>
      <div class="metrics-strip__item">
        <span class="metrics-strip__value">off</span>
        <span class="metrics-strip__label">Cron</span>
      </div>
    </div>
    {
      reviewQueueCards.length > 0 ? (
        <ul>
          {reviewQueueCards.slice(0, 5).map((c) => (
            <li>
              <strong>{c.priority}</strong> — {c.title} ({c.review_status},{" "}
              <a href={`/jurisdictions/${c.jurisdiction_id}/`}>{c.jurisdiction_id}</a>)
            </li>
          ))}
        </ul>
      ) : (
        <p>No review queue cards in export.</p>
      )
    }
    <p>
      <a href="/review-queue/">Full regulation review queue →</a>
    </p>
    {
      reviewCandidates.length > 0 && (
        <section>
          <h3>Raw review candidates (backend export)</h3>
          <ul>
            {reviewCandidates.slice(0, 5).map((c) => (
              <li>
                {c.proposed_title ?? "Untitled"} — <em>{c.candidate_status}</em> (review required)
              </li>
            ))}
          </ul>
        </section>
      )
    }
    {
      detectedChanges.length > 0 && (
        <ul>
          {detectedChanges.map((c) => (
            <li>
              <strong>{c.change_type}</strong> — {c.change_summary} (
              <code>{c.source_key}</code>, review required)
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <section class="tracker-section">
    <h2>Filters</h2>
    <TrackerFilterForm
      action="/tracker/"
      regions={regions}
      topics={topics}
      current={{ region, status, topic }}
    />
  </section>

  <section class="tracker-section">
    <h2>Regulation status map</h2>
    <TrackerChoroplethMap
      items={
        filteredStatuses.length
          ? enrichedStatuses.filter((e) =>
              filteredStatuses.some((f) => f.jurisdiction_id === e.jurisdiction_id),
            )
          : enrichedStatuses
      }
    />
  </section>

  <section class="tracker-section">
    <h2>
      Latest updates
      <a href="/updates/" class="tracker-section__more">Full feed →</a>
    </h2>
    {
      latestUpdates.length === 0 ? (
        <p>No updates match the current filters.</p>
      ) : (
        <div class="update-feed-list">
          {latestUpdates.map((u) => (
            <UpdateFeedCard update={u} />
          ))}
        </div>
      )
    }
  </section>

  <section class="tracker-section">
    <h2>
      Country status list
      <a href="/countries/" class="tracker-section__more">All countries →</a>
      <a href="/compare/" class="tracker-section__more">Compare →</a>
    </h2>
    <p>
      Showing {filteredStatuses.length} of {allStatuses.length} pilot jurisdictions. Average maturity
      index {metrics.average_regulation_maturity_score ?? "—"} (heuristic tracker metadata — not
      legal certainty).
    </p>
  </section>
</BaseLayout>
