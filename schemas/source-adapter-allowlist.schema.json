{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/source-adapter-allowlist.schema.json",
  "title": "Caesar AI Regulation Watch — Source adapter allowlist",
  "description": "Manual-gated registry for future RSS/API metadata adapters. Not live collection. Not legal advice.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_adapter_allowlist_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_live_collection",
    "no_scheduled_monitoring",
    "adapters"
  ],
  "properties": {
    "source_adapter_allowlist_id": {
      "type": "string",
      "pattern": "^source-adapter-allowlist-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_collection": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "adapters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/adapterEntry" }
    }
  },
  "$defs": {
    "adapterEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter_id",
        "source_id",
        "source_name",
        "jurisdiction_ids",
        "region",
        "source_type",
        "adapter_kind",
        "status",
        "collection_mode",
        "allowed_host",
        "paywall_login_required",
        "captcha_or_waf_risk",
        "stores_full_text",
        "stores_metadata_only",
        "legal_text_publication_allowed",
        "schedule_enabled",
        "broad_crawl_allowed",
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed",
        "owner_review_required",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "adapter_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "source_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "source_name": { "type": "string", "minLength": 1 },
        "jurisdiction_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
        },
        "region": { "type": "string", "minLength": 1 },
        "source_type": {
          "type": "string",
          "enum": ["rss", "atom", "api", "webpage_metadata", "manual"]
        },
        "adapter_kind": {
          "type": "string",
          "enum": [
            "rss_metadata",
            "atom_metadata",
            "api_metadata",
            "manual_seed",
            "disabled"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "disabled",
            "draft",
            "manual_review_ready",
            "approved_for_manual_run"
          ]
        },
        "collection_mode": {
          "type": "string",
          "enum": [
            "fixture_only",
            "manual_network_disabled",
            "manual_network_approved"
          ]
        },
        "endpoint_url": { "type": "string", "format": "uri" },
        "source_url": { "type": "string", "format": "uri" },
        "allowed_host": { "type": "string", "minLength": 1 },
        "robots_policy_note": { "type": "string" },
        "paywall_login_required": { "type": "boolean" },
        "captcha_or_waf_risk": { "type": "boolean" },
        "stores_full_text": { "type": "boolean", "const": false },
        "stores_metadata_only": { "type": "boolean", "const": true },
        "legal_text_publication_allowed": { "type": "boolean", "const": false },
        "schedule_enabled": { "type": "boolean", "const": false },
        "broad_crawl_allowed": { "type": "boolean", "const": false },
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false },
        "owner_review_required": { "type": "boolean" },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" }
      },
      "oneOf": [
        { "required": ["endpoint_url"] },
        { "required": ["source_url"] }
      ],
      "allOf": [
        {
          "if": {
            "properties": { "collection_mode": { "const": "manual_network_approved" } },
            "required": ["collection_mode"]
          },
          "then": {
            "properties": { "status": { "const": "approved_for_manual_run" } }
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "approved_for_manual_run" } },
            "required": ["status"]
          },
          "then": {
            "properties": { "collection_mode": { "const": "manual_network_approved" } }
          }
        }
      ]
    }
  }
}
