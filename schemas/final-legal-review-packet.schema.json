{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/final-legal-review-packet.schema.json",
  "title": "Caesar AI Regulation Watch — Final legal review packet",
  "description": "Internal final legal review packet. Not approval. Not publication. Not final source verification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "final_legal_review_packets_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_live_collection",
    "no_scheduled_monitoring",
    "packets"
  ],
  "properties": {
    "final_legal_review_packets_id": {
      "type": "string",
      "pattern": "^final-legal-review-packets-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_collection": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "packets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/packetRecord" }
    }
  },
  "$defs": {
    "gateState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false }
      }
    },
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "final_legal_approval_completed",
        "final_source_verification_completed",
        "publication_allowed",
        "public_export_allowed",
        "evidence_export_allowed",
        "metadata_only",
        "stores_full_text",
        "requires_final_approval_before_publication"
      ],
      "properties": {
        "final_legal_approval_completed": { "type": "boolean", "const": false },
        "final_source_verification_completed": { "type": "boolean", "const": false },
        "publication_allowed": { "type": "boolean", "const": false },
        "public_export_allowed": { "type": "boolean", "const": false },
        "evidence_export_allowed": { "type": "boolean", "const": false },
        "metadata_only": { "type": "boolean", "const": true },
        "stores_full_text": { "type": "boolean", "const": false },
        "requires_final_approval_before_publication": { "type": "boolean", "const": true }
      }
    },
    "packetScope": {
      "type": "string",
      "const": "internal_final_legal_review_packet"
    },
    "packetStatus": {
      "type": "string",
      "enum": ["pending_final_legal_review", "blocked", "superseded"]
    },
    "reviewStage": {
      "type": "string",
      "const": "pre_publication_internal_review"
    },
    "legalReviewItemStatus": {
      "type": "string",
      "enum": ["pending", "needs_follow_up", "blocked", "local_metadata_available"]
    },
    "legalReviewItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "status", "reviewer_role"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/legalReviewItemStatus" },
        "note": { "type": "string", "maxLength": 500 },
        "reviewer_role": { "type": "string", "minLength": 1 }
      }
    },
    "packetRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "draft_update_id",
        "draft_update_path",
        "source_verification_result_id",
        "checklist_id",
        "promotion_id",
        "decision_id",
        "revision_id",
        "readiness_id",
        "packet_scope",
        "packet_status",
        "review_stage",
        "legal_review_items",
        "blockers_remaining",
        "next_required_step",
        "created_at",
        "updated_at",
        "gates",
        "safety"
      ],
      "properties": {
        "packet_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "draft_update_id": { "type": "string", "minLength": 1 },
        "draft_update_path": { "type": "string", "pattern": "^data/regulatory-updates/drafts/" },
        "source_verification_result_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "checklist_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "promotion_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "decision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "revision_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "readiness_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "packet_scope": { "$ref": "#/$defs/packetScope" },
        "packet_status": { "$ref": "#/$defs/packetStatus" },
        "review_stage": { "$ref": "#/$defs/reviewStage" },
        "legal_review_items": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/legalReviewItem" }
        },
        "blockers_remaining": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "next_required_step": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" },
        "gates": { "$ref": "#/$defs/gateState" },
        "safety": { "$ref": "#/$defs/safetyFlags" }
      }
    }
  }
}
