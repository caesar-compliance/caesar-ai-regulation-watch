---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SourceCard from "../../components/SourceCard.astro";
import { getSources } from "../../lib/data";

const sources = getSources();
---

<BaseLayout title="Official sources" currentPath="/sources/">
  <h1>Official sources</h1>
  <p class="lead">
    Canonical URLs in the pilot registry. Primary truth is always the official source — not this summary.
  </p>

  <ul class="card-list">
    {sources.map((s) => (
      <SourceCard source={s} />
    ))}
  </ul>
</BaseLayout>
