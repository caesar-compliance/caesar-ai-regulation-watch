{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/monitoring-source-config.schema.json",
  "title": "Caesar AI Regulation Watch — Monitoring source config batch",
  "description": "Adapter/config pack for watcher-eligible official sources. Not legal advice. No client evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "monitoring_source_config_batch_id",
    "generated_at",
    "access_date",
    "product_version",
    "watcher_eligibility_batch_id",
    "legal_safe_note",
    "no_broad_scraping",
    "no_competitor_source",
    "client_use_allowed",
    "final_evidence_allowed",
    "configs"
  ],
  "properties": {
    "monitoring_source_config_batch_id": {
      "type": "string",
      "pattern": "^source-configs-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "access_date": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "watcher_eligibility_batch_id": {
      "type": "string",
      "pattern": "^watcher-eligibility-[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_broad_scraping": { "type": "boolean", "const": true },
    "no_competitor_source": { "type": "boolean", "const": true },
    "client_use_allowed": { "type": "boolean", "const": false },
    "final_evidence_allowed": { "type": "boolean", "const": false },
    "configs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceConfig" }
    }
  },
  "$defs": {
    "sourceConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "jurisdiction_id",
        "official_url",
        "monitoring_method",
        "adapter_type",
        "allowed_to_fetch",
        "fetch_scope",
        "diff_policy",
        "rate_limit_note",
        "no_broad_scraping",
        "no_competitor_source",
        "client_use_allowed",
        "final_evidence_allowed",
        "verified_on_source",
        "limitations"
      ],
      "properties": {
        "source_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "jurisdiction_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "official_url": { "type": "string", "format": "uri" },
        "monitoring_method": {
          "type": "string",
          "enum": [
            "url_status_check",
            "page_metadata_check",
            "feed_check",
            "api_check",
            "manual_only"
          ]
        },
        "adapter_type": {
          "type": "string",
          "enum": ["static_page", "feed", "official_api", "manual_only"]
        },
        "allowed_to_fetch": { "type": "boolean" },
        "fetch_scope": {
          "type": "string",
          "enum": [
            "status_only",
            "metadata_only",
            "feed_entries",
            "api_metadata",
            "not_fetched"
          ]
        },
        "diff_policy": {
          "type": "string",
          "enum": [
            "no_text_storage",
            "metadata_only",
            "title_date_url_only"
          ]
        },
        "rate_limit_note": { "type": "string", "minLength": 1 },
        "no_broad_scraping": { "type": "boolean", "const": true },
        "no_competitor_source": { "type": "boolean", "const": true },
        "client_use_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "verified_on_source": { "type": "boolean", "const": false },
        "limitations": { "type": "string", "minLength": 1 },
        "not_fetched_this_run": { "type": "boolean" },
        "requires_human_review": { "type": "boolean" }
      }
    }
  }
}
