---
import type { CountryStatus } from "../lib/tracker-data";

interface Props {
  items: CountryStatus[];
  linkBase?: string;
}

const { items, linkBase = "/jurisdictions/" } = Astro.props;

const byRegion = items.reduce(
  (acc, cs) => {
    const list = acc.get(cs.region) ?? [];
    list.push(cs);
    acc.set(cs.region, list);
    return acc;
  },
  new Map<string, CountryStatus[]>(),
);

const regions = [...byRegion.entries()].sort(([a], [b]) => a.localeCompare(b));
---

<div class="tracker-map" aria-label="World regions — jurisdiction status (skeleton map)">
  <p class="tracker-map__note">
    Skeleton status map (CSS regions, not geographic boundaries). Click a jurisdiction for profile
    and sources. Full choropleth map planned in a later task.
  </p>
  <svg
    class="tracker-map__svg"
    viewBox="0 0 800 360"
    role="img"
    aria-label="Abstract world regions diagram"
  >
    <rect x="0" y="0" width="800" height="360" fill="var(--color-accent-soft)" rx="8" />
    <text x="400" y="28" text-anchor="middle" class="tracker-map__svg-title">
      Caesar Regulation Watch — regional coverage (pilot)
    </text>
    {
      regions.map(([region], i) => {
        const col = i % 3;
        const row = Math.floor(i / 3);
        const x = 40 + col * 250;
        const y = 50 + row * 100;
        const count = byRegion.get(region)?.length ?? 0;
        return (
          <g>
            <rect
              x={x}
              y={y}
              width="220"
              height="80"
              rx="6"
              fill="var(--color-surface)"
              stroke="var(--color-border)"
            />
            <text x={x + 12} y={y + 24} class="tracker-map__region-label">
              {region}
            </text>
            <text x={x + 12} y={y + 48} class="tracker-map__region-meta">
              {count} jurisdiction{count === 1 ? "" : "s"}
            </text>
          </g>
        );
      })
    }
  </svg>

  <div class="tracker-map__regions">
    {
      regions.map(([region, regionItems]) => (
        <section class="tracker-map__region-block">
          <h3 class="tracker-map__region-heading">{region}</h3>
          <ul class="tracker-map__country-list">
            {regionItems
              .sort((a, b) => a.country_name.localeCompare(b.country_name))
              .map((cs) => (
                <li>
                  <a
                    href={`${linkBase}${cs.jurisdiction_id}/`}
                    class={`tracker-map__country-link tracker-map__country-link--${cs.status_bucket}`}
                  >
                    <span class="tracker-map__country-name">{cs.country_name}</span>
                    <span class="tracker-map__country-status">{cs.status_label}</span>
                  </a>
                </li>
              ))}
          </ul>
        </section>
      ))
    }
  </div>
</div>
