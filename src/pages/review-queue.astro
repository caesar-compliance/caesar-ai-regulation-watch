---
import BaseLayout from "../layouts/BaseLayout.astro";
import { PROJECT_VERSION_LABEL } from "../lib/project-version";
import {
  getReviewQueueCards,
  getReviewQueueSummary,
  getSourceFreshnessSummary,
  getOperatorReviewSummary,
  REVIEW_STATUS_LABELS,
} from "../lib/regulation-review-queue";
import { getJurisdictions } from "../lib/data";
import { humanizeId } from "../lib/format";

const cards = getReviewQueueCards();
const summary = getReviewQueueSummary();
const freshnessSummary = getSourceFreshnessSummary();
const operatorSummary = getOperatorReviewSummary();
const jurisdictions = getJurisdictions();
const jMap = Object.fromEntries(jurisdictions.map((j) => [j.jurisdiction_id, j.name]));

const priorities = ["high", "medium", "low"];
const statuses = [
  "review_required",
  "in_review",
  "needs_source_check",
  "needs_legal_review",
  "accepted_for_tracking",
  "dismissed",
].filter((s) => cards.some((c) => c.review_status === s));
const sources = [...new Set(cards.map((c) => c.source_key))].sort();
const topics = [...new Set(cards.flatMap((c) => c.topic_tags))].sort();
const decisionCounts = operatorSummary.decision_counts ?? {};
---

<BaseLayout
  title="Regulation review queue"
  currentPath="/review-queue/"
  description="Read-only regulation monitoring review queue with source freshness signals — metadata only, not legal advice."
>
  <div data-filter-page>
    <h1>Regulation review queue</h1>
    <p class="lead">
      {PROJECT_VERSION_LABEL} — Backend-derived review candidates with operator decision state (T082).
      Read-only public view; decisions are recorded locally in YAML and rebuilt into exports.
    </p>

    <div class="banner banner--review" role="note">
      <strong>{summary.total} candidates</strong> · {summary.review_required} review_required ·{" "}
      {summary.in_review} in_review · {summary.needs_source_check} needs source check ·{" "}
      {summary.accepted_for_tracking} tracking only · {summary.dismissed} dismissed · Cron:{" "}
      <strong>disabled</strong> · Not legal advice.
    </div>

    <section class="tracker-section">
      <h2>Operator decisions (T082)</h2>
      <div class="metrics-strip metrics-strip--monitoring">
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{operatorSummary.decision_count ?? 0}</span>
          <span class="metrics-strip__label">Local decisions</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{summary.with_operator_decision ?? 0}</span>
          <span class="metrics-strip__label">Applied to queue</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{decisionCounts.mark_in_review ?? 0}</span>
          <span class="metrics-strip__label">Mark in review</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{decisionCounts.needs_source_check ?? 0}</span>
          <span class="metrics-strip__label">Needs source check</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{decisionCounts.accept_for_tracking ?? 0}</span>
          <span class="metrics-strip__label">Accept tracking</span>
        </div>
      </div>
      <p>
        Edit <code>data/runtime/operator-review-decisions.yml</code> then rebuild exports.
        Operator guide: <code>docs/OPERATOR_REVIEW_WORKFLOW.md</code> in the repository.
      </p>
      <p>
        <a href="/data/operator-review-summary.json">operator-review-summary.json</a> ·{" "}
        <a href="/data/review-packets-index.json">review-packets-index.json</a>
      </p>
    </section>

    <section class="tracker-section">
      <h2>Source freshness summary</h2>
      <div class="metrics-strip metrics-strip--monitoring">
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{freshnessSummary.fresh ?? 0}</span>
          <span class="metrics-strip__label">Fresh (automated)</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{freshnessSummary.aging ?? 0}</span>
          <span class="metrics-strip__label">Aging</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{freshnessSummary.stale ?? 0}</span>
          <span class="metrics-strip__label">Stale</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{freshnessSummary.manual_review_needed ?? 0}</span>
          <span class="metrics-strip__label">Manual review needed</span>
        </div>
        <div class="metrics-strip__item">
          <span class="metrics-strip__value">{freshnessSummary.not_automated ?? 0}</span>
          <span class="metrics-strip__label">Not automated</span>
        </div>
      </div>
      <p>
        <a href="/runtime-health/">Runtime health</a> ·{" "}
        <a href="/data/source-freshness.json">source-freshness.json</a> ·{" "}
        <a href="/data/regulation-review-queue.json">regulation-review-queue.json</a>
      </p>
    </section>

    <div class="filter-bar">
      <label>
        Priority
        <select data-filter-key="priority">
          <option value="">All</option>
          {priorities.map((p) => (
            <option value={p}>{humanizeId(p)}</option>
          ))}
        </select>
      </label>
      <label>
        Review status
        <select data-filter-key="status">
          <option value="">All</option>
          {statuses.map((s) => (
            <option value={s}>{REVIEW_STATUS_LABELS[s] ?? humanizeId(s)}</option>
          ))}
        </select>
      </label>
      <label>
        Has operator decision
        <select data-filter-key="hasDecision">
          <option value="">All</option>
          <option value="yes">With decision</option>
          <option value="no">No decision yet</option>
        </select>
      </label>
      <label>
        Jurisdiction
        <select data-filter-key="jurisdiction">
          <option value="">All</option>
          {jurisdictions.map((j) => (
            <option value={j.jurisdiction_id}>{j.name}</option>
          ))}
        </select>
      </label>
      <label>
        Source
        <select data-filter-key="source">
          <option value="">All</option>
          {sources.map((s) => (
            <option value={s}>{s}</option>
          ))}
        </select>
      </label>
      <label>
        Topic
        <select data-filter-key="topic">
          <option value="">All</option>
          {topics.map((t) => (
            <option value={t}>{humanizeId(t)}</option>
          ))}
        </select>
      </label>
      <p class="filter-bar__count" data-filter-count />
    </div>

    <ul class="card-list" data-regulation-review-queue-list>
      {
        cards.map((card) => {
          const op = card.operator_decision;
          const statusLabel =
            REVIEW_STATUS_LABELS[card.review_status] ?? humanizeId(card.review_status);
          return (
            <li
              class="card filter-item"
              data-filter-item
              data-priority={card.priority}
              data-status={card.review_status}
              data-jurisdiction={card.jurisdiction_id}
              data-source={card.source_key}
              data-topic={card.topic_tags.join(" ")}
              data-has-decision={op ? "yes" : "no"}
            >
              <div class="card__meta">
                <span class={`badge badge--${card.priority === "high" ? "warn" : "type"}`}>
                  {card.priority} priority
                </span>
                <span class={`badge badge--decision-${card.review_status}`}>
                  {statusLabel}
                </span>
                {
                  card.review_status === "accepted_for_tracking" && (
                    <span class="badge badge--tracking-only">Tracking only — not legal verification</span>
                  )
                }
                {
                  card.review_required && card.review_status !== "dismissed" && (
                    <span class="badge badge--review">Review required</span>
                  )
                }
                {op && <span class="badge badge--type">Operator: {humanizeId(op.decision)}</span>}
              </div>
              <h2 class="card__title-sm">{card.title}</h2>
              <p class="card__excerpt">
                <small>
                  {jMap[card.jurisdiction_id] ?? card.jurisdiction_id} · {card.source_title} ·{" "}
                  <span class="mono">{card.change_type}</span>
                  {card.detected_at && ` · ${card.detected_at.slice(0, 10)}`}
                </small>
              </p>
              {card.metadata_summary && <p>{card.metadata_summary}</p>}
              {
                op?.public_note && (
                  <p class="card__excerpt">
                    <strong>Public note:</strong> {op.public_note}
                  </p>
                )
              }
              {
                op?.rationale && (
                  <p class="card__excerpt">
                    <small>
                      <strong>Rationale:</strong> {op.rationale}
                    </small>
                  </p>
                )
              }
              {
                card.review_status === "needs_source_check" && (
                  <p class="card__excerpt warn-text">
                    <strong>Source check needed</strong> — confirm official URL before any tracker change.
                    {op?.source_checked_url && (
                      <>
                        {" "}
                        <a href={op.source_checked_url} target="_blank" rel="noopener noreferrer">
                          Checked URL ↗
                        </a>
                      </>
                    )}
                  </p>
                )
              }
              {
                card.source_url && (
                  <p>
                    <a href={card.source_url} target="_blank" rel="noopener noreferrer">
                      Official source ↗
                    </a>
                  </p>
                )
              }
              <p class="card__excerpt">
                <small>{card.safety_notes}</small>
              </p>
            </li>
          );
        })
      }
    </ul>

    {
      cards.length === 0 && (
        <p>No regulation review candidates in current export. Run a bounded worker pilot and rebuild exports.</p>
      )
    }
  </div>

  <section class="tracker-section">
    <h2>Registry human review queue (legacy)</h2>
    <p>
      Curated registry URL/content verification items remain in{" "}
      <a href="/data/review-queue.json">review-queue.json</a> and{" "}
      <a href="/content-review/">content review</a> — separate from backend monitoring candidates above.
    </p>
  </section>

  <script is:inline src="/scripts/regulation-review-queue-filter.js"></script>
</BaseLayout>

<style>
  .warn-text {
    color: var(--color-warn-text, #8a4510);
  }
</style>
