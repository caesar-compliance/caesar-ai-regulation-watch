---
import type { AutomationFirstMetrics } from "../lib/tracker-data";

interface Props {
  metrics: AutomationFirstMetrics;
}

const { metrics } = Astro.props;
---

<div class="metrics-strip" role="group" aria-label="Automation-first tracker metrics">
  <div class="metrics-strip__card">
    <strong>{metrics.jurisdiction_count}</strong>
    <span>Jurisdictions tracked</span>
  </div>
  <div class="metrics-strip__card">
    <strong>{metrics.adopted_or_enforced_count}</strong>
    <span>Adopted / enforcement signals</span>
  </div>
  <div class="metrics-strip__card">
    <strong>{metrics.proposed_or_consultation_count}</strong>
    <span>Proposed / consultation signals</span>
  </div>
  <div class="metrics-strip__card">
    <strong>{metrics.regulatory_update_count}</strong>
    <span>Regulatory updates</span>
  </div>
  {
    metrics.offline_metadata_adapter_update_count != null && (
      <div class="metrics-strip__card">
        <strong>{metrics.offline_metadata_adapter_update_count}</strong>
        <span>Metadata adapter updates</span>
      </div>
    )
  }
  <div class="metrics-strip__card">
    <strong>{metrics.updates_last_30_days}</strong>
    <span>Updates (last 30 days)</span>
  </div>
  {
    metrics.average_regulation_maturity_score != null && (
      <div class="metrics-strip__card">
        <strong>{metrics.average_regulation_maturity_score}</strong>
        <span>Avg maturity index (heuristic)</span>
      </div>
    )
  }
</div>
