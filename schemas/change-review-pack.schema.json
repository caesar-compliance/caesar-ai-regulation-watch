{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/change-review-pack.schema.json",
  "title": "Caesar AI Regulation Watch — Metadata change review pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "change_review_pack_id",
    "generated_at",
    "product_version",
    "live_metadata_run_id",
    "legal_safe_note",
    "no_full_text_storage",
    "client_use_allowed",
    "final_evidence_allowed",
    "reviews"
  ],
  "properties": {
    "change_review_pack_id": {
      "type": "string",
      "pattern": "^change-review-pack-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "live_metadata_run_id": {
      "type": "string",
      "pattern": "^live-metadata-run-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "previous_reference_run_id": {
      "type": "string",
      "pattern": "^monitoring-run-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_full_text_storage": { "type": "boolean", "const": true },
    "client_use_allowed": { "type": "boolean", "const": false },
    "final_evidence_allowed": { "type": "boolean", "const": false },
    "reviews": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceReview" }
    }
  },
  "$defs": {
    "sourceReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "official_url",
        "review_status",
        "change_detected",
        "human_review_required",
        "client_use_allowed",
        "final_evidence_allowed"
      ],
      "properties": {
        "source_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "official_url": { "type": "string", "format": "uri" },
        "previous_metadata_summary": { "type": "object" },
        "current_metadata_summary": { "type": "object" },
        "changed_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "change_detected": { "type": "boolean" },
        "review_status": {
          "type": "string",
          "enum": [
            "no_change_observed",
            "metadata_change_needs_review",
            "check_failed_needs_review",
            "redirect_changed_needs_review"
          ]
        },
        "human_review_required": { "type": "boolean" },
        "client_use_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "notes": { "type": "string" }
      }
    }
  }
}
