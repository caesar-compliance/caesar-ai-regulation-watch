{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/topic.schema.json",
  "title": "Caesar AI Regulation Watch — Tracker topic tag",
  "description": "Topic/category label for automation-first tracker filters.",
  "type": "object",
  "additionalProperties": false,
  "required": ["topic_id", "label"],
  "properties": {
    "topic_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "label": { "type": "string", "minLength": 1 },
    "parent_topic_id": {
      "type": ["string", "null"],
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "description": { "type": "string" }
  }
}
