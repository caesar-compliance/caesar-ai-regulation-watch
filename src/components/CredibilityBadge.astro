---
import { getTaxonomies, taxonomyLabel } from "../lib/data";

interface Props {
  level: string;
}

const { level } = Astro.props;
const taxonomies = getTaxonomies();
const label = taxonomyLabel(taxonomies, "source-credibility-levels", level);
---

<span class={`badge badge--credibility-${level}`} title={level}>{label}</span>
