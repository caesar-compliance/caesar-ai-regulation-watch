{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/evidence-export-candidate-review.schema.json",
  "title": "Caesar AI Regulation Watch — Evidence export candidate review batch",
  "description": "Governance/export-readiness review for evidence export candidates only. Not final evidence. Not client evidence. Not legal advice.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_export_candidate_review_batch_id",
    "review_date",
    "verifier_type",
    "legal_safe_note",
    "candidate_reviews"
  ],
  "properties": {
    "evidence_export_candidate_review_batch_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "review_date": {
      "type": "string",
      "format": "date"
    },
    "verifier_type": {
      "type": "string",
      "enum": ["human_reviewer", "automated_check_pending", "curator_batch"]
    },
    "legal_safe_note": {
      "type": "string",
      "minLength": 1
    },
    "candidate_reviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_review_id",
          "candidate_id",
          "review_date",
          "reviewer_type",
          "review_purpose",
          "candidate_review_status",
          "governance_review_summary",
          "checks_performed",
          "human_review_required",
          "client_use_allowed",
          "final_evidence_allowed",
          "qualified_advisor_review_required",
          "legal_safe_note"
        ],
        "properties": {
          "candidate_review_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "candidate_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "review_date": {
            "type": "string",
            "format": "date"
          },
          "reviewer_type": {
            "type": "string",
            "enum": ["human_reviewer", "automated_check_pending", "curator_batch"]
          },
          "review_purpose": {
            "type": "string",
            "const": "governance_export_readiness_only"
          },
          "candidate_review_status": {
            "type": "string",
            "enum": [
              "reviewed_for_internal_governance_only",
              "needs_more_source_review",
              "needs_mapping_review",
              "rejected_for_export_candidate_use",
              "review_not_applicable"
            ]
          },
          "content_review_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "governance_review_summary": {
            "type": "string",
            "minLength": 1
          },
          "checks_performed": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "candidate_understandable",
                "content_review_present",
                "disclaimers_present",
                "blocking_reasons_consistent",
                "suggested_controls_plausible",
                "suggested_evidence_plausible",
                "not_client_evidence_confirmed",
                "not_final_evidence_confirmed",
                "simulation_blocked_confirmed"
              ]
            }
          },
          "governance_findings": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "recommended_next_action": {
            "type": "string",
            "enum": [
              "no_action_until_qualified_review",
              "complete_source_verification",
              "complete_mapping_review",
              "reject_for_export_candidate_use",
              "not_applicable_simulation_blocked"
            ]
          },
          "human_review_required": {
            "type": "boolean",
            "const": true
          },
          "client_use_allowed": {
            "type": "boolean",
            "const": false
          },
          "final_evidence_allowed": {
            "type": "boolean",
            "const": false
          },
          "qualified_advisor_review_required": {
            "type": "boolean",
            "const": true
          },
          "legal_safe_note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
