{
  "name": "caesar-ai-regulation-watch",
  "type": "module",
  "version": "1.0.8",
  "private": true,
  "description": "Read-only static site for Caesar AI Regulation Watch pilot data",
  "scripts": {
    "validate:data": "node scripts/validate-data.mjs",
    "validate:source-adapters": "node scripts/validate-source-adapter-allowlist.mjs",
    "validate:manual-source-intake": "node scripts/validate-manual-source-intake-runs.mjs",
    "validate:network-dry-run-approvals": "node scripts/validate-network-dry-run-approvals.mjs",
    "validate:single-network-dry-run-executions": "node scripts/validate-single-network-dry-run-executions.mjs",
    "validate:manual-review-promotions": "node scripts/validate-manual-review-promotions.mjs",
    "validate:manual-review-decisions": "node scripts/validate-manual-review-decisions.mjs",
    "build:manual-review-promotion": "node scripts/build-manual-review-promotion.mjs",
    "build:manual-review-decision-summary": "node scripts/build-manual-review-decision-summary.mjs",
    "build:network-dry-run-plan": "node scripts/build-network-dry-run-plan.mjs",
    "run:approved-network-dry-run": "node scripts/run-approved-network-dry-run.mjs",
    "run:manual-source-intake": "node scripts/run-manual-source-intake.mjs",
    "build:source-adapter-fixtures": "node scripts/parse-source-adapter-fixture.mjs",
    "build:regulatory-updates": "node scripts/build-regulatory-updates-from-metadata.mjs",
    "generate:evidence-candidates": "node scripts/generate-evidence-export-candidates.mjs",
    "generate:exports": "node scripts/generate-static-exports.mjs",
    "dev": "astro dev",
    "build:site": "astro build",
    "build:search": "pagefind --site dist",
    "check:urls": "node scripts/check-official-urls.mjs",
    "watch:official": "node scripts/run-official-source-watchers.mjs",
    "watch:simulate-change": "node scripts/simulate-watcher-change.mjs",
    "watch:simulate-feed-change": "node scripts/simulate-feed-change.mjs",
    "watch:simulate-api-change": "node scripts/simulate-api-change.mjs",
    "monitoring:report": "node scripts/run-monitoring-cycle.mjs --mode=report_only",
    "monitoring:cycle": "node scripts/run-monitoring-cycle.mjs --mode=write",
    "monitoring:cycle:dry-run": "node scripts/run-monitoring-cycle.mjs --mode=dry-run",
    "monitoring:summary": "node scripts/summarize-monitoring-changes.mjs",
    "monitoring:pack": "node scripts/run-monitoring-pack.mjs",
    "monitoring:live-metadata": "node scripts/run-live-metadata-pilot.mjs",
    "monitoring:live-artifact": "node scripts/build-live-metadata-review-artifact.mjs",
    "monitoring:policy-check": "node scripts/check-monitoring-policy.mjs --artifact-dir tmp/live-metadata-review-pack",
    "source:verify:autonomous": "node scripts/run-autonomous-source-verification.mjs",
    "build": "npm run build:regulatory-updates && npm run generate:evidence-candidates && npm run validate:data && npm run generate:exports && npm run build:site && npm run build:search",
    "build:pages": "ASTRO_BASE_PATH=/caesar-ai-regulation-watch/ ASTRO_SITE=https://caesar-compliance.github.io npm run build && ASTRO_BASE_PATH=/caesar-ai-regulation-watch/ node scripts/rewrite-dist-base-path.mjs",
    "build:custom-domain": "ASTRO_SITE=https://regulation-watch.caesar.no npm run build",
    "verify:dist": "node scripts/verify-dist-output.mjs",
    "preview": "astro preview"
  },
  "dependencies": {
    "astro": "^5.7.10",
    "fast-xml-parser": "^4.5.6",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "pagefind": "^1.3.0"
  }
}
