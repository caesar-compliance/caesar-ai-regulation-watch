{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://caesar.no/schemas/caesar-ai-regulation-watch/source-verification-result.schema.json",
  "title": "Caesar AI Regulation Watch — Source verification result",
  "description": "Item-level manual source URL check results. Not final source verification. Not publication.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_verification_results_id",
    "generated_at",
    "product_version",
    "legal_safe_note",
    "no_live_collection",
    "no_scheduled_monitoring",
    "results"
  ],
  "properties": {
    "source_verification_results_id": {
      "type": "string",
      "pattern": "^source-verification-results-[0-9]{4}-[0-9]{2}-[0-9]{2}-v[0-9]{3}$"
    },
    "generated_at": { "type": "string", "format": "date" },
    "product_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "legal_safe_note": { "type": "string", "minLength": 1 },
    "no_live_collection": { "type": "boolean", "const": true },
    "no_scheduled_monitoring": { "type": "boolean", "const": true },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/resultRecord" }
    }
  },
  "$defs": {
    "gateState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_on_source",
        "client_use_allowed",
        "client_evidence_allowed",
        "final_evidence_allowed",
        "legal_change_claimed"
      ],
      "properties": {
        "verified_on_source": { "type": "boolean", "const": false },
        "client_use_allowed": { "type": "boolean", "const": false },
        "client_evidence_allowed": { "type": "boolean", "const": false },
        "final_evidence_allowed": { "type": "boolean", "const": false },
        "legal_change_claimed": { "type": "boolean", "const": false }
      }
    },
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "final_source_verification_completed",
        "publication_allowed",
        "public_export_allowed",
        "evidence_export_allowed",
        "metadata_only",
        "stores_full_text",
        "requires_final_legal_approval"
      ],
      "properties": {
        "final_source_verification_completed": { "type": "boolean", "const": false },
        "publication_allowed": { "type": "boolean", "const": false },
        "public_export_allowed": { "type": "boolean", "const": false },
        "evidence_export_allowed": { "type": "boolean", "const": false },
        "metadata_only": { "type": "boolean", "const": true },
        "stores_full_text": { "type": "boolean", "const": false },
        "requires_final_legal_approval": { "type": "boolean", "const": true }
      }
    },
    "resultScope": {
      "type": "string",
      "const": "source_url_manual_check_only"
    },
    "resultStatus": {
      "type": "string",
      "enum": ["draft", "recorded", "superseded"]
    },
    "itemResult": {
      "type": "string",
      "enum": ["manual_pass", "manual_fail", "needs_follow_up", "not_checked"]
    },
    "overallResult": {
      "type": "string",
      "enum": ["partial_pass_needs_follow_up", "blocked", "ready_for_final_legal_review"]
    },
    "checklistItemKey": {
      "type": "string",
      "enum": [
        "source_url_accessibility_check",
        "source_identity_match_check",
        "publication_date_match_check",
        "title_match_check",
        "summary_rewrite_check",
        "topic_jurisdiction_confirmation_check",
        "no_full_text_storage_check",
        "public_export_exclusion_check"
      ]
    },
    "itemResultRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "result", "checked_by_role", "checked_at"],
      "properties": {
        "item_id": { "$ref": "#/$defs/checklistItemKey" },
        "result": { "$ref": "#/$defs/itemResult" },
        "note": { "type": "string", "maxLength": 500 },
        "checked_by_role": { "type": "string", "minLength": 1 },
        "checked_at": { "type": "string", "format": "date" }
      }
    },
    "resultRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_id",
        "checklist_id",
        "draft_update_id",
        "draft_update_path",
        "source_adapter_id",
        "source_id",
        "source_url",
        "result_scope",
        "result_status",
        "item_results",
        "overall_result",
        "blockers_remaining",
        "next_required_step",
        "created_at",
        "updated_at",
        "gates",
        "safety"
      ],
      "properties": {
        "result_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "checklist_id": { "type": "string", "pattern": "^T[0-9]{3}-[0-9]{3}$" },
        "draft_update_id": { "type": "string", "minLength": 1 },
        "draft_update_path": { "type": "string", "pattern": "^data/regulatory-updates/drafts/" },
        "source_adapter_id": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string", "minLength": 1 },
        "source_url": { "type": "string", "format": "uri" },
        "result_scope": { "$ref": "#/$defs/resultScope" },
        "result_status": { "$ref": "#/$defs/resultStatus" },
        "item_results": {
          "type": "array",
          "minItems": 8,
          "items": { "$ref": "#/$defs/itemResultRecord" }
        },
        "overall_result": { "$ref": "#/$defs/overallResult" },
        "blockers_remaining": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "next_required_step": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" },
        "gates": { "$ref": "#/$defs/gateState" },
        "safety": { "$ref": "#/$defs/safetyFlags" }
      }
    }
  }
}
