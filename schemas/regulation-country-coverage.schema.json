{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RegulationCountryCoverageExport",
  "type": "object",
  "required": ["jurisdictions", "generated_at"],
  "properties": {
    "generated_at": { "type": "string" },
    "review_required": { "type": "boolean" },
    "jurisdictions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["jurisdiction_id", "monitored_sources"],
        "properties": {
          "jurisdiction_id": { "type": "string" },
          "monitored_sources": { "type": "array" }
        }
      }
    }
  }
}
